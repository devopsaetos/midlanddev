        <template id="purchase_requisition_template_view">

            <t t-call="web.html_container">
                <t t-call="purchase_requisitions.pr_customized_header"/>
                <t t-call="purchase_requisitions.pr_customized_footer"/>
                <t t-call="web.external_layout">
                    <t t-foreach="docs" t-as="o">
                        <div class="page">
                            <div class="row">
                                <div class="col-12">
                                    <h2 class="text-center text-capitalize" style="color: #191970;">
                                        Purchase Requisition
                                    </h2>
                                </div>
                            </div>
                            <br/>
                            <div class="row">
                                <div class="col-6">
                                    <div class="row">
                                        <div class="col-4">
                                            <b>Employee:</b>
                                        </div>
                                        <div class="col-8">
                                            <t t-if="o.employee_id.name">
                                                <span t-esc="o.employee_id.name"/>
                                            </t>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-4">
                                            <b>Department:</b>
                                        </div>
                                        <div class="col-8">
                                            <t t-if="o.department_id.name">
                                                <span t-esc="o.department_id.name"/>
                                            </t>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-4">
                                            <b>Responsible:</b>
                                        </div>
                                        <div class="col-8">
                                            <t t-if="o.requisition_responsible_id.name">
                                                <span t-esc="o.requisition_responsible_id.name"/>
                                            </t>
                                        </div>
                                    </div>
<!--                                    <div class="row">-->
<!--                                        <div class="col-4">-->
<!--                                            <b>Company:</b>-->
<!--                                        </div>-->
<!--                                        <div class="col-8">-->
<!--                                            <t t-if="o.company_id.name">-->
<!--                                                <span t-esc="o.company_id.name"/>-->
<!--                                            </t>-->
<!--                                        </div>-->
<!--                                    </div>-->
                                </div>
                                <div class="col-1"/>
                                <div class="col-5">
                                    <div class="row">
                                        <div class="col-5">
                                            <b>Requisition Date:</b>
                                        </div>
                                        <div class="col-6">
                                            <t t-if="o.requisition_date">
                                                <span t-field="o.requisition_date"
                                                      t-options='{"format": "dd-MM-yyyy"}'/>
                                            </t>
                                        </div>
                                    </div>

<!--                                    <div class="row">-->
<!--                                        <div class="col-5">-->
<!--                                            <b>Received Date:</b>-->
<!--                                        </div>-->
<!--                                        <div class="col-6">-->
<!--                                            <t t-if="o.received_date">-->
<!--                                                <span t-field="o.received_date" t-options='{"format": "dd-MM-yyyy"}'/>-->
<!--                                            </t>-->
<!--                                        </div>-->
<!--                                    </div>-->
                                    <div class="row">
                                        <div class="col-5">
                                            <b>Deadline:</b>
                                        </div>
                                        <div class="col-6">
                                            <t t-if="o.requisition_deadline_date">
                                                <span t-field="o.requisition_deadline_date"
                                                      t-options='{"format": "dd-MM-yyyy"}'/>
                                            </t>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-5">
                                            <b>Branch:</b>
                                        </div>
                                        <div class="col-6">
                                            <t t-if="o.branch_id.name">
                                                <span t-esc="o.branch_id.name"/>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">

                                <div class="col-2">
                                    <b>Company:</b>
                                </div>
                                <div class="col-10">
                                    <span t-field="o.company_id.name"/>
                                </div>
                            </div>

                            <table class="table table-sm table-bordered"
                                   style="margin-top:20px;font-family:'Roboto',sans-serif;font-size:15px;">
                                <thead>
                                    <tr>
                                        <!--                                        <th>Requisition Action</th>-->
                                        <th>Product</th>
                                        <th>Description</th>
                                        <th>Quantity</th>
                                        <th>Unit Of Measure</th>
                                        <th>Unit Price</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody class="consumed_tbody">
                                    <t t-foreach="o.requisition_line_ids" t-as="requisition">
                                        <tr>
                                            <!--                                            <td>-->
                                            <!--                                                <span t-field="requisition.requisition_action"/>-->
                                            <!--                                            </td>-->
                                            <td>
                                                <span t-field="requisition.product_id.name"/>
                                            </td>
                                            <td>
                                                <span t-field="requisition.name"/>
                                            </td>
                                            <td>
                                                <span t-field="requisition.qty"
                                                      t-options='{"widget": "float", "precision": 2}'/>
                                            </td>
                                            <td>
                                                <span t-field="requisition.uom_id.name"/>
                                            </td>
                                            <td>
                                                <span t-field="requisition.price_unit"
                                                      t-options='{"widget": "float", "precision": 2}'/>
                                            </td>
                                            <td>
                                                <span t-field="requisition.total_val"
                                                      t-options='{"widget": "float", "precision": 2}'/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>


                            </table>
                            <h7 style="margin-top:50px;">
                                <b>Amount in Words:</b>
                                <t t-if="o.currency_id">
                                    <span t-esc="o.currency_id.amount_to_text(sum(line.total_val for line in docs.requisition_line_ids))"/>
                                </t>
                            </h7>


                            <div class="row"
                                 style="font-family:'Roboto',sans-serif;font-size:15px;color:#191970; margin-top:200px">
                                <div class="col-4 text-center">
                                    <t t-esc="docs.create_uid.name"/>
                                </div>
                                <div class="col-4"/>
                                <div class="col-4"/>
                            </div>
                            <div class="row" style="font-family:'Roboto',sans-serif;font-size:15px;color:#191970;">
                                <div class="col-4 text-center" style="text-decoration:overline">Prepared By</div>
                                <div class="col-4 text-center" style="text-decoration:overline">Checked By</div>
                                <div class="col-4 text-center" style="text-decoration:overline">Approved By</div>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="paperformat_purchase_req" model="report.paperformat">
            <field name="name">Customized Paper Format</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">25</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">25</field>
            <field name="dpi">90</field>
        </record>

        <report id="purchase_requisition_report_id"
                string="Purchase Requisition"
                model="material.purchase.requisition"
                report_type="qweb-pdf"
                file="purchase_requisitions.purchase_requisition_template_view"
                name="purchase_requisitions.purchase_requisition_template_view"
                paperformat="purchase_requisitions.paperformat_purchase_req"/>

    </data>
</odoo>
