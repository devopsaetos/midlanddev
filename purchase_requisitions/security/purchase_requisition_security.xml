<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Privilege replaces category_id in Odoo 19 -->
        <record model="res.groups.privilege" id="privilege_purchase_requisition">
            <field name="name">Material Purchase Requisitions</field>
            <field name="sequence">3</field>
        </record>

        <record id="group_purchase_requisition_administrator" model="res.groups">
            <field name="name">Purchase Requisition Administrator</field>
            <field name="privilege_id" ref="privilege_purchase_requisition"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_requisition_department_manager" model="res.groups">
            <field name="name">Purchase Requisition Department Manager</field>
            <field name="privilege_id" ref="privilege_purchase_requisition"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_purchase_requisition_department_head" model="res.groups">
            <field name="name">Purchase Requisition Department Head</field>
            <field name="privilege_id" ref="privilege_purchase_requisition"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_purchase_requisition_ceo" model="res.groups">
            <field name="name">Purchase Requisition CEO</field>
            <field name="privilege_id" ref="privilege_purchase_requisition"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- User rule: see only own requisitions -->
        <record id="res_user_requisition_rule" model="ir.rule">
            <field name="name">Res User Requisition</field>
            <field name="model_id" ref="purchase_requisitions.model_material_purchase_requisition"/>
            <field name="domain_force">[('requisition_responsible_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Manager rule: see requisitions for their direct reports -->
        <record id="requisition_rule_manager" model="ir.rule">
            <field name="name">Rule to show all requisitions according to manager</field>
            <field name="model_id" ref="purchase_requisitions.model_material_purchase_requisition"/>
            <field name="domain_force">[('requisition_responsible_id.user_manager', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('purchase_requisitions.group_requisition_department_manager'))]"/>
        </record>

        <!-- HOD/CEO rule: see all requisitions -->
        <record id="requisition_rule_hod_ceo" model="ir.rule">
            <field name="name">Rule to show all requisitions to hod and ceo</field>
            <field name="model_id" ref="purchase_requisitions.model_material_purchase_requisition"/>
            <field name="domain_force">
                ['|', ('requisition_responsible_id', '!=', user.id), ('requisition_responsible_id', '=', False)]
            </field>
            <field name="groups" eval="[
                (4, ref('purchase_requisitions.group_purchase_requisition_department_head')),
                (4, ref('purchase_requisitions.group_purchase_requisition_ceo'))
            ]"/>
        </record>

        <!-- Multi-company rule -->
        <record model="ir.rule" id="purchase_requisition_comp_rule">
            <field name="name">Purchase Requisitions multi company</field>
            <field name="model_id" ref="model_material_purchase_requisition"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>