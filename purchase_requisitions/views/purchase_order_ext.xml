<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view for "purchase order" -->
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">view.purchase.order.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="rfq_type"/>
            </xpath>
            <xpath expr="//field[@name='origin']" position="before">
                <field name="requisition_responsible_id" force_save="1" options="{'no_open': True, 'no_create': True, 'no_edit': True, 'no_create_edit': True}"/>
                <field name="requisition_po_id" force_save="1" options="{'no_open': True, 'no_create': True, 'no_edit': True, 'no_create_edit': True}"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="before">
                <field name="category_id" context="{'from_purchasing': True}" force_save="1"
                       readonly="state in ('purchase', 'to approve', 'done', 'cancel')"
                       options="{'no_open': True, 'no_create': True, 'no_edit': True, 'no_create_edit': True}"/>
                <field name="product_expense" invisible="1" force_save="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="required">0</attribute>
                <attribute name="domain">[('categ_id', '=', category_id)]</attribute>
                <attribute name="readonly">state in ('purchase', 'to approve', 'done', 'cancel')</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="after">
                <field name="requisition_line_id" invisible="1"/>
            </xpath>
        </field>
    </record>

