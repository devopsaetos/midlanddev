        <record id="action_requisition_rfq" model="ir.actions.act_window">
            <field name="name">Requisition Orders</field>
            <field name="res_model">requisition.order</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to create a Requisition Order.
                </p>
                <p>
                    The requisition order contains the history of the discussion/negotiation
                    you had with your vendor. Once confirmed, a requisition order is converted into a final quotation order.
                </p>
            </field>
        </record>

        <menuitem action="action_requisition_rfq" id="menu_requisition_order"
                  parent="menu_purchase_requisition"
                  name="Requisition Orders"
                  sequence="2"/>

