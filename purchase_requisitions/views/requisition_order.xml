<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="requisition_view_form" model="ir.ui.view">
            <field name="name">requisition_view_form</field>
            <field name="model">requisition.order</field>
            <field name="arch" type="xml">
                <form string="requisition_form">
                    <header>
                        <button name="button_confirm" type="object" invisible="state != 'draft'"
                                string="Confirm Request"
                                id="draft_confirm"/>
                        <button name="button_approve" type="object" string="Approve"
                                invisible="state != 'requisition'"/>
                        <button name="button_draft" invisible="state != 'cancel'" string="Set to Draft" type="object"/>
                        <button name="button_cancel" invisible="state not in ('draft','approved','requisition')"
                                string="Cancel"
                                type="object"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,sent,requisition,approved"
                               readonly="1"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button type="object" name="purchase_order_button" class="oe_stat_button" icon="fa-book"
                                    invisible="quotation_order_count == 0">
                                <field name="quotation_order_count" widget="statinfo" string="RFQ/Quotations"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" string="Request for Quotation"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="issue_date" required="1"
                                       readonly="state in ('requisition', 'approved')"/>
                                <field name="creation_date"
                                       readonly="state in ('requisition', 'approved')"
                                       required="1"/>
                                <field name="closure_date"
                                       readonly="state in ('requisition', 'approved')"
                                       required="1"/>
                            </group>
                            <group>
                                <field name="rfq_type"
                                       readonly="state in ('requisition', 'approved')" invisible="1"/>
                                <field name="payment_terms" options="{'no_create': True,'no_open': True}"
                                       readonly="state in ('requisition', 'approved')"/>
                                <field name="currency_id" options="{'no_create': True,'no_open': True}" required="1"
                                       readonly="state in ('requisition', 'approved')"/>
                                <field name="company_id" options="{'no_create': True,'no_open': True}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Request Order Lines">
                                <field name="order_line_ids"
                                       readonly="state in ('requisition', 'approved')"
                                       widget="section_and_note_one2many"
                                       mode="list,kanban"
                                       context="{'default_type': context.get('default_type')}">
                                    <list string="Request Order Lines" editable="bottom">
                                        <field name="state" invisible="1"/>
                                        <field name="sequence" widget="handle"/>
                                        <field name="product_id"
                                               readonly="state in ('purchase', 'approved','done', 'cancel')"
                                               options="{'no_create': True,'no_open': True}"
                                               force_save="1"/>
                                        <field name="name" widget="section_and_note_text" force_save="1"/>
                                        <field name="price_unit"/>
                                        <field name="taxes_id" widget="many2many_tags" invisible="1"/>
                                        <field name="amount"/>
                                        <field name="schedule_date"/>
                                        <field name="warehouse_id" invisible="1"/>
                                        <field name="category_id" invisible="1"/>
                                    </list>
                                    <form>
                                        <field name="sequence" invisible="1"/>
                                        <group>
                                            <group>
                                                <field name="product_id"
                                                       required="1"
                                                       force_save="1"
                                                       widget="many2one_barcode"
                                                />
                                                <field name="price_unit"/>
                                                <field name="sequence" invisible="1"/>
                                            </group>
                                        </group>
                                        <field name="name"/>
                                        <field name="state" invisible="1"/>
                                    </form>
                                </field>
                                <notebook>
                                    <page string="Vendors">
                                        <group>
                                            <field name="partner_id" options="{'no_create': True,'no_open': True}"
                                                   readonly="state in ('requisition', 'approved')"/>
                                        </group>
                                    </page>
                                </notebook>
                                <field name="notes" class="oe_inline"
                                       placeholder="Define your terms and conditions ..."
                                       readonly="state in ('requisition', 'approved')"/>
                                <div class="oe_clear"/>
                            </page>
                            <page string="Order Line Details">
                                <field name="order_line" widget="one2many_list">
                                    <list string="Order Lines" editable="bottom" create="0" delete="0">
                                        <field name="product_id" invisible="1"/>
                                        <field name="name" widget="section_and_note_text" force_save="1" invisible="1"/>
                                        <field name="display_type" force_save="1" invisible="1"/>
                                        <field name="product_uom" options="{'no_create': True,'no_open': True}"
                                               invisible="1"/>
                                        <field name="category_id" options="{'no_create': True,'no_open': True}"
                                               force_save="1"/>
                                        <field name="warehouse_id" readonly="requisition_line_id != False"
                                               force_save="1"/>
                                        <field name="requisition_line_id" readonly="1" force_save="1"/>
                                        <field name="product_qty" invisible="1"/>
                                        <field name="price_unit" invisible="1"/>
                                        <field name="schedule_date" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Committee Member">
                                <group>
                                    <field name="member_committee_ids"
                                           options="{'no_create': True,'no_open': True}"
                                           readonly="state in ('requisition', 'approved')">
                                        <list>
                                            <field name="name" readonly="1"/>
                                            <!--                                            <field name="job_id" options="{'no_create': True,'no_open': True}"-->
                                            <!--                                                   readonly="1"/>-->
                                            <field name="department_id"
                                                   options="{'no_create': True,'no_open': True}" readonly="1"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

