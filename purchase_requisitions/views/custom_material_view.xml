        <!--        Material Purchase Requisition Lines Tree View For Requisition Poll-->
        <record id="action_accepted_material_purchase_requisition_lines" model="ir.actions.act_window">
            <field name="name">Approved Requisitions</field>
            <field name="res_model">requisition.line</field>
            <field name="view_mode">list</field>
            <field name="context">{'from_purchasing': True, 'group_by': 'requisition_id'}</field>
            <field name="domain">[('state', 'in', ('approved', 'rfq_created', 'qo_created'))]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create a Requisition, the first step of a new Request.
                </p>
                <p>
                    Once the Purchase Requisition is confirmed, it will become visible here.
                    You'll be able to create Purchase orders and Request For Quotation.
                    From the Action by selecting records.
                </p>
            </field>
        </record>

