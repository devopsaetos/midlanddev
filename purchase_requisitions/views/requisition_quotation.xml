    <record id="action_purchase_quotation" model="ir.actions.act_window">
        <field name="name">Requisition Quotation Order</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">quotation.order</field>
        <field name="context">{'group_by': 'origin', 'show_line_price': True, 'show_purchase': False, 'from_purchasing':
            True}
        </field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a quotation for quotation.
            </p>
            <p>
                The quotation contains the history of the discussion/negotiation
                you had with your vendor. Once confirmed, a quotation for
                quotation is converted into a final quotation order.
            </p>
        </field>
    </record>

    <menuitem id="menu_quotation_order"
              name="Requisition Quotation Order"
              parent="menu_purchase_requisition"
              action="purchase_requisitions.action_purchase_quotation"
              sequence="3"
    />

    <record id="quotation_order_line_tree" model="ir.ui.view">
        <field name="name">quotation.order.line.tree</field>
        <field name="model">quotation.order.line</field>
        <field name="arch" type="xml">
            <list string="Quotation Analysis" create="0">
                <field name="state" invisible="1"/>
                <field name="po_created" invisible="1"/>
                <field name="order_id" string="Quotation Number"/>
                <field name="rfq_type" string="RFQ Type" invisible="1"/>
                <field name="closure_date"/>
                <field name="date_order"/>
                <field name="category_id" context="{'from_purchasing': True, }"/>
                <field name="product_id" domain="[('categ_id', '=', category_id)]"
                       readonly="state in ('purchase','done', 'cancel')"
                       context="{'quantity':product_qty,'uom':product_uom, 'company_id': parent.company_id}"
                       force_save="1"/>
                <field name="name"/>
                <field name="product_uom"
                       readonly="state in ('purchase', 'done', 'cancel')" force_save="1"/>
                <field name="product_qty"/>
                <field name="price_unit"/>
                <field name="discount" class="oe_inline"/>
                <field name="price_subtotal"/>
            </list>
        </field>
    </record>

    <record id="view_quotation_order_line_filter" model="ir.ui.view">
        <field name="name">quotation.order.line.select</field>
        <field name="model">quotation.order.line</field>
        <field name="arch" type="xml">
            <search string="Search Quotation Order">
                <filter string="Quotations" name="to_purchase" domain="[('state','=', 'quotation')]"/>
                <separator/>
                <field name="order_id"/>
            </search>
        </field>
    </record>

    <record id="action_purchase_quotation_draft" model="ir.actions.act_window">
        <field name="name">Requisition Quotation Order Lines</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">quotation.order.line</field>
        <field name="context">{'group_by':['origin', 'partner_id'] ,'search_default_to_purchase': 1, 'show_line_price':
            True, 'from_purchasing': True}
        </field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a quotation for quotation.
            </p>
            <p>
                The quotation contains the history of the discussion/negotiation
                you had with your vendor. Once confirmed, a quotation for
                quotation is converted into a final quotation order.
            </p>
        </field>
    </record>

    <menuitem id="menu_compare_quotation_order"
              name="Quotation Analysis"
              parent="menu_purchase_requisition"
              action="purchase_requisitions.action_purchase_quotation_draft"
              sequence="4"
    />

</odoo>