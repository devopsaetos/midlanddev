<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_move_form_po_bridge_ext" model="ir.ui.view">
        <field name="name">account.move.form.po.bridge</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Pass task context to invoice lines for cost sheet default -->
            <field name="invoice_line_ids" position="attributes">
                <attribute name="context">{'default_task': task_id}</attribute>
            </field>
            <!-- Add cost sheet column in invoice lines (visible) -->
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='product_id']" position="after">
                <field name="task_cost_sheet_id"
                       optional="show"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

</odoo>
