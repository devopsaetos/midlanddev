<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record model="ir.ui.view" id="stock_transaction_form">
        <field name="name">stock.transaction.form</field>
        <field name="model">stock.transaction</field>
        <field name="arch" type="xml">
            <form string="Item Issuance and Return">
                <header>
                    <button name="action_create_moves" string="Confirm" type="object" invisible="state != 'draft'"/>
                    <button name="action_print_st_return_report" type="object" string="Print Report"
                            invisible="type not in ('return', 'transfer_in', 'transfer_out')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,cancelled,rejected"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_get_stock_move_lines"
                                type="object" icon="fa-exchange">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Stock Moves</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" type="object" name="button_view_suborders"
                                invisible="total_back_order == 0"
                                icon="fa-file-text-o">
                            <field string="Back Orders" name="total_back_order" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_transtion_id" invisible="1"/>
                            <field name="check_req" invisible="1"/>
                            <field name="type" readonly="state == 'confirm'"/>
                            <field name="warehouse_id"/>
                            <field name="target_warehouse_id"/>
                            <field name="location_id" readonly="state == 'confirm'"  invisible="1"/>
                            <field name="scrap_location_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="date" readonly="state == 'confirm'"/>
                            <field name="legacy_ref_no" readonly="state == 'confirm'"/>
                            <field name="company_id" readonly="state == 'confirm'"/>
<!--                            <field name="branch_id" invisible="1"/>-->
                            <field name="cost_center_id" invisible="1"/>
                            <field name="location_updated" invisible="1"/>
                            <field name="returned_by" invisible="type == 'return'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="line_ids" readonly="state == 'confirm'">
                                <list editable="bottom">
                                    <field name="transaction_id" optional="hide"/>
                                    <field name="charge_type" required="True"/>
                                    <field name="product_id"/>
                                    <field name="check_req" column_invisible="True"/>
                                    <field name="product_uom_id"/>
                                    <field name="total_req_qty" invisible="check_req != True"
                                           readonly="check_req == True"/>
                                    <field name="product_location_ids" widget="many2many_tags" optional="hide"/>
                                    <field name="source_location_id" domain="[('id', 'in',product_location_ids)]"/>
                                    <field name="onhand_quantity"/>
<!--                                    <field name="free_qty"/>-->
                                    <field name="reserved_qty" optional="hide"/>
                                    <field name="scrap_qty"/>
                                    <field name="analytic_account_id"/>
                                    <!--                                    <field name="analytic_tag_ids" widget="many2many_tags"/>-->
                                    <field name="cost_center_id"/>
                                    <field name="memo_text"/>
                                    <field name="state" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="stock_transactions_view_tree" model="ir.ui.view">
        <field name="name">stock.transaction.list</field>
        <field name="model">stock.transaction</field>
        <field name="arch" type="xml">
            <list string="stock_transactions_tree">
                <field name="name"/>
                <field name="type"/>
                <field name="location_id" invisible="1" />
                <field name="date"/>
                <field name="legacy_ref_no"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="inventory_transaction_action">
        <field name="name">Stock Transactions</field>
        <field name="res_model">stock.transaction</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem id="stock_transaction_menu" name="Stock Transaction" parent="stock.menu_stock_warehouse_mgmt"
              action="inventory_transaction_action"/>
</odoo>