<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="charge_type_view_form" model="ir.ui.view">
        <field name="name">charge_type_view_form</field>
        <field name="model">charge.type</field>
        <field name="arch" type="xml">
            <form string="Charge type form">
                <group>
                    <field name="name"/>
                    <field name="account_control_id"/>
                </group>
            </form>
        </field>
    </record>


    <record id="charge_type_view_tree" model="ir.ui.view">
        <field name="name">charge_type_view_tree</field>
        <field name="model">charge.type</field>
        <field name="arch" type="xml">
            <list string="charge_type_tree">
                <field name="name"/>
                <field name="account_control_id"/>
            </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="charge_type_action">
        <field name="name">ChargeType</field>
        <field name="res_model">charge.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Add your Charge type</p>
        </field>
    </record>

    <menuitem id="Charge_type" name="Charge Type" parent="stock.menu_stock_inventory_control"
              action="charge_type_action"/>
</odoo>
