<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="maintenance_exemption_withdrawal_view_form" model="ir.ui.view">
            <field name="name">maintenance_realestate_specific maintenance_exemption_withdrawal_view_form</field>
            <field name="model">maintenance.exemption.withdrawal</field>
            <field name="arch" type="xml">
                <form>
                     <header>
                        <field name="state" widget="statusbar"/>
                        <button class="btn btn-primary" name="button_submit" type="object" string="Submit To Approve" invisible="state != 'draft'" groups="maintenance_recovery_batch.officer_group_id"/>
                        <button class="btn btn-primary" name="button_approve" type="object" string="Approve" invisible="state != 'submit_approve'" groups="maintenance_recovery_batch.manager_group_id"/>
                        <button class="btn btn-primary" name="button_cancel" type="object" string="Cancel" invisible="state != 'submit_approve'" groups="maintenance_recovery_batch.manager_group_id"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="withdrawal_batch_no" required="1" readonly="1"/>
                            </group>
                            <group>
                                <field name="product_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page name="maintenance_exemption_withdrawal_lines" string="Lines" autofocus="autofocus">
                                <field name="withdrawal_line_ids">
                                    <list editable="bottom" delete="1">
                                        <field name="exemption_withdrawal_no" readonly="1"/>
                                        <field name="file_id" optional="hide" column_invisible="True" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="inventory_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="maintenance_exemption_id" readonly="0" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="unit_category_type_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="society_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="phase_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="sector_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="street_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="category_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="size_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="from_date"/>
                                        <field name="to_date"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="maintenance_exemption_withdrawal_view_tree" model="ir.ui.view">
            <field name="name">maintenance_realestate_specific maintenance_exemption_withdrawal_view_tree</field>
            <field name="model">maintenance.exemption.withdrawal</field>
            <field name="arch" type="xml">
                <list>
                    <field name="withdrawal_batch_no"/>
                    <field name="product_id" options="{'no_create': True, 'no_open': True}"/>
                </list>
            </field>
        </record>

        <record model="ir.actions.act_window" id="maintenance_realestate_specific.action_maintenance_exemption_withdrawal">
            <field name="name">Maintenance Exemption Withdrawal</field>
            <field name="res_model">maintenance.exemption.withdrawal</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
                id="maintenance_realestate_specific.maintenance_exemption_withdrawal_menu"
                name="Maintenance Exemption Withdrawal"
                parent="maintenance_realestate_specific.maintenance_exemption_parent_menu"
                action="maintenance_realestate_specific.action_maintenance_exemption_withdrawal"
                sequence='2'
        />
    </data>
</odoo>