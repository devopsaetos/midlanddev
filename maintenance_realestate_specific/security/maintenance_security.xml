<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_maintenance_user" model="res.groups">
        <field name="name">Maintenance Request User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_maintenance_manager" model="res.groups">
        <field name="name">Maintenance Request Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_maintenance_user'))]"/>
        <!-- res.groups field renamed 'users' -> 'user_ids' in Odoo 19 -->
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>


    <data noupdate="1">
        <!-- Manager gets all team access rights -->
        <record id="maintenance_user_rule" model="ir.rule">
            <field name="name">Maintenance Request User</field>
            <!-- Odoo 19 migration note: qualified with the 'maintenance.' module prefix -
                 'maintenance.request' is defined by core Odoo's 'maintenance' app (now an
                 explicit manifest dependency, previously only pulled in transitively via
                 the unavailable 'website_axis_helpdesk'), not by this module, so the
                 xmlid must reference that owning module explicitly. -->
            <field name="model_id" ref="maintenance.model_maintenance_request"/>
            <field name="domain_force">['|', ('message_partner_ids', 'in', [user.partner_id.id]), ('user_id.id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_user'))]"/>
        </record>

        <record id="maintenance_manager_rule" model="ir.rule">
            <field name="name">Maintenance Request Manager</field>
            <!-- Odoo 19 migration note: qualified with the 'maintenance.' module prefix -
                 'maintenance.request' is defined by core Odoo's 'maintenance' app (now an
                 explicit manifest dependency, previously only pulled in transitively via
                 the unavailable 'website_axis_helpdesk'), not by this module, so the
                 xmlid must reference that owning module explicitly. -->
            <field name="model_id" ref="maintenance.model_maintenance_request"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_manager'))]"/>
        </record>
    </data>
</odoo>
