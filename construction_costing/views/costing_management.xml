<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Form View ──────────────────────────────────────────────── -->
    <record id="task_cost_sheet_form_view" model="ir.ui.view">
        <field name="name">task.cost.sheet.form</field>
        <field name="model">task.cost.sheet</field>
        <field name="arch" type="xml">
            <form string="Task Cost Sheet">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary"
                            invisible="stage in ('confirm','approve','done')"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-primary"
                            invisible="stage in ('draft','approve','done')"/>
                    <button name="action_done" string="Done" type="object"
                            class="btn-primary"
                            invisible="stage in ('draft','confirm','done')"/>
                    <field name="stage" widget="statusbar"
                           statusbar_visible="draft,confirm,approve,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="sequence" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name" required="1" readonly="stage == 'done'"/>
                            <field name="project_id"
                                   readonly="context.get('from_task') or stage == 'done'"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="task_id"
                                   readonly="context.get('from_task') or stage == 'done'"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="analytic_account_id" readonly="1"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="close_date" readonly="1"/>
                            <field name="create_by_id" readonly="1"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="company_id" readonly="1"
                                   groups="base.group_multi_company"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Material">
                            <field name="material_task_cost_line_ids"
                                   readonly="stage == 'done'"
                                   context="{'default_job_type': 'material'}">
                                <list string="Material" editable="bottom">
                                    <field name="date"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="reference"/>
                                    <field name="quantity" sum="Qty"/>
                                    <field name="uom_id"/>
                                    <field name="unit_price"/>
                                    <field name="actual_purchase_qty" optional="hide"/>
                                    <field name="subtotal" widget="monetary" sum="Sub Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="job_type" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Labour">
                            <field name="bills_line_ids"
                                   readonly="stage == 'done'"
                                   context="{'default_job_type': 'labour'}">
                                <list string="Labour" editable="bottom">
                                    <field name="date"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="reference"/>
                                    <field name="hours" sum="Hours"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="actual_timesheet_hours" sum="Actual Hours" optional="hide"/>
                                    <field name="subtotal" widget="monetary" sum="Sub Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Overhead">
                            <field name="overhead_task_cost_line_ids"
                                   readonly="stage == 'done'">
                                <list string="Overhead" editable="bottom">
                                    <field name="date"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="reference"/>
                                    <field name="over_head_value" widget="monetary" sum="Overhead Value"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <group>
                        <group class="oe_subtotal_footer oe_right" colspan="2">
                            <field name="total_material_cost" widget="monetary"/>
                            <field name="total_labour_cost" widget="monetary"/>
                            <field name="total_overhead_cost" widget="monetary"/>
                            <div class="oe_subtotal_footer_separator oe_inline">
                                <label for="total_cost"/>
                            </div>
                            <field name="total_cost" widget="monetary" nolabel="1"
                                   class="oe_subtotal_footer_separator"/>
                        </group>
                    </group>
                    <separator string="Job Cost Description"/>
                    <field name="task_cost_description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── List View ─────────────────────────────────────────────── -->
    <record id="task_cost_sheet_list_view" model="ir.ui.view">
        <field name="name">task.cost.sheet.list</field>
        <field name="model">task.cost.sheet</field>
        <field name="arch" type="xml">
            <list string="Cost Sheets" decoration-muted="stage == 'done'">
                <field name="sequence"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="stage" widget="badge"
                       decoration-info="stage == 'draft'"
                       decoration-warning="stage == 'confirm'"
                       decoration-primary="stage == 'approve'"
                       decoration-success="stage == 'done'"/>
                <field name="create_date"/>
                <field name="close_date" optional="hide"/>
                <field name="total_material_cost" widget="monetary" optional="hide"/>
                <field name="total_labour_cost" widget="monetary" optional="hide"/>
                <field name="total_overhead_cost" widget="monetary" optional="hide"/>
                <field name="total_cost" widget="monetary" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ─── Search View ───────────────────────────────────────────── -->
    <record id="task_cost_sheet_search_view" model="ir.ui.view">
        <field name="name">task.cost.sheet.search</field>
        <field name="model">task.cost.sheet</field>
        <field name="arch" type="xml">
            <search string="Search Cost Sheets">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <filter string="Draft"     name="draft"     domain="[('stage','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('stage','=','confirm')]"/>
                <filter string="Approved"  name="approved"  domain="[('stage','=','approve')]"/>
                <filter string="Done"      name="done"      domain="[('stage','=','done')]"/>
                <separator/>
                <group>
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Task"    name="group_task"    context="{'group_by': 'task_id'}"/>
                    <filter string="Stage"   name="group_stage"   context="{'group_by': 'stage'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────────── -->
    <record id="action_job_cost_sheet" model="ir.actions.act_window">
        <field name="name">Cost Sheets</field>
        <field name="res_model">task.cost.sheet</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="task_cost_sheet_search_view"/>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <!-- ─── Sequence ──────────────────────────────────────────────── -->
    <record id="seq_task_cost_sheet" model="ir.sequence">
        <field name="name">Task Cost Sheet</field>
        <field name="code">task.cost.sheet</field>
        <field name="prefix">COST/</field>
        <field name="padding">4</field>
    </record>

    <!-- ─── Menus ─────────────────────────────────────────────────── -->
    <menuitem id="menu_construction_root"
              name="Construction"
              web_icon="construction_costing,static/description/icon_construction.png"
              sequence="50"/>

    <menuitem id="menu_construction_cost_sheets"
              name="Cost Sheets"
              parent="menu_construction_root"
              action="action_job_cost_sheet"
              sequence="1"/>

</odoo>
