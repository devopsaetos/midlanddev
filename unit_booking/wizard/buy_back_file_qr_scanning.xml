<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="unit_booking.buy_back_file_qr_scanning_form1" model="ir.ui.view">
            <field name="name">unit_booking buy_back_file_qr_scanning_form</field>
            <field name="model">file.qr.scanning</field>
            <field name="arch" type="xml">
                <form create="false">
                    <sheet>
                        <group>
                            <group>

                                <field name="units_booking_id" widget="m2o_int" string="File"
                                       options="{'no_create': True}"/>

                            </group>
                            <group>
                                <field name="issue_to_sub_dealer"/>
                                <field name="buy_back_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Unit Details">
                                <field name="file_qr_line_ids">
                                    <list create="false">
                                        <field name="units_booking_id" options="{'no_open': True}"
                                               readonly="1" force_save="1" string="File"/>
                                        <field name="society_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                                        <field name="phase_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                                        <field name="sector_id" string="Block" readonly="1" force_save="1" options="{'no_open': True}"/>
                                        <field name="category_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                                        <field name="unit_category_type_id" readonly="1" force_save="1"
                                               options="{'no_open': True}"
                                               string="Product"/>
                                        <field name="batch_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                                        <field name="unit_booking_allotment_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                                        <field name="state" readonly="1" force_save="1" options="{'no_open': True}"/>
                                        <field name="file_qr_id" invisible="1"/>
                                    </list>
                                    <form name="open_file_qr" string="Open File">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="units_booking_id"
                                                           options="{'no_open': True}"
                                                           readonly="1" force_save="1"
                                                           string="File"/>
                                                    <field name="society_id"
                                                           options="{'no_open': True}"
                                                           readonly="1" force_save="1"/>
                                                    <field name="phase_id"
                                                           options="{'no_open': True}"
                                                           readonly="1" force_save="1"/>
                                                    <field name="sector_id"
                                                           options="{'no_open': True}"
                                                           string="Block" readonly="1" force_save="1"/>
                                                </group>
                                                <group>
                                                    <field name="category_id"
                                                           options="{'no_open': True}"
                                                           readonly="1" force_save="1"/>
                                                    <field name="unit_category_type_id"
                                                           options="{'no_open': True}"
                                                           readonly="1" force_save="1"
                                                           string="Product"/>
                                                    <field name="batch_id" options="{'no_open': True}"
                                                           readonly="1" force_save="1"/>
                                                    <field name="unit_booking_allotment_id" options="{'no_open': True}"
                                                           readonly="1" force_save="1"/>
                                                    <field name="state" options="{'no_open': True}"
                                                           readonly="1" force_save="1"/>
                                                    <field name="file_qr_id" invisible="1"/>
                                                </group>
                                            </group>
                                        </sheet>
                                        <footer>
                                            <button string="Discard" class="btn-default" special="cancel"/>
                                        </footer>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="proceed_to_qr" string="Done" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>