<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="unit_booking.file_assignment_undo_view_form1" model="ir.ui.view">
            <field name="name">unit_booking file_assignment_undo_view_form</field>
            <field name="model">file.assignment.selection</field>
            <field name="arch" type="xml">
                <form create="false">
                    <field name="assignment_id" invisible="1"/>
                    <field name="file_assignment_line_ids">
                        <list editable="bottom">
                            <field name="is_check"/>
                            <field name="open_file_assignment_line_id" invisible="1"/>
                            <field name="sector_id" string="Block" force_save="1" readonly="1"/>
                            <field name="category_id" force_save="1" readonly="1"/>
                            <field name="unit_category_type_id" force_save="1" readonly="1" string="Product"/>
                            <field name="batch_id" force_save="1" readonly="1"/>
                            <field name="unit_booking_starting_id" force_save="1" readonly="1"/>
                            <field name="unit_booking_ending_id" force_save="1" readonly="1"/>
                            <field name="predefine_plan_id" force_save="1" readonly="1"/>
                            <field name="unit_price" force_save="1" readonly="1"/>
                            <field name="no_of_units" force_save="1" readonly="1"/>
                            <field name="file_assignment_id" invisible="1"/>
                        </list>
                    </field>
                    <footer>
                        <button string="Undo Assignment" name="undo_assignment" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>