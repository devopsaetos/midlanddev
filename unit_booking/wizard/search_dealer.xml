<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="unit_booking.dealer_search_form_view" model="ir.ui.view">
            <field name="name">unit_booking dealer_search_form_view</field>
            <field name="model">search.dealer</field>
            <field name="arch" type="xml">
                <form create="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="dealer_id"
                                       options="{'no_create': True, 'no_open': True}"
                                       domain="[('is_unit_booking_agent','=',True)]"/>
                                 <field name="date_from"/>
                            </group>

                            <group>
                                <field name="process" required="1"/>
                                <field name="date_to"/>
                            </group>
                        </group>
                        <group>
                            <group name="left_panel">
                            </group>

                            <group class="oe_subtotal_footer oe_right">
                                <button string="Search" name="search_related_records" type="object" class="btn-primary"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Dealer Detail">
                                <field name="search_line_ids">
                                    <list editable="bottom">
                                        <field name="is_checked" string="Select"/>

                                        <field name="dealer_id" string="Dealer" force_save="1" readonly="1"/>

                                        <field name="dealer_category_id"  string="Category" force_save="1" readonly="1"/>

                                        <field name="unit_booking_agent_type" string="Type" force_save="1" readonly="1"/>

                                        <field name="valid_till" string="Validity" force_save="1" readonly="1"/>

                                        <field name="registration_fee" force_save="1" readonly="1"/>

                                        <field name="security_fee" force_save="1" readonly="1"/>

                                        <field name="state" force_save="1" readonly="1"/>

                                        <field name="search_id" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Create" name="create_req" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="unit_booking.dealer_search_action">
            <field name="name">Search</field>
            <field name="res_model">search.dealer</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <menuitem
                id="unit_booking.dealer_search_main_menu"
                name="Search"
                parent="unit_booking.agent_menu_root"
                action="unit_booking.dealer_search_action"
                sequence='2'
        />
    </data>
</odoo>