<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="unit_booking.unit_booking_reset_print_state_view_form" model="ir.ui.view">
            <field name="name">unit_booking unit_booking_reset_print_state_view_form</field>
            <field name="model">unit.booking.reset.print.state</field>
            <field name="arch" type="xml">
                <form create="false">
                    <sheet>
                        <group string="Unit Details">
                            <group>
                                <field name="batch_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="prefix_id"
                                       domain="[('batch_id','=',batch_id)]"
                                       options="{'no_create': True, 'no_open': True}" required="1"/>
                            </group>
                            <group>

                                <field name="unit_booking_starting_id" string="Starting No."
                                       required="0"
                                       options="{'no_create': True, 'no_open': True}"/>

                                <field name="unit_booking_ending_id" string="Ending No."
                                       required="0"
                                       readonly="not unit_booking_starting_id"
                                       options="{'no_create': True, 'no_open': True}"/>

                            </group>
                        </group>
                        <group>
                            <group name="left_panel">
                            </group>

                            <group class="oe_subtotal_footer oe_right">
                                <button string="Search" name="search_related_records" type="object" class="btn-primary"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="is_qr_printed" string="Open File Printed"/>
                                <field name="is_receipt_printed" string="Receipt Printed"/>
                                <field name="is_ledger_printed" string="Ledger Printed"/>
                            </group>
                            <group>

                            </group>
                        </group>
                        <notebook>
                            <page string="Unit Detail">
                                <field name="search_line_ids" readonly="1">
                                    <list editable="bottom">

                                        <field name="units_booking_id" string="File"
                                               force_save="1" readonly="1"/>

                                        <field name="society_id" force_save="1" readonly="1" invisible="1"/>

                                        <field name="phase_id" force_save="1" readonly="1" invisible="1"/>

                                        <field name="sector_id" string="Block" force_save="1" readonly="1" invisible="1"/>

                                        <field name="category_id" force_save="1" readonly="1" invisible="1"/>

                                        <field name="unit_category_type_id" force_save="1" readonly="1" string="Product" invisible="1"/>

                                        <field name="is_qr_printed" force_save="1" readonly="1" string="Open File Printed"/>

                                        <field name="is_receipt_printed" string="Receipt Printed" force_save="1" readonly="1"/>

                                        <field name="is_ledger_printed" force_save="1" readonly="1" string="Ledger Printed"/>

                                        <field name="batch_id" force_save="1" readonly="1"/>

                                        <field name="state" force_save="1" readonly="1" string="State"/>

                                        <field name="search_id" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Create" name="create_issuance_req" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="unit_booking.action_unit_booking_reset_printing_state">
            <field name="name">Search</field>
            <field name="res_model">unit.booking.reset.print.state</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <menuitem
                id="unit_booking.unit_booking_reset_printing_state_menu"
                name="Reset Printing State"
                parent="unit_booking.process_management_root"
                action="unit_booking.action_unit_booking_reset_printing_state"
                sequence='1'
                groups="unit_booking.group_can_do_reset_printing_state"
        />
    </data>
</odoo>