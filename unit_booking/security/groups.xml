        <record model="ir.module.category" id="unit_booking.module_category_unit_booking">
            <field name="name">Unit Booking</field>
            <field name="sequence">0</field>
            <field name="visible" eval="0"/>
        </record>

        <record id="unit_booking.group_can_undo_assignment" model="res.groups">
