<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="unit_booking.seq_internal_serial" model="ir.sequence">
            <field name="name">Serial Number</field>
            <field name="code">unit.booking</field>
            <field name="prefix">OPF</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>

