<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="unit_booking.issuance_request_verification" name="File Verification">
        <t t-call="web.html_container">
            <style>
                body
                {
                background: #000428; /* fallback for old browsers */
                background: -webkit-linear-gradient(to right, #004e92, #000428); /* Chrome 10-25, Safari 5.1-6 */
                background: linear-gradient(to right, #004e92, #000428); /* W3C, IE 10+/ Edge, Firefox 16+, Chrome 26+, Opera 12+, Safari 7+ */
                }
                .company-logo
                {
                width: auto;
                height: 225px !important;
                }
                i
                {
                margin-left: 20px !important;
                margin-right: 20px !important;
                }
                @media only screen and (max-width: 768px)
                {
                .company-logo {width: 300px !important; height: 100px !important;}
                .watermark {
                position: fixed;
                font-size: 95px !important;
                font-weight: bolder;
                opacity: 0.6;
                z-index: 99;
                color: red;
                width: auto;
                -ms-transform: rotate(25deg) !important;
                -webkit-transform: rotate(25deg) !important;
                transform: rotate(-50deg) !important;
                left: -65px !important;
                top: 250px !important;
                }
                }
                .card, .card-body
                {
                background: url("/unit_booking/static/description/silver-bg.jpg");
                background-size: cover;
                }
                .text-muted span
                {
                font-weight: bolder;
                color: rgb(0 0 0 / 50%) !important;
                }
                .rounded-circle
                {
                border-radius: 50% !important;
                border: 2px solid darkgrey;
                }
                .watermark {
                position: fixed;
                font-size: 180px;
                font-weight: bolder;
                opacity: 0.5;
                z-index: 99;
                color: red;
                width: auto;
                -ms-transform: rotate(20deg);
                -webkit-transform: rotate(20deg);
                transform: rotate(-40deg);
                top: 280px !important;
                }
            </style>
            <section>
                <div class="container py-5">
                    <t t-if="issuance_request.state == 'cancel'">
                        <div class="watermark">
                            <p>CANCELLED</p>
                        </div>
                    </t>
                    <div class="row">
                        <div class="col-lg-4">
                            <center>
                                <img class="company-logo"
                                     t-att-src="image_data_uri(issuance_request.unit_swapping_request_lines[0].investor_file_id.society_id.company_id.logo)" alt=""/>
                            </center>
                        </div>
                    </div>
                    <hr/>
                    <div class="row">
                        <div class="col-lg-4">
                            <div class="card mb-4 m-3">
                                <div class="card-body text-center box--gradient silver">
                                    <t t-if="issuance_request.member_image">
                                        <img t-att-src="image_data_uri(issuance_request.member_image)" alt=""
                                             class="rounded-circle img-fluid" style="width: 155px; height:155px;"/>
                                    </t>
                                    <!--                                    <h5 class="my-3"><span t-esc="issuance_request.transferee_name"/></h5>-->
                                    <div class="d-flex justify-content-left mb-2">
                                        <h5 class="my-3">
                                            <!--                                            <hr/>-->
                                            <i class="fa fa-user-circle" style="margin-left: 0px;"/>
                                            <span t-esc="issuance_request.transferee_name"/>
                                            <hr/>
                                            <i class="fa fa-address-card-o"/>
                                            <span t-esc="issuance_request.transferee_cnic_number"/>
                                            <hr/>
                                            <i class="fa fa-phone"/>
                                            <span t-esc="issuance_request.transferee_mobile"/>
                                            <hr/>
                                        </h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-8">
                            <div class="card mb-4 m-3">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <p class="mb-0">Request No.</p>
                                        </div>
                                        <div class="col-sm-9">
                                            <p class="text-muted mb-0">
                                                <span t-esc="issuance_request.name"/>
                                            </p>
                                        </div>
                                    </div>
                                    <hr/>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <p class="mb-0">Request Date</p>
                                        </div>
                                        <div class="col-sm-9">
                                            <p class="text-muted mb-0">
                                                <span t-esc="issuance_request.create_date.strftime('%d %b %Y')"/>
                                            </p>
                                        </div>
                                    </div>
                                    <hr/>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <p class="mb-0">Agent Name</p>
                                        </div>
                                        <div class="col-sm-9">
                                            <p class="text-muted mb-0">
                                                <span t-esc="issuance_request.investor_id.name"/>
                                            </p>
                                        </div>
                                    </div>
                                    <hr/>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <p class="mb-0">Society</p>
                                        </div>
                                        <div class="col-sm-9">
                                            <p class="text-muted mb-0">
                                                <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.society_id.name"/>
                                            </p>
                                        </div>
                                    </div>
                                    <hr/>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <p class="mb-0">Phase</p>
                                        </div>
                                        <div class="col-sm-9">
                                            <p class="text-muted mb-0">
                                                <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.phase_id.name"/>
                                            </p>
                                        </div>
                                    </div>
                                    <hr/>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <p class="mb-0">Category</p>
                                        </div>
                                        <div class="col-sm-9">
                                            <p class="text-muted mb-0">
                                                <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.category_id.name"/>
                                            </p>
                                        </div>
                                    </div>
                                    <hr/>
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <p class="mb-0">Product</p>
                                        </div>
                                        <div class="col-sm-9">
                                            <p class="text-muted mb-0">
                                                <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.unit_category_type_id.name"/>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-12">
                            <div class="card mb-4 m-3">
                                <div class="card-body text-center box--gradient silver">
                                    <h5>
                                        <i class="fa fa-map-marker" style="font-size:30px;"/>
                                        <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.society_id.company_id.street"/>
                                        <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.society_id.company_id.street2"/>
                                        <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.society_id.company_id.city"/>
                                        <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.society_id.company_id.state_id.name"/>
                                        <span t-esc="issuance_request.unit_swapping_request_lines[0].investor_file_id.society_id.company_id.country_id.name"/>
                                    </h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
