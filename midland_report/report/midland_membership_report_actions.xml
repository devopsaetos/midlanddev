<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_midland_membership" model="report.paperformat">
        <field name="name">Midland Membership Form</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_midland_membership" model="ir.actions.report">
        <field name="name">Membership Form</field>
        <field name="model">file</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">midland_report.report_midland_membership_document</field>
        <field name="report_file">midland_report.report_midland_membership_document</field>
        <field name="print_report_name">'Membership Form - %s' % (object.tracking_id or object.name)</field>
        <field name="binding_model_id" ref="real_estate.model_file"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_midland_membership"/>
    </record>

</odoo>
