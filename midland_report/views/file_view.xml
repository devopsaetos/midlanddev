<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="file_form_inherit_print_report" model="ir.ui.view">
        <field name="name">file.form.inherit.midland.print.report</field>
        <field name="model">file</field>
        <field name="inherit_id" ref="real_estate.file_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="%(midland_report.action_report_midland_membership)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-print">
                    <span class="o_stat_text">Print PDF</span>
                </button>
            </div>
        </field>
    </record>
</odoo>