<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="plot_inventory_status_form" model="ir.ui.view">
        <field name="name">plot_inventory_status_form</field>
        <field name="model">plot.inventory.status</field>
        <field name="arch" type="xml">
            <form string="Confirm Draft Invoices">
                <p class="oe_grey">
                    The Status on which you want to change the selected plots.
                </p>
                <group>
                    <group>
                        <field name="state"/>
                    </group>
                </group>
                <footer>
                    <button string="Confirm Status" name="status_confirm" type="object" default_focus="1" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_plot_inventory_status" model="ir.actions.act_window">
        <field name="name">Change State</field>
        <field name="res_model">plot.inventory.status</field>
        <field name="binding_model_id" ref="model_plot_inventory"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>