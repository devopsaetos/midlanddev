<odoo>
    <template id="pf_customized_header">
        <div class="header">
            <div class="o_clean_header">
                <div class="row">
                    <div class="col-12" name="company_address">
                        <ul class="list-unstyled">
                            <li t-if="res_company.street">
                                <span t-field="res_company.street"/>
                            </li>
                            <li t-if="res_company.street2">
                                <span t-field="res_company.street2"/>
                            </li>
                            <li t-if="res_company.city and  res_company.country_id">
                                <span t-field="res_company.city"/>,
                                <span t-field="res_company.country_id.name"/>
                            </li>
                            <li t-elif="res_company.country_id">
                                <span t-field="res_company.country_id.name"/>
                            </li>
                            <li t-else="">
                                <span t-field="res_company.city"/>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="pf_customized_footer">
        <div class="footer">
            <div class="row" style="font-size:11px;color:black;border-top:1px solid #000;padding-top:4px;">
                <div class="col-6">
                    <span>Printed By:
                        <span t-esc="request.env.user.name"/>
                    </span>
                </div>
                <div class="col-6 text-end">
                    <span>Print Date:
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y')"/>
                    </span>
                </div>
            </div>
        </div>
    </template>

    <template id="processing_form">
        <t t-call="web.html_container">
            <t t-call="real_estate.pf_customized_header"/>
            <t t-call="real_estate.pf_customized_footer"/>
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            p, li, div, span {
                            font-family: "Helvetica", Arial, sans-serif;
                            color: black;
                            }
                            h6.pf_section_title {
                            color:black;
                            font-size:16px;
                            font-weight:bold;
                            margin-top:15px;
                            margin-bottom:10px;
                            }
                        </style>

                        <div class="row" style="text-align:center; margin-top:0;">
                            <div class="col-12">
                                <h4 style="color:black; margin-top:0;">
                                    <b>PROCESSING FORM</b>
                                </h4>
                            </div>
                        </div>

                        <div class="row" style="margin-top:30px;">
                            <div class="col-6">
                                Date:
                                <span t-esc="o.transfer_date.strftime('%d %b %Y') if o.transfer_date else ''"/>
                            </div>
                            <div class="col-6 text-end">
                                Process #:
                                <span t-esc="o.t_request_id.name"/>
                            </div>
                        </div>

                        <div class="row" style="margin-top:15px;">
                            <div class="col-12">
                                <p align="justify">
                                    I/We
                                    <b>
                                        <span t-esc="o.member_name"/>
                                    </b>
                                    as per details given below do hereby undertake that I/We have sold File No.
                                    <b>
                                        <span t-esc="o.file_id.name"/>
                                    </b>
                                    having Tracking ID
                                    <b>
                                        <span t-esc="o.tracking_id"/>
                                    </b>
                                    to the Buyer (Second Party) as per details given below.
                                </p>
                            </div>
                        </div>

                        <div class="row" style="margin-top:30px;">
                            <div class="col-6" style="text-align:center;">
                                <h5>
                                    <b>Seller (First Party)</b>
                                </h5>
                            </div>
                            <div class="col-6" style="text-align:center; border-left:1px solid #000;">
                                <h5>
                                    <b>Buyer (Second Party)</b>
                                </h5>
                            </div>
                        </div>

                        <div style="display:table; width:100%; table-layout:fixed;">
                            <div style="display:table-cell; width:50%; vertical-align:top; padding-right:15px;">
                                <h6 class="pf_section_title">Personal Information</h6>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Name:</div>
                                    <div class="col-8">
                                        <span t-esc="o.member_name"/>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Father/Spouse:</div>
                                    <div class="col-8">
                                        <span t-esc="o.membership_id.relation_name"/>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">CNIC:</div>
                                    <div class="col-8">
                                        <span t-esc="o.membership_id.cnic"/>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Mobile:</div>
                                    <div class="col-8">
                                        <span t-esc="o.membership_id.mobile"/>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Address:</div>
                                    <div class="col-8">
                                        <span t-esc="o.membership_id.street"/>
                                        <br/>
                                        <span t-esc="o.membership_id.city_id.name"/>,
                                        <span t-esc="o.membership_id.country_id.name"/>
                                    </div>
                                </div>

                                <h6 class="pf_section_title">Unit Detail</h6>
                                <div class="row">
                                    <div class="col-6">
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-5">Plot No:</div>
                                            <div class="col-7">
                                                <b>
                                                    <span t-esc="o.unit_number"/>
                                                </b>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-5">Phase:</div>
                                            <div class="col-7">
                                                <span t-esc="o.phase_id.name"/>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-5">Sector:</div>
                                            <div class="col-7">
                                                <span t-esc="o.sector_id.name"/>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-5">Street:</div>
                                            <div class="col-7">
                                                <span t-esc="o.street_id.name"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-7">Category:</div>
                                            <div class="col-5">
                                                <b>
                                                    <span t-esc="o.category_id.name"/>
                                                </b>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-7">Product:</div>
                                            <div class="col-5">
                                                <b>
                                                    <span t-esc="o.unit_category_type_id.name"/>
                                                </b>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-7">Size:</div>
                                            <div class="col-5">
                                                <span t-esc="o.size_id.name"/>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-7">Type:</div>
                                            <div class="col-5">
                                                <span t-esc="o.unit_class_id.name"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <h6 class="pf_section_title">Seller Undertaking</h6>
                                <p align="justify">
                                    First Party (Seller) do hereby undertake following;
                                </p>
                                <ol style="list-style-position: outside;">
                                    <li>
                                        That from today onward there is no connection or belonging of the
                                        said plot/ membership / house to me and my heirs.
                                    </li>
                                    <li>
                                        That me and my heirs will never claim ownership of the above said
                                        plot/ membership / house in future.
                                    </li>
                                    <li>
                                        That I have never sold / handed over this plot / membership / house
                                        to anyone before this.
                                    </li>
                                    <li>
                                        That I have never mortgaged the above-mentioned plot / membership /
                                        house nor I given gift deed to any other person.
                                    </li>
                                </ol>

                                <div class="row" style="margin-top:50px;">
                                    <div class="col-6" style="text-align:center;">
                                        <div style="border-top:1px solid #000; width:80%; margin:0 auto;"/>
                                        Signature of Seller
                                    </div>
                                    <div class="col-6" style="text-align:center;">
                                        <div style="border-top:1px solid #000; width:80%; margin:0 auto;"/>
                                        Thumb of Seller
                                    </div>
                                </div>
                            </div>

                            <div style="display:table-cell; width:50%; vertical-align:top; padding-left:15px; border-left:1px solid #000;">
                                <h6 class="pf_section_title">Personal Information</h6>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Name:</div>
                                    <div class="col-8">
                                        <span t-esc="o.transferee_name"/>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Father/Spouse:</div>
                                    <div class="col-8">
                                        <t t-if="o.transferee_partner_id">
                                            <span t-esc="o.transferee_partner_id.relation_name"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">CNIC:</div>
                                    <div class="col-8">
                                        <span t-esc="o.transferee_cnic_number"/>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Mobile:</div>
                                    <div class="col-8">
                                        <t t-if="o.transferee_partner_id">
                                            <span t-esc="o.transferee_partner_id.mobile"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="row"
                                     style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                    <div class="col-4">Address:</div>
                                    <div class="col-8">
                                        <t t-if="o.transferee_partner_id">
                                            <span t-esc="o.transferee_partner_id.street"/>
                                            <br/>
                                            <span t-esc="o.transferee_partner_id.city_id.name"/>,
                                            <span t-esc="o.transferee_partner_id.country_id.name"/>
                                        </t>
                                    </div>
                                </div>

                                <t t-if="o.transferee_partner_id">
                                    <h6 class="pf_section_title">Next Of Kin</h6>
                                    <t t-set="a" t-value="0"/>
                                    <t t-foreach="o.transferee_partner_id.kin_line_ids" t-as="relative">
                                        <t t-if="a &lt; 1">
                                            <div class="row"
                                                 style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                                <div class="col-4">Name:</div>
                                                <div class="col-8">
                                                    <span t-esc="relative.name"/>
                                                </div>
                                            </div>
                                            <div class="row"
                                                 style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                                <div class="col-4">Relation:</div>
                                                <div class="col-8">
                                                    <span t-esc="dict(relative._fields['relation_with_member'].selection).get(relative.relation_with_member, '')"/>
                                                </div>
                                            </div>
                                            <div class="row"
                                                 style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                                <div class="col-4">CNIC:</div>
                                                <div class="col-8">
                                                    <span t-esc="relative.cnic"/>
                                                </div>
                                            </div>
                                            <div class="row"
                                                 style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                                <div class="col-4">Mobile:</div>
                                                <div class="col-8">
                                                    <span t-esc="relative.mobile"/>
                                                </div>
                                            </div>
                                            <t t-set="a" t-value="a+1"/>
                                        </t>
                                    </t>
                                </t>

                                <h6 class="pf_section_title">Buyer Undertaking</h6>
                                <p align="justify">
                                    Second Party (Buyer) do hereby undertake following;
                                </p>
                                <ol style="list-style-position: outside;">
                                    <li>
                                        That all the credentials and data mentioned above are true to the
                                        best of my knowledge.
                                    </li>
                                    <li>
                                        That I will abide by all rules and regulations of allotment.
                                    </li>
                                    <li>
                                        That I will abide by all the by laws, terms and conditions as well
                                        as rules and regulations of
                                        <span t-esc="o.env.company.name"/>.
                                    </li>
                                    <li>
                                        That I will be bound by all such conditions, obligations and
                                        responsibilities as printed overleaf in this respect.
                                    </li>
                                </ol>

                                <div class="row" style="margin-top:50px;">
                                    <div class="col-6" style="text-align:center;">
                                        <div style="border-top:1px solid #000; width:80%; margin:0 auto;"/>
                                        Signature of Buyer
                                    </div>
                                    <div class="col-6" style="text-align:center;">
                                        <div style="border-top:1px solid #000; width:80%; margin:0 auto;"/>
                                        Thumb of Buyer
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div style="display:table; width:100%; table-layout:fixed; margin-top:70px;">
                            <div style="display:table-cell; width:50%; vertical-align:top; padding-right:15px;">
                                <h6 class="pf_section_title">Witness 1</h6>
                                <p style="margin-bottom:8px;">
                                    Signature/Thumb:
                                    <span style="display:inline-block; width:72%; border-bottom:1px solid #000;">
                                        &#160;
                                    </span>
                                </p>
                                <t t-set="a" t-value="0"/>
                                <t t-foreach="o.transfer_witness_ids" t-as="witness">
                                    <t t-if="a &lt; 1">
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-4">Name:</div>
                                            <div class="col-8">
                                                <span t-esc="witness.name"/>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-4">S/O:</div>
                                            <div class="col-8">
                                                <span t-esc="witness.father_name"/>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-4">CNIC:</div>
                                            <div class="col-8">
                                                <span t-esc="witness.cnic"/>
                                            </div>
                                        </div>
                                        <t t-set="a" t-value="a+1"/>
                                    </t>
                                </t>
                            </div>
                            <div style="display:table-cell; width:50%; vertical-align:top; padding-left:15px; border-left:1px solid #000;">
                                <h6 class="pf_section_title">Witness 2</h6>
                                <p style="margin-bottom:8px;">
                                    Signature/Thumb:
                                    <span style="display:inline-block; width:72%; border-bottom:1px solid #000;">
                                        &#160;
                                    </span>
                                </p>
                                <t t-set="a" t-value="0"/>
                                <t t-foreach="o.transfer_witness_ids" t-as="witness">
                                    <t t-if="a == 1">
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-4">Name:</div>
                                            <div class="col-8">
                                                <span t-esc="witness.name"/>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-4">S/O:</div>
                                            <div class="col-8">
                                                <span t-esc="witness.father_name"/>
                                            </div>
                                        </div>
                                        <div class="row"
                                             style="border-bottom:1px solid #ccc; padding-bottom:2px; margin-bottom:2px;">
                                            <div class="col-4">CNIC:</div>
                                            <div class="col-8">
                                                <span t-esc="witness.cnic"/>
                                            </div>
                                        </div>
                                    </t>
                                    <t t-set="a" t-value="a+1"/>
                                </t>
                            </div>
                        </div>

                        <p style="page-break-before: always"/>
                        <div class="row">
                            <div class="col-4">
                                Seller Name:
                                <span t-esc="o.member_name"/>
                            </div>
                            <div class="col-4">
                                Tracking ID:
                                <span t-esc="o.tracking_id"/>
                            </div>
                            <div class="col-4">
                                File No.:
                                <span t-esc="o.file_id.name"/>
                            </div>
                        </div>

                        <t t-if="o.combine_image">
                            <div class="row" style="margin-top:15px;">
                                <div class="col-12" style="text-align:center;">
                                    <img t-att-src="image_data_uri(o.combine_image)"
                                         style="max-width:100%; max-height:500px;"/>
                                </div>
                            </div>
                        </t>

                        <div style="display:table; width:100%; table-layout:fixed; margin-top:40px;">
                            <div style="display:table-cell; width:25%; vertical-align:top; padding-right:10px;">
                                <h6 class="pf_section_title">Seller (First Party)</h6>
                                <p>
                                    Name:
                                    <br/>
                                    <span t-esc="o.member_name"/>
                                    <br/>
                                    <br/>
                                    Father/Spouse:
                                    <br/>
                                    <span t-esc="o.membership_id.relation_name"/>
                                    <br/>
                                    <br/>
                                    CNIC:
                                    <br/>
                                    <span t-esc="o.membership_id.cnic"/>
                                </p>
                                <div style="border-top:1px solid #000; width:80%; margin-top:90px;"/>
                                Signature/Thumb
                            </div>
                            <div style="display:table-cell; width:25%; vertical-align:top; padding-left:10px; padding-right:10px; border-left:1px solid #000;">
                                <h6 class="pf_section_title">Buyer (Second Party)</h6>
                                <p>
                                    Name:
                                    <br/>
                                    <span t-esc="o.transferee_name"/>
                                    <br/>
                                    <br/>
                                    Father/Spouse:
                                    <br/>
                                    <t t-if="o.transferee_partner_id">
                                        <span t-esc="o.transferee_partner_id.relation_name"/>
                                    </t>
                                    <br/>
                                    <br/>
                                    CNIC:
                                    <br/>
                                    <span t-esc="o.transferee_cnic_number"/>
                                </p>
                                <div style="border-top:1px solid #000; width:80%; margin-top:90px;"/>
                                Signature/Thumb
                            </div>
                            <div style="display:table-cell; width:25%; vertical-align:top; padding-left:10px; padding-right:10px; border-left:1px solid #000;">
                                <h6 class="pf_section_title">Witness 1</h6>
                                <t t-set="a" t-value="0"/>
                                <t t-foreach="o.transfer_witness_ids" t-as="witness">
                                    <t t-if="a &lt; 1">
                                        <p>
                                            Name:
                                            <br/>
                                            <span t-esc="witness.name"/>
                                            <br/>
                                            <br/>
                                            Father/Spouse:
                                            <br/>
                                            <span t-esc="witness.father_name"/>
                                            <br/>
                                            <br/>
                                            CNIC:
                                            <br/>
                                            <span t-esc="witness.cnic"/>
                                        </p>
                                        <t t-set="a" t-value="a+1"/>
                                    </t>
                                </t>
                                <div style="border-top:1px solid #000; width:80%; margin-top:90px;"/>
                                Signature/Thumb
                            </div>
                            <div style="display:table-cell; width:25%; vertical-align:top; padding-left:10px; padding-right:10px; border-left:1px solid #000;">
                                <h6 class="pf_section_title">Witness 2</h6>
                                <t t-set="a" t-value="0"/>
                                <t t-foreach="o.transfer_witness_ids" t-as="witness">
                                    <t t-if="a == 1">
                                        <p>
                                            Name:
                                            <br/>
                                            <span t-esc="witness.name"/>
                                            <br/>
                                            <br/>
                                            Father/Spouse:
                                            <br/>
                                            <span t-esc="witness.father_name"/>
                                            <br/>
                                            <br/>
                                            CNIC:
                                            <br/>
                                            <span t-esc="witness.cnic"/>
                                        </p>
                                    </t>
                                    <t t-set="a" t-value="a+1"/>
                                </t>
                                <div style="border-top:1px solid #000; width:80%; margin-top:90px;"/>
                                Signature/Thumb
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="paperformat_processing_form" model="report.paperformat">
        <field name="name">Customized Paper Format</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="page_height">300</field>
        <field name="page_width">240</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">12</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">90</field>
    </record>

    <record id="processing_form_action" model="ir.actions.report">
        <field name="name">Processing Form</field>
        <field name="model">transfer.application</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">real_estate.processing_form</field>
        <field name="report_file">real_estate.processing_form</field>
        <field name="paperformat_id" ref="paperformat_processing_form"/>
        <field name="print_report_name">'Processing Form - %s' % (object.tracking_id or '')</field>
        <field name="binding_model_id" ref="model_transfer_application"/>
        <field name="binding_type">report</field>
    </record>
</odoo>