<odoo>
    <template id="pr_customized_header">
        <div class="header">
            <div class="o_clean_header">
                <div class="row text-dark" style="font-family:'Roboto',sans-serif;">
                    <div class="col-8">
                        <img t-if="o.env.company.logo" t-att-src="image_data_uri(o.env.company.logo)" alt="Logo"
                             class="center"/>
                    </div>
                    <div class="col-4" style="text-align:right; font-size:11px;margin-top:15px;">
                        <h7 style="color:black;">
                            <t t-if="o.env.company.street">
                                <t t-esc="o.env.company.street"/>,
                                <br/>
                                <t t-esc="o.env.company.street2"/>,
                                <br/>
                                <t t-esc="o.env.company.city"/>
                            </t>
                        </h7>
                        <br/>
                        <h7 style="color:black;">
                            <t t-if="o.env.company.phone">
                                <t t-esc="o.env.company.phone"/>
                            </t>
                        </h7>
                    </div>
                </div>
            </div>
        </div>
    </template>
    <template id="pr_customized_footer">
        <div class="footer">
            <div class="row" style="font-size:11px;font-family:'Roboto',sans-serif;color:#191970;">
                <div class="col-4 text-center" style="margin-top:50px;">
                    <span>Printed By:
                        <span t-esc="request.env.user.name"/>
                    </span>
                </div>
                <div class="col-4 text-center" style="margin-top:50px;"/>

                <div class="col-4 text-center" style="margin-top:50px;">
                    <span>Print Date:
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y')"/>
                    </span>
                </div>
            </div>
        </div>
    </template>
