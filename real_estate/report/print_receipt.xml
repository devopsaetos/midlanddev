                                    <div class="col-7">
                                        <span t-field="o.partner_id.name"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-4">
                                        <strong>Customer No:</strong>
                                    </div>
                                    <div class="col-7">
                                        <span t-esc="o.partner_id.ref"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-4">
                                        <strong>Payment Journal:</strong>
                                    </div>
                                    <div class="col-7">
                                        <span t-field="o.journal_id"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-4">
                                        <strong>Memo:</strong>
                                    </div>
                                    <div class="col-8">
                                        <span t-esc="o.communication"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="row">
                                    <div class="col-2"/>
                                    <div class="col-4">
                                        <strong>Receipt #:</strong>
                                    </div>
                                    <div class="col-7">
                                        <b>
                                            <span t-field="o.name"/>
                                        </b>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-2"/>
                                    <div class="col-4">
                                        <strong>Date:</strong>
                                    </div>
                                    <div class="col-6">
                                        <span t-field="o.payment_date"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-2"/>
                                    <div class="col-4">
                                        <strong>Cheque Name:</strong>
                                    </div>
                                    <div class="col-6">
                                        <span t-esc="o.cheque_name"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-2"/>
                                    <div class="col-4">
                                        <strong>Cheque No:</strong>
                                    </div>
                                    <div class="col-6">
                                        <span t-esc="o.cheque_no"/>
                                    </div>
                                </div>
                            </div>
