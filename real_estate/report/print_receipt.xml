                                    <th class="text-capitalize" style="color:white;font-weight: normal;">Category
                                    </th>
                                    <th class="text-capitalize"
                                        style="color:white;font-weight: normal;text-align:center;">Plot Number
                                    </th>
                                    <th class="text-capitalize" style="color:white;font-weight: normal;">Invoice
                                        Number
                                    </th>
                                    <th class="text-capitalize" style="color:white;font-weight: normal;">Payment
                                        Type
                                    </th>
                                    <th class="text-capitalize"
                                        style="color:white;text-align:center;font-weight: normal;">Total
                                    </th>
                                    <th class="text-capitalize"
                                        style="color:white; text-align:center;font-weight: normal;">Paid
                                    </th>
                                    <th class="text-capitalize"
                                        style="color:white;text-align:center;font-weight: normal;">Due
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="total" t-value="0"/>
                                <t t-set="total_paid" t-value="0"/>
                                <t t-if="o.is_advance_payment">
                                    <tr style="color:black;">
                                        <th/>
                                        <th/>
                                        <th/>
                                        <th/>
                                        <th class="text-capitalize" style="color:black;font-weight: normal;">Advance
                                            Payment
                                        </th>
                                        <th/>
                                        <th style="color:black;font-weight: normal; text-align:right;">
                                            <span t-esc="o.amount"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </th>
                                        <th/>
                                    </tr>
                                </t>
                                <t t-else="">
                                    <tr t-foreach="o.invoice_ids" t-as="inv" style="color:black;">
                                        <th style="color:black;font-weight: normal;">
                                            <t t-if="o.invoice_ids.property_invoice_type=='token'">
                                                <span t-esc="o.invoice_ids.token_id.serial_number"/>
                                            </t>
                                            <t t-elif="o.invoice_ids.property_invoice_type=='investment_installment'">
