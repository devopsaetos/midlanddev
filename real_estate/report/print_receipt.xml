                                            <t t-if="o.invoice_ids.property_invoice_type=='token'">
                                                <span t-esc="o.invoice_ids.token_id.token_line_ids[0].category_id.name"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="inv.file_ids.category_id.name"/>
                                            </t>
                                        </th>
                                        <th style="color:black;font-weight: normal;">
                                            <t t-if="o.invoice_ids.property_invoice_type=='token'">
                                                <span t-esc="o.invoice_ids.token_id.token_line_ids[0].inventory_id.name"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="inv.file_ids.unit_number"/>
                                            </t>
                                        </th>
                                        <th style="color:black;font-weight: normal;">
                                            <span t-field="inv.name"/>
                                        </th>
                                        <th class="text-capitalize" style="color:black;font-weight: normal;">
                                            <t t-set="values" t-value="dict(([
		                                ('initial_payment', 'Initial Payment'),
		                                ('adv_and_securities', 'Advances and Securities'),
		                                ('installment', 'Installment'),
		                                ('initial_payment_plus_installment', 'Initial Payment + Installment'),
		                                ('transfer_application', 'Transfer Application'),
		                                ('rent', 'Rent'),
		                                ('others', 'Others'),('token', 'Token'),('investment', 'Investment'),
		                                ('investment_installment', 'Investment Installment')
		                                ]))"/>
                                            <t t-esc="values[o.invoice_ids.property_invoice_type]"/>
                                        </th>
                                        <th class="text-right" style="color:black;font-weight: normal;">
                                            <span t-field="o.invoice_ids[0].amount_total"/>
                                        </th>
                                        <th class="text-right" style="color:black;font-weight: normal;">
                                            <span t-esc="o.amount"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
