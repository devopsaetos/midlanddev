<odoo>
        <template id="full_greeting_letter">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="container">
                            <style>
                                p {
                                font-family: "Times New Roman", Times, serif;
                                font-size: 16px;
                                color: black;
                                }
                                li {
                                font-family: "Times New Roman", Times, serif;
                                font-size: 16px;
                                color: black;
                                }
                                table, th, td {
                                border: 1px solid black;
                                color: black;
                                font-family: "Times New Roman", Times, serif;
                                font-size: 16px;
                                }
                            </style>

                            <div class="row" style="margin-top:20px;">
                                <div class="col-xs-4 col-xs-offset-8">
                                    <p>
                                        Tracking ID:
                                        <span style="text-decoration: underline;" t-field="o.tracking_id"/>
                                    </p>
                                </div>
                            </div>

                            <div class="row" style="margin-top:20px;">
                                <div class="col-xs-5">
                                    <p>
                                        <span style="text-decoration: underline;" t-field="o.booking_date"
                                              t-options='{"format": "MM/dd/yyyy"}'/>
                                    </p>
                                </div>
                            </div>

                            <div class="row" style="margin-top:20px; margin-left:20px;">
                                <div class="col-xs-5">
                                    <p>
                                        <span style="text-decoration: underline;" t-field="o.membership_id"/>
                                        <br/>
                                        S/o,D/o,W/o
                                        <span style="text-decoration: underline;"
                                              t-field="o.membership_id.relation_name"/>
                                        <br/>
                                        <span style="text-decoration: underline;" t-field="o.membership_id.street"/>
                                        <br/>
                                        <t t-if="o.membership_id.street2">
                                            <span style="text-decoration: underline;"
                                                  t-field="o.membership_id.street2"/>
                                            <br/>
                                        </t>
                                        <t t-if="o.membership_id.city_id">
                                            <span style="text-decoration: underline;"
                                                  t-field="o.membership_id.city_id"/>
                                            <br/>
                                        </t>
                                    </p>

                                </div>
                                <div class="col-xs-4 col-xs-offset-5">
                                    <b style="text-decoration: underline; font-size: 20px; font-style: oblique;color:#283075;">
                                        Greetings:
                                    </b>

                                </div>
                            </div>

                            <div style="margin-left:50px;">
                                <p>
                                    <strong>
                                        Dear Mr./Ms.
                                        <span style="text-decoration: underline;" t-field="o.membership_id"/>
                                    </strong>
                                </p>
                            </div>

                            <div style="margin-left:50px;">
                                <p>
                                    I would like to welcome you as a member of this exclusive community. “<t
                                        t-esc="res_company.name"/>” is a premium project located right in the heart of<t
                                        t-esc="res_company.city"/>.
                                </p>
                                <!--                                <p>-->
                                <!--                                    The project land is strategically located at the intersection of three main-->
                                <!--                                    structure roads namely-->
                                <!--                                    <strong>Coastal Highway (300 ft. wide), Sarawan Avenue and Buleda-->
                                <!--                                        Avenue.-->
                                <!--                                    </strong>-->
                                <!--                                </p>-->
                                <!--                                <p>-->
                                <!--                                    Gwadar Central has located <strong>1 km from Jinnah Avenue</strong> which is the-->
                                <!--                                    main commercial hub-->
                                <!--                                    of Gwadar. It is located <strong>1.5 km</strong> from the <strong>Industrial Zone,-->
                                <!--                                    3.5km-->
                                <!--                                </strong> from <strong>Zero Point,</strong> and-->
                                <!--                                    <strong>4.5 km</strong>-->
                                <!--                                    from-->
                                <!--                                    <strong>Gwadar International Airport.</strong>-->
                                <!--                                </p>-->
                                <p>
                                    We are confident that
                                    <t t-esc="res_company.name"/>
                                    will emerge as one of the icons of modern
                                    living in<t t-esc="res_company.city"/>. We also hope that you will continue to
                                    invest with us in our
                                    future extension projects.
                                </p>
                                <p style="margin-top:50px;">
                                    Below is the detail of the installments of the <strong>plot file.</strong>  You have
                                    booked in<t t-esc="res_company.name"/>:
                                    <br/>
                                </p>
                            </div>
                            <div style="margin-left:50px;">
                                <table class="table table-bordered">
                                    <thead>
                                        <tr style="background-color:#283075;">
                                            <th style="color:white;">Plot Size</th>
                                            <th style="color:white;">Type</th>
                                            <th style="color:white;">Total Price Rs.</th>
                                            <th style="color:white;">Discount</th>
                                            <th style="color:white;">Amount Received in Full</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="text-center">
                                                <span t-field="o.size_id"/>
                                            </td>
                                            <td class="text-left">
                                                <span t-field="o.category_id"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-field="o.net_sale_amount"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-field="o.discount_amount"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-field="o.net_sale_amount"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <br/>
                            </div>

                            <div style="margin-left:50px; margin-top:50px;">
                                <p>
                                    Your cooperation in this regard is highly appreciated. Please feel free to contact
                                    us for any query.
                                </p>
                                <p>
                                    Yours truly,
                                </p>
                            </div>

                            <div style="margin-left:50px; margin-top:60px;">
                                <strong>
                                    <t t-esc="res_company.name"/>
                                </strong>
                            </div>

                            <div style="margin-left:50px;">
                                <p>
                                    <b>
                                        P.S. Only Plot files with up to date installments will be eligible for
                                        balloting.
                                    </b>
                                </p>
                            </div>
                        </div>

                    </t>
                </t>
            </t>
        </template>

        <report
                string="Full Greeting Letter"
                id="full_greeting_letter_action"
                model="file"
                report_type="qweb-pdf"
                name="real_estate.full_greeting_letter"
                file="real_estate.full_greeting_letter"
        />

    
</odoo>