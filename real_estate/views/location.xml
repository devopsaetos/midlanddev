<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="real_estate.location_form">
        <field name="name">real_estate location_form</field>
        <field name="model">location</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title oe_state_size w-100">
                        <field name="project_type" invisible='1'/>
                        <h1 class="w-100">
                            <field name="name" string="Name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field
                                    name="street"
                                    placeholder="Street..."
                                    class="o_address_street"
                            />

                            <field
                                    name="city_id"
                                    placeholder="City"
                                    class="o_address_city"
                                    options='{"no_open": True}'
                                    context="{'state_id': state_id}"
                            />

                            <field
                                    name="state_id"
                                    class="o_address_state"
                                    placeholder="State"
                                    options='{"no_open": True}'
                                    context="{'country_id': country_id}"
                            />
                            <field
                                    name="zip"
                                    placeholder="ZIP"
                                    class="o_address_zip"
                            />
                            <field
                                    name="country_id"
                                    placeholder="Country"
                                    class="o_address_country"
                                    options='{"no_open": True, "no_create": True}'
                            />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="real_estate.location_tree">
        <field name="name">real_estate location_tree</field>
        <field name="model">location</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="street"/>
                <field name="city_id"/>
                <field name="state_id" string="Province"/>
                <field name="zip"/>
                <field name="country_id"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="real_estate.location_search">
        <field name="name">real_estate location_search</field>
        <field name="model">location</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="street"/>
                <field name="city_id"/>
                <field name="state_id" string="Province"/>
                <field name="zip"/>
                <field name="country_id"/>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="real_estate.action_location">
        <field name="name">Location</field>
        <field name="res_model">location</field>

        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to add an New Location.
            </p>
        </field>
        <field name="view_mode">list,form</field>
        <field name="context">{'current_view': 'realestate', 'default_project_type': 'housing_society'}</field>
        <field name="domain">
            [
            ('project_type', '=', 'housing_society')
            ]
        </field>
    </record>

    <menuitem
            id="real_estate.location"
            name="Location"
            parent="real_estate.menu_society"
            action="real_estate.action_location"
            sequence='8'
    />

</odoo>