<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.unit_size_form">
            <field name="name">real_estate unit_size_form</field>
            <field name="model">unit.size</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_type" invisible="1"/>
                                <field name="name"/>
                                <field name="standard_area" string="Total Area (sft)"/>
                                <field name="from_area" groups="real_estate.group_unit_size_in_range"/>
                            </group>
                            <group>
                                <field name="code"/>
                                <field name="to_area" groups="real_estate.group_unit_size_in_range"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.unit_size_tree">
            <field name="name">real_estate unit_size_tree</field>
            <field name="model">unit.size</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="standard_area" string="Total Area (sft)"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.unit_size_search">
            <field name="name">real_estate unit_size_search</field>
            <field name="model">unit.size</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="standard_area" string="Total Area (sft)"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="real_estate.action_unit_size">
            <field name="name">Size</field>
            <field name="res_model">unit.size</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add a Size.
              </p>
            </field>
            <field name="view_mode">list,form</field>
            <field name="domain">
                [
                    ('project_type', 'in', ['housing_society', False])
                ]
            </field>
            <field name="context">{'current_view' : 'realestate', 'default_project_type':'housing_society'}</field>
        </record>

        <menuitem
            id="real_estate.unit_size"
            name="Size"
            parent="real_estate.menu_inventory"
            action="real_estate.action_unit_size"
            sequence='3'
        />
        
</odoo>