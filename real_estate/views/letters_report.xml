<?xml version="1.0" encoding="utf-8"?>
<odoo>
      	<record model="ir.ui.view" id="real_estate.customized_letter_form">
            <field name="name">real_estate customized_letter_form</field>
            <field name="model">reminder.letters</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
    	            <sheet>
    	            	<group>
    		              	<group>
                                <field name="starting_month"/>
                            </group>
                            <group>
                                <field name="ending_month"/>
                            </group>
    		            </group>
                         <notebook colspan="4">
                            <page string="Members" >
                                <field name="members_id"/>
                            </page>
                        </notebook>
    	            </sheet>
                    <footer>
                        <button string="Print" name="print_letters" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
    	    </field>
    	</record>

      	<record model="ir.actions.act_window" id="real_estate.action_letters">
            <field name="name">Letter</field>
            <field name="res_model">reminder.letters</field>

            <field name="view_mode">form</field>
            <field name="context">{'current_view': 'realestate'}</field>
            <field name="target">new</field>
        </record>

        <menuitem 
            id="real_estate.customized_letter" 
            name="Letters"
            parent="real_estate.menu_reports"
            action="real_estate.action_letters"
            sequence='10'
        />
</odoo>
