<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.source_form">
            <field name="name">real_estate member_category_form</field>
            <field name="model">source</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.source_tree">
            <field name="name">real_estate source_tree</field>
            <field name="model">source</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.source_search">
            <field name="name">real_estate source_search</field>
            <field name="model">source</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="real_estate.action_source">
            <field name="name">Source</field>
            <field name="res_model">source</field>

            <field name="view_mode">list,form</field>
            <field name="context">{ 'current_view': 'realestate' }</field>
        </record>

        <menuitem
            id="real_estate.source"
            name="Source"
            parent="real_estate.menu_configuration"
            action="real_estate.action_source"
            sequence='4'
        />

</odoo>