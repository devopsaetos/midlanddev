<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.street_form">
            <field name="name">real_estate street_form</field>
            <field name="model">street</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="sector_id"/>
                                <field
                                        name="company_id"
                                        options="{'no_create': True, 'no_open': True}"
                                        required="1"
                                />
                            </group>
                            <group>
                                <field name="code"/>
                                <field name="street_type"/>
                                <field
                                    name="branch_id"
                                    options="{'no_create': True, 'no_open': True}"
                                    required="1"
                                />
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page name="plot_inventory" string="Units" autofocus="autofocus">
                                <field name="plot_inventory_ids" readonly = '1'>
                                    <list>
                                        <field name="serial_number" string="Plot No."/>
                                        <field name="category_id"/>
                                        <field name="unit_category_type_id" string="Product"/>
                                        <field name="size_id" string="Size"/>
                                        <field name="unit_class_id" string="Type"/>
                                        <field name="standard_area" string="Total Area (sft)"/>
                                        <!-- <field name="name" invisible="1"/> -->
                                        <!-- <field name="demarcation_id" invisible="1"/> -->
                                        <field name="possession_status" string="Status"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.street_tree">
            <field name="name">real_estate street_tree</field>
            <field name="model">street</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="sector_id"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

