        <record model="ir.actions.act_window" id="real_estate.action_street">
            <field name="name">Street</field>
            <field name="res_model">street</field>
            <field name="context">
                {
                    'search_default_group_by_sector_id': 1,
                }
            </field>
            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click create to add Street.
              </p>
            </field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="real_estate.street"
            name="Street"
            parent="real_estate.menu_society"
            action="real_estate.action_street"
            sequence='5'
        />
        
</odoo>