<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="real_estate.investor_payment_form" model="ir.ui.view">
            <field name="name">real_estate investor_payment</field>
            <field name="model">investment.payment</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form string="Create Payment">
                    <sheet>
                        <group>
                            <group>
                                <field name="investment_id" domain="[('state', '=', 'payment'),('project_type','=','housing_society')]" options="{'no_create': True, 'no_open': True}"/>
                                <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="date"/>
                            </group>
                            <group>
                                <field name="total_amount"/>
                                <field name="payment_amount"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Create Payment" name="create_payment" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="real_estate.action_investor_payment">
            <field name="name">Deal Payment</field>
            <field name="res_model">investment.payment</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>
            <field name="view_id" ref="real_estate.investor_payment_form"/>
            <field name="context">{'current_view': 'realestate'}</field>
        </record>

