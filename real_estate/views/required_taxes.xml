<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.tax_setup_form">
            <field name="name">real_estate tax_setup_form</field>
            <field name="model">tax.setup</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="transaction_type"/>
                            </group>
                            <group>
                                <field name="setup_for"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page string="Tax Requirements" autofocus="autofocus">
                                <field name="tax_setup_line_ids">
                                    <list editable="bottom">
                                        <field name="name" required="1"/>
                                        <field name="description"/>
                                        <field name="tax_status" required="1"/>
                                        <field name="product_id" required="1"/>
                                        <field name="rate" required="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.tax_setup_tree">
            <field name="name">real_estate tax_setup_tree</field>
            <field name="model">tax.setup</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="transaction_type"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.tax_setup_search">
            <field name="name">real_estate tax_setup_search</field>
            <field name="model">setup</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="transaction_type"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="real_estate.action_tax_setup">
            <field name="name">Required Taxes</field>
            <field name="res_model">tax.setup</field>

            <field name="view_mode">list,form</field>
            <field name="context">{'current_view': 'realestate'}</field>
        </record>

        <menuitem 
            id="real_estate.tax_setup"
            name="Required Taxes"
            parent="real_estate.menu_configuration"
            action="real_estate.action_tax_setup"
            sequence='5'
        />

        <record model="ir.ui.view" id="real_estate.required_taxes_form">
            <field name="name">real_estate required_taxes_form</field>
            <field name="model">required.taxes</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group string="Seller">
                            <group>
                                <field name="membership_id" readonly="1" required="1"/>
                                <field name="seller_name" readonly="1"/>
                            </group>
                            <group>
                                <field name="seller_total_tax" readonly="1"/>
                                <field name="transfer_req_id" readonly="1"/>
                            </group>

                        </group>
                        <group string="Tax Details">
                                <form>
                                    <field name="seller_required_tax_ids">
                                        <list editable="bottom">
                                            <field name="name" readonly="1"/>
                                            <field name="product_id"/>
                                            <field name="rule" readonly="1"/>
                                            <field name="rate"/>
                                            <field name="amount"/>
                                        </list>
                                    </field>
                                </form>
                            </group>
                        <group string="Buyer">
                            <group>
                                <field name="transferee_partner_id"/>
                                <field name="buyer_name" readonly="1" required="0"/>
                            </group>
                            <group>
                                <field name="buyer_total_tax" readonly="1"/>
                                <field name="transfer_req_id" readonly="1"/>
                            </group>

                        </group>
                        <group string="Tax Details">
                                <form>
                                    <field name="buyer_required_tax_ids">
                                        <list editable="bottom">
                                            <field name="name" readonly="1"/>
                                            <field name="product_id"/>
                                            <field name="rule" readonly="1"/>
                                            <field name="rate"/>
                                            <field name="amount"/>
                                        </list>
                                    </field>
                                </form>
                        </group>
                        <group string="Other Charges">
                            <group>
                                <field name="charges_partner_id" readonly="0"/>
                            </group>
                            <group>
                                <field name="total_charges" readonly="1"/>
                            </group>
                            <group></group>
                        </group>
                        <group string="Details">
                                <form>
                                    <field name="other_charges_ids">
                                        <list editable="bottom">
                                            <field name="product_id"/>
                                            <field name="amount"/>
                                        </list>
                                    </field>
                                </form>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="real_estate.tax_invoice_popup" model="ir.ui.view">
            <field name="name">real_estate tax_invoice_popup</field>
            <field name="model">tax.invoice.popup</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form string="Create Invoice">
                    <sheet>
                        <group>
                            <group>
                                <field name="required_tax_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="date"/>
                                <field name="journal_id" required="1" options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="partner_id"/>
                                <field name="cheque_name"/>
                                <field name="cheque_no"/>
                                <field name="bank_ref"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page name="product_detail" string="Product Detail">
                                <field name="product_line" readonly="1">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Receive Payment" name="create_invoice" type="object" class="btn-primary"
                                invisible="payment_type != 'osp'"/>
                        <button string="Create Invoice" name="create_invoice" type="object" class="btn-primary"
                                invisible="payment_type != 'tsp'"/>
                        <button string="Discard" class="btn-default" special="cancel"/>
                        <field name="payment_type" invisible="1"/>
                    </footer>
                </form>
            </field>
        </record>
        
</odoo>