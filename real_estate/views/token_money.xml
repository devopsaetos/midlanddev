<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <!-- Form View Of Token Money -->
    <record id="real_estate.validate_token_form" model="ir.ui.view">
        <field name="name">validate.token.fee.wizard</field>
        <field name="model">token.money</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form name="token_money_form" string="Token Fee">
                <header>
                    <button name="token_expiry" type="object" string="Expire Token" class="oe_highlight"
                            groups="real_estate.group_token_expiry"
                            invisible="state != 'open' or validity_expire == True"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                                class="oe_stat_button"
                                name="create_member"
                                type="object" icon="fa-pencil-square-o"
                                string="Member"
                                invisible="(((((token_generated != True or is_existing == True) or state == 'cancel') or state == 'refund') or validity_expire == True) or create_open_file == True)">
                        </button>
                        <button
                                class="oe_stat_button"
                                name="create_file"
                                type="object" icon="fa-pencil-square-o"
                                string="File"
                                invisible="(((((token_generated != True or is_existing != True) or state == 'cancel') or state == 'refund') or validity_expire == True) or create_open_file == True)">
                        </button>
                        <button
                                class="oe_stat_button"
                                name="create_open_files"
                                type="object" icon="fa-pencil-square-o"
                                string="Open File"
                                invisible="((payment_type != 'lump_sum' or create_open_file != True) or state != 'adjusted')">
                        </button>
                        <button
                                class="oe_stat_button"
                                name="propose_plan"
                                type="object" icon="fa-pencil-square-o"
                                string="Installment Calculator"
                                invisible="(((state == 'refund' or state == 'cancel') or validity_expire == True) or payment_type == 'lump_sum')"
                        >
                        </button>
                        <button
                                class="oe_stat_button"
                                name="create_token_fees"
                                type="object" icon="fa-pencil-square-o"
                                string="Generate Token"
                                invisible="token_generated == True">
                        </button>
                        <button
                                class="oe_stat_button"
                                name="create_open_file_invoice"
                                type="object" icon="fa-pencil-square-o"
                                string="Create Invoice"
                                invisible="(((state == 'adjusted' or payment_type != 'lump_sum') or token_paid != True) or create_open_file != True)">
                        </button>
                        <button
                                class="oe_stat_button"
                                name="cancel_token"
                                type="object" icon="fa-pencil-square-o"
                                string="Cancel Token"
                                invisible="state in ('cancel', 'refund', 'adjusted')">
                        </button>
                        <button
                                name="increase_validity" string="Increase Validity"
                                type="object" class="oe_stat_button" icon="fa-pencil-square-o"
                                invisible="state != 'open'">
                        </button>
                        <button
                                class="oe_stat_button"
                                name="token_refund"
                                type="object" icon="fa-pencil-square-o"
                                string="Token Refund"
                                invisible="state != 'paid'">
                        </button>
                        <button
                                name="open_invoices"
                                type="object"
                                class="oe_stat_button"
                                string="Invoices :  "
                                icon="fa-pencil-square-o"
                                invisible="no_of_invoices == 0">

                            <field name="no_of_invoices" invisible="no_of_invoices == 0"/>
                        </button>
                    </div>
                    <div class="oe_title oe_state_size" invisible="token_generated != True">
                        <h1>
                            <field name="serial_number"/>
                        </h1>
                    </div>
                    <group string="Contact Information">
                        <group>
                            <!--                            <field name="file_created" invisible="1"/>-->
                            <field name="validity_expire" invisible="1"/>
                            <field name="token_generated" invisible="1"/>
                            <field name="plan_locked" invisible="1"/>
                            <field name="open_file_amount_received" invisible="1"/>
                            <field name="party_type" readonly="token_generated == True"/>
                            <field name="investor_id" invisible="party_type != 'investor'"
                                   required="party_type == 'investor'" readonly="token_generated == True"
                                   options="{'no_create': True}"/>
                            <field name="investment_id" string="Investment No"
                                   invisible="party_type != 'investor'"
                                   readonly="token_generated == True"
                                   domain="[('partner_id', '=', investor_id)]"
                                   options="{'no_create': True}"/>
                            <field name="no_of_units" invisible="party_type != 'investor'"/>
<!--                            <field name="is_existing"-->
<!--                                   readonly="(token_generated == True or token_generated == True)"/>-->
                            <field name="is_existing" invisible="1"/>
                            <!--<field name="change_member" invisible="party_type == 'investor'"/>-->
                            <field name="create_open_file" invisible="state != 'draft'"/>
                            <!--<field name="contact_name" invisible="is_existing == True or party_type == 'investor'" required="is_existing != True and party_type != 'investor'" readonly="token_generated == True"/>-->
<!--                            <field name="name" invisible="1"/>-->
                            <field name="partner_id" string="Name"/>
                            <field name="member_number" invisible="party_type == 'investor'"/>
                            <field name="file_id" invisible="party_type == 'investor'"/>
                            <!--                            <field name="company_type" string="Member Type"-->
                            <!--                                   readonly="(token_generated == True or is_existing == True)" required="is_existing != True"-->
                            <!--                            />-->

                            <field name="company_type" string="Member Type"
                                   invisible="party_type == 'investor'"
                            />

                            <!--                            <field name="phone_no" widget="mask" data-inputmask="'mask': '+99-999-9999999'"-->
                            <!--                                   readonly="(token_generated == True or is_existing == True)" invisible="company_type != 'person'" required="company_type == 'person'"/>-->
                            <field name="phone_no" widget="mask" data-inputmask="'mask': '+99-999-9999999'"
                                   invisible="company_type != 'person' or party_type == 'investor'"/>
                            <!--                            <field name="cp_phone_no" widget="mask" data-inputmask="'mask': '+99-999-9999999'" string="Phone No"-->
                            <!--                                   readonly="(token_generated == True or is_existing == True)" invisible="company_type == 'person'" required="company_type != 'person'"/>-->
                            <field name="cp_phone_no" widget="mask" data-inputmask="'mask': '+99-999-9999999'"
                                   string="Phone No"
                                   invisible="company_type == 'person' or party_type == 'investor'"/>

                            <field name="cnic" widget="mask" data-inputmask="'mask': '99999-9999999-9'"
                                   readonly="token_generated == True" invisible="company_type != 'person' or party_type == 'investor'" required="company_type == 'person' and party_type != 'investor'"/>
                            <field name="email" readonly="token_generated == True" invisible="party_type == 'investor'"/>
                        </group>
                        <group>
                            <field name="token_fees" readonly="token_generated == True"/>
                            <field name="journal_id" required="1" options="{'no_create': True}"
                                   readonly="token_generated == True"/>
                            <field name="date" string="Valid Upto"
                                   readonly="token_generated == True"/>
                            <field name="token_paid" invisible="1"/>
                            <field name="from_crm" invisible="1"/>
                            <field name="payment_type" required="1"/>
                            <field name="payment_date"/>
                            <field name="ttl_sale_amount" required="1"/>
                            <field name="balance_amount" readonly="1"/>
                            <field name="no_of_invoices" invisible="1"/>
                        </group>
                        <group>
                            <field name="society_id"
                                   domain="[('project_type','=','housing_society'),('is_society','=',True)]"
                                   options="{'no_create': True, 'no_open': True}"
                                   readonly="token_generated == True"/>
                            <field name="project_type" invisible="1"/>
                        </group>
                        <group string="Bank Details">
                            <field name="cheque_name" readonly="token_generated == True"/>
                            <field name="cheque_no" readonly="token_generated == True"/>
                            <field name="bank_ref" readonly="token_generated == True"/>
                        </group>

                    </group>
                    <notebook>
                        <pages string="Unit(s) Reserved">
                            <field name="token_line_ids"
                                   readonly="(from_crm == True or token_generated == True)">
                                <list editable="bottom">
                                    <field name="phase_id"
                                           domain="[('project_type','=','housing_society'),('is_society','!=',True)]"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="sector_id" domain="[('project_type','=','housing_society')]"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="street_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="inventory_id" domain="[('project_type','=','housing_society')]"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="category_id" force_save="1"
                                           domain="[('project_type','=','housing_society')]"
                                           options="{'no_create': True, 'no_open': True}"
                                           readonly="inventory_id != False"/>
                                    <field name="unit_category_type_id" force_save="1"
                                           domain="[('project_type','=','housing_society')]"
                                           options="{'no_create': True, 'no_open': True}"
                                           readonly="inventory_id != False"/>
                                    <field name="size_id" force_save="1"
                                           domain="[('project_type','=','housing_society')]"
                                           options="{'no_create': True, 'no_open': True}"
                                           readonly="inventory_id != False"/>
                                    <field name="unit_class_id" force_save="1"
                                           domain="[('project_type','=','housing_society')]"
                                           options="{'no_create': True, 'no_open': True}"
                                           readonly="inventory_id != False"/>
                                </list>
                            </field>
                        </pages>
                        <pages string="Details"
                               invisible="company_type not in 'aop'">
                            <field name="cnic_line_ids" readonly="is_existing == True">
                                <list editable="bottom">
                                    <field name="member_name" required="1"/>
                                    <field name="cnic" widget="mask"
                                           data-inputmask="'mask': '99999-9999999-9'" required="1"/>
                                    <field name="cnic_expiry_date"/>
                                    <field name="cnic_front"/>
                                    <field name="cnic_back"/>
                                    <field name="phone"/>
                                    <field name="address"/>
                                    <field name="name" required="1"/>
                                    <field name="father_spouse_cnic" widget="mask"
                                           data-inputmask="'mask': '99999-9999999-9'" required="1"/>
                                </list>
                            </field>
                            <!--                                    </page>-->
                            <!--                                </notebook>-->
                            <!--                            </group>-->
                        </pages>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="real_estate.validate_token_money_tree" model="ir.ui.view">
        <field name="name">validate.token.fee.wizard</field>
        <field name="model">token.money</field>
        <field name="arch" type="xml">
            <list>
                <field name="serial_number"/>
                <field name="email"/>
                <field name="phone_no"/>
                <field name="society_id"/>
                <field name="token_fees"/>
                <field name="date" string="Valid Upto"/>
            </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="real_estate.token_action">
        <field name="name">Token</field>
        <field name="res_model">token.money</field>
        <field name="domain">[('project_type','=','housing_society'), ('party_type','=','member')]</field>
        <field name="context">{'default_from_crm':0, 'current_view': 'realestate', 'default_project_type':
            'housing_society'}
        </field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('real_estate.validate_token_money_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('real_estate.validate_token_form')}),
                ]"
        />
    </record>

    <menuitem
            id="real_estate.token_menu"
            name="Token"
            action="real_estate.token_action"
            sequence="4"
            parent="real_estate.menu_fms"
    />

    <!-- Investor Token -->
    <record id="real_estate.investor_token_money_tree" model="ir.ui.view">
        <field name="name">investor.token.fee.tree</field>
        <field name="model">token.money</field>
        <field name="arch" type="xml">
            <list>
                <field name="serial_number"/>
                <field name="investor_id"/>
                <field name="society_id"/>
                <field name="token_fees"/>
                <field name="date" string="Valid Upto"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="real_estate.investor_token_action">
        <field name="name">Investor Token</field>
        <field name="res_model">token.money</field>
        <field name="domain">[('party_type','=','investor')]</field>
        <field name="context">{'default_party_type': 'investor', 'current_view': 'realestate'}</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('real_estate.investor_token_money_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('real_estate.validate_token_form')}),
                ]"
        />
    </record>

    <!-- Portfolio Management parent menu is disabled for housing_society (see menuitems.xml);
    keeping this in step with the sibling investors/investment/investor_file menuitems, which
    are commented out for the same reason. Uncomment together if Portfolio Management is enabled. -->
    <!--
    <menuitem
            id="real_estate.investor_token_menu"
            name="Investor Token"
            action="real_estate.investor_token_action"
            sequence='3'
            parent="real_estate.menu_investment_parent"
    />
    -->
    <!--    Record Rule for Multi Company-->
        <record id="real_estate.token_money_rule" model="ir.rule">
            <field name="name">token_money multi-company</field>
            <field name="model_id" ref="model_token_money"/>
            <field name="domain_force">
                [
                '|',
                ('society_id.company_id','=',False),
                ('society_id.company_id','in',company_ids)
                ]
            </field>
        </record>
</odoo>