<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.account_invoice_ext_form">
            <field name="name">real_estate account_invoice_ext_form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
               <xpath expr="//field[@name='partner_shipping_id']" position="after">
                    <field name="property_invoice_type" invisible="1"/>
                     <field name="invoice_way_type" invisible="1"/>
                    <field name="invoice_way_value" invisible="1"/>
                    <field name="not_sync" invisible="1"/>
                    <field name="file_ids" force_save="1" invisible="1"/>
                    <field name="crm_id" invisible="1"/>
                    <field name="token_partner" invisible="1"/>
               </xpath>
            </field>
        </record>
        
</odoo>