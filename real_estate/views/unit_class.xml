<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.unit_class_form">
            <field name="name">real_estate unit_class_form</field>
            <field name="model">unit.class</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_type" invisible="1"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="code"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.unit_class_tree">
            <field name="name">real_estate unit_class_tree</field>
            <field name="model">unit.class</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>

<!--        <record model="ir.ui.view" id="real_estate.unit_class_search">-->
<!--            <field name="name">real_estate unit_class_search</field>-->
<!--            <field name="model">unit.class</field>-->
<!--            <field name="priority">1</field>-->
<!--            <field name="arch" type="xml">-->
<!--                <search>-->
<!--                    <field name="name"/>-->
<!--                    <field name="code"/>-->
<!--                </search>-->
<!--            </field>-->
<!--        </record>-->

        <record model="ir.actions.act_window" id="real_estate.action_unit_class">
            <field name="name">Type</field>
            <field name="res_model">unit.class</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add Type.
              </p>
            </field>
            <field name="domain">
                [
                    ('project_type','=','housing_society')
                ]
            </field>
            <field name="context">{ 'current_view': 'realestate', 'default_project_type':'housing_society'}</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="real_estate.unit_class"
            name="Type"
            parent="real_estate.menu_inventory"
            action="real_estate.action_unit_class"
            sequence='4'
        />
</odoo>