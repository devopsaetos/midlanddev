<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.view_investor_form">
            <field name="name">res.member.form</field>
            <field name="model">res.member</field>
            <field name="priority" eval="10"/>
            <field name="arch" type="xml">
                <form string="Partners">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button
                                    name="open_invoices"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-pencil-square-o"
                            >
                                <field name="no_of_invoices" string="Invoices" widget="statinfo"/>

                            </button>
<!--                            <button-->
<!--                                    name="open_file"-->
<!--                                    type="object"-->
<!--                                    class="oe_stat_button"-->
<!--                                    string="Files :  "-->
<!--                                    icon="fa-folder-open-o"-->
<!--                            >-->

<!--                                <field name="no_of_files"/>-->

<!--                            </button>-->
                            <button
                                    name="toggle_active"
                                    type="object"
                                    class="oe_stat_button" icon="fa-archive">

                                <field
                                        name="active"
                                        widget="boolean_button"
                                        options='{"terminology": "archive"}'
                                />
                            </button>
                        </div>

                        <!-- image is Inherited field -->
                        <field
                                name="image_1920"
                                widget='image'
                                class="oe_avatar"
                                style="width:100px; height:100px"
                        />
                        <div class="oe_title">
                            <h1>
                                <field name="name" required="1" default_focus="1" placeholder="Name"/>
                            </h1>
                            <field name="project_type" invisible="1"/>
                        </div>

                        <group>
                            <group>
                                <field name="is_investor" invisible='1'/>
                                <field name='create_date' invisible='1'/> <!-- create_date is Inherited field -->
                                <field name="ref" string="Investor Number" readonly="1"/>
                                <field name="company_type" string="Investor Type"
                                       readonly="token_generated == True"/>
                                <field name="assigned_user_ids" string="Assigned Users"/>
                                <field name="user_id" string="Prop. Manage. Executive"/>
                                <field name="tracking_id" invisible="1"/>
                                <field name="token_generated" invisible="1"/>
                            </group>
                            <group>
                                <field name='source_ids' options='{"no_open": True, "no_create": True}'/>
                                <field name='cnic' string="CNIC" invisible="company_type != 'person'"/>
                            </group>
                        </group>

                        <notebook colspan="4">
                            <page
                                    string="Company Information"
                                    invisible="company_type not in 'company'"
                                    autofocus="autofocus">
                                <group>
                                    <group name='primary_address' string="Registered Address">
                                        <!-- All address fields are Inherited field except city_id -->
                                        <label for="street" string="Address"/>
                                        <div class="o_address_format">
                                            <field name="street" placeholder="Street..." class="o_address_street"
                                                   required='1'/>
                                            <field name="street2" placeholder="Street 2..." class="o_address_street"/>

                                            <field name="city_id" placeholder="City" class="o_address_city"
                                                   required='1' options='{"no_open": True}'/>

                                            <field name="state_id" string="Province" class="o_address_state"
                                                   placeholder="State" options='{"no_open": True}'
                                                   context="{'country_id': country_id, 'zip': zip}"
                                            />

                                            <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                            <field name="country_id" placeholder="Country" class="o_address_country"
                                                   options='{"no_open": True, "no_create": True}'
                                                   required='1'
                                            />
                                        </div>
                                    </group>
                                    <group name='corespondence_address' string="Correspondence Address">
                                        <label for="street" string="Address"/>
                                        <div class="o_address_format">
                                            <field name="corespondence_street" placeholder="Street..."
                                                   class="o_address_street" force_save="1"/>
                                            <field name="corespondence_street2" placeholder="Street 2..."
                                                   class="o_address_street" force_save="1"/>

                                            <field name="corespondence_city_id" options='{"no_open": True}'
                                                   placeholder="City" class="o_address_city" force_save="1"/>

                                            <field name="corespondence_state_id" string="Province"
                                                   class="o_address_state"
                                                   placeholder="State" options='{"no_open": True}'
                                                   context="{'country_id': country_id, 'zip': zip}"
                                                   force_save="1"
                                            />

                                            <field name="corespondence_zip" placeholder="ZIP" class="o_address_zip"
                                                   force_save="1"/>
                                            <field name="corespondence_country_id" placeholder="Country"
                                                   class="o_address_country"
                                                   options='{"no_open": True, "no_create": True}'
                                                   force_save="1"
                                            />
                                        </div>
                                        <field name="is_same"/>
                                    </group>
                                </group>
                                <group>
                                    <group name='contact_info' string="Contact Person">

                                        <field name="cp_name"/>
                                        <label for="country_code_phone_id" string="Mobile"/>
                                        <div class="o_address_format">
                                            <field name="cp_code_mobile_id"
                                                   placeholder="0092"
                                                   required="company_type == 'company'"
                                                   class="o_country_code" options='{"no_open": True}'/>
                                            <field widget="mask"
                                                   data-inputmask="'mask': '999-9999999'"
                                                   name="cp_mobile"
                                                   required="company_type == 'company'"
                                                   placeholder='3007654321'
                                                   class="o_phone_number"/>
                                        </div>
                                        <label for="cp_landline" string="LandLine"/>
                                        <div class="o_address_format">
                                            <field name="cp_code_landline_id"
                                                   placeholder="0092"
                                                   required="company_type == 'company'"
                                                   class="o_country_code"
                                                   options='{"no_open": True}'/>
                                            <field widget="mask"
                                                   data-inputmask="'mask': '999-9999999'"
                                                   name="cp_landline"
                                                   required="company_type == 'company'"
                                                   placeholder='42987654'
                                                   class="o_phone_number"/>
                                        </div>
                                        <field name="cp_desigination"/>
                                        <label for="email" string="Email"/>
                                        <div>
                                            <field name="email" widget="email" context="{'gravatar_image': True}"/>
                                        </div>
                                    </group>
                                    <group name='Company_info' string="Company Information">

                                        <field name="tax_status"/>
                                        <field name="vat" string="NTN" placeholder="e.g. 7929261-0"/>
                                        <field name="nature_of_business"/>
                                        <label for="cp_landline" string="Telephone"/>
                                        <div class="o_address_format">
                                            <field name="cp_code_landline_id" placeholder="0092"
                                                   required="company_type == 'company'"
                                                   class="o_country_code" options='{"no_open": True}'/>
                                            <field name="cp_landline"
                                                   required="company_type == 'company'"
                                                   placeholder='42987654'
                                                   class="o_phone_number"/>
                                        </div>
                                        <field name="company_email"/>
                                        <field name="fax"/>
                                        <field name="uan"/>
                                    </group>
                                </group>
                            </page>

                            <page string="Personal Information"
                                  invisible="company_type not in 'person'" autofocus="autofocus">
                                <group>

                                    <group name='general_info' string="General Info">
                                        <field name="gender"
                                               required="company_type == 'person'"/>
                                        <field name='dob'/>
<!--                                        <field name='correnponding_option' string="Corresponding"/>-->
<!--                                        <field name='correspondence_mean_id' string="Modes" widget='many2many_tags'/>-->

                                    </group>
                                    <group name='contact_info' string="Contact Info">
                                        <label
                                                for="email"
                                                string="Email"
                                                class="oe_damage_control_1"
                                        />

                                        <div>
                                            <field
                                                    class="oe_damage_control_1"
                                                    name="email"
                                                    widget="email"
                                                    context="{'gravatar_image': True}"
                                            />
                                        </div>
                                        <label for="linkedin" string="LinkedIn"/>
                                        <div>
                                            <field name="linkedin" widget="url" placeholder="https://linkedin.com/in/..."/>
                                        </div>
                                        <label
                                                for="country_code_mobile_id"
                                                string="Primary Mobile"/>
                                        <div class="o_address_format">
                                            <field
                                                    name="country_code_mobile_id"
                                                    placeholder="0092"
                                                    required="company_type == 'person'"
                                                    class="o_country_code"
                                                    options='{"no_open": True}'/>

                                            <field
                                                    name="mobile"
                                                    required="company_type == 'person'"
                                                    placeholder='3008765432'
                                                    class="o_phone_number"/>
                                        </div>

                                        <label for="country_code_mobile2_id" string="Secondary Mobile"/>
                                        <div class="o_address_format">
                                            <field
                                                    name="country_code_mobile2_id"
                                                    placeholder="0092"
                                                    class="o_country_code"
                                                    options='{"no_open": True}'/>

                                            <field
                                                    name="secondary_phone"
                                                    placeholder='3008765432'
                                                    class="o_phone_number"/>
                                        </div>
                                        <label for="country_code_phone_id" string="Phone"/>
                                        <div
                                                class="o_address_format">
                                            <field
                                                    name="country_code_phone_id"
                                                    placeholder="0092"
                                                    class="o_country_code"
                                                    options='{"no_open": True}'/>

                                            <field
                                                    name="phone"
                                                    placeholder='42987654'
                                                    class="o_phone_number"/>
                                        </div>
                                    </group>
                                </group>
                                <group>
                                    <group name='primary_address' string="Primary Address">
                                        <!-- All address fields are Inherited field except city_id -->
                                        <label for="street" string="Address"/>
                                        <div class="o_address_format">
                                            <field
                                                    name="street"
                                                    placeholder="Street..."
                                                    class="o_address_street"
                                                    required='1'/>

                                            <field
                                                    name="street2"
                                                    placeholder="Street 2..."
                                                    class="o_address_street"/>

                                            <field
                                                    name="city_id"
                                                    placeholder="City"
                                                    class="o_address_city"
                                                    required='1'
                                                    options='{"no_open": True}'/>

                                            <field
                                                    name="state_id"
                                                    string="Province"
                                                    class="o_address_state"
                                                    placeholder="State"
                                                    options='{"no_open": True}'
                                                    context="{'country_id': country_id, 'zip': zip}"/>

                                            <field
                                                    name="zip"
                                                    placeholder="ZIP"
                                                    class="o_address_zip"/>

                                            <field
                                                    name="country_id"
                                                    placeholder="Country"
                                                    class="o_address_country"
                                                    options='{"no_open": True, "no_create": True}'
                                                    required='1'/>
                                        </div>
                                    </group>
                                </group>
                                <group name="id_info">
                                    <group string="Identification Info">
                                        <field name='identification_type'/>
                                        <field name='relation_name' string="Mother/Father"
                                               invisible="identification_type != 'parent_cnic'" required="identification_type == 'parent_cnic'"/>
                                        <field
                                                widget="mask"
                                                data-inputmask="'mask': '99999-9999999-9'"
                                                name='cnic'
                                                required="identification_type in ('cnic', 'parent_cnic') and company_type == 'person'" invisible="identification_type != 'cnic'"/>
                                        <field name='cnic_expiry_date'
                                               invisible="identification_type not in ('cnic', 'parent_cnic')"/>
                                        <field name='passport'
                                               invisible="identification_type != 'passport'"/>
                                        <field name='passport_expiry_date'
                                               invisible="identification_type != 'passport'"/>
                                        <field name='passport_front'
                                               required="identification_type == 'passport'" invisible="identification_type != 'passport'"
                                               widget='image'
                                               style="width:100px; height:100px"
                                        />
                                        <field name='form_b'
                                               invisible="identification_type != 'form_b'"
                                        />
                                        <field name='form_b_front'
                                               required="identification_type == 'form_b'" invisible="identification_type != 'form_b'"
                                               widget='image'
                                               style="width:100px; height:100px"
                                        />
                                    </group>
                                    <group string="Authorised Person">
                                        <field name="kin_name" string="Name" required="is_investor == True and company_type == 'person'"/>
                                        <field name="kin_mobile" string="Mobile" widget="mask" data-inputmask="'mask': '9999-9999999'"/>
                                        <field name="kin_cnic" string="CNIC" widget="mask" data-inputmask="'mask': '99999-9999999-9'"/>
                                        <field name="document"/>
                                    </group>

                                    <group invisible="identification_type not in ('cnic', 'parent_cnic')">

                                        <field name='cnic_front'
                                               widget='image'
                                               style="width:100px; height:100"
                                        />
                                        <field name='cnic_back'
                                               widget='image'
                                               style="width:100px; height:100"
                                        />
                                    </group>
                                </group>
                                <group string="Authorised Person">
                                    <field name="authorised_representative_ids">
                                        <list editable="bottom">
                                            <field name="name" string="Name" required="1"/>
                                            <field name="mobile" string="Mobile" required="1" widget="mask" data-inputmask="'mask': '9999-9999999'"/>
                                            <field name="cnic" string="CNIC" required="1" widget="mask" data-inputmask="'mask': '99999-9999999-9'"/>
                                            <field name="document"/>
                                            <field name="status"/>
                                        </list>
                                        <form>
                                            <sheet>
                                                <group>
                                                    <group>
                                                        <field name="name" string="Name" required="1"/>
                                                        <field name="mobile" string="Mobile" required="1" widget="mask" data-inputmask="'mask': '9999-9999999'"/>
                                                        <field name="cnic" string="CNIC" required="1" widget="mask" data-inputmask="'mask': '99999-9999999-9'"/>
                                                        <field name="document"/>
                                                        <field name="status"/>
                                                    </group>
                                                    <group>
                                                        <label for="street" string="Address"/>
                                                        <div class="o_address_format">
                                                            <field
                                                                    name="street"
                                                                    placeholder="Street..."
                                                                    class="o_address_street"
                                                                    required='1'/>
                                                            <field
                                                                    name="city"
                                                                    placeholder="City"
                                                                    class="o_address_city"
                                                                    required='1'
                                                                    options='{"no_open": True}'/>

                                                            <field
                                                                    name="state"
                                                                    string="Province"
                                                                    class="o_address_state"
                                                                    placeholder="State"/>

                                                            <field
                                                                    name="country"
                                                                    placeholder="Country"
                                                                    class="o_address_country"/>
                                                        </div>
                                                    </group>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.view_investor_tree">
            <field name="name">res.member.tree</field>
            <field name="model">res.member</field>
            <field name="priority" eval="10"/>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="ref"/>
                    <field name="cnic"/>
                    <field name="mobile"/>
                    <field name="email"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.view_investor_search">
            <field name="name">res.member.search</field>
            <field name="model">res.member</field>
            <field name="priority" eval="10"/>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="ref"/>
                    <field name="cnic"/>
                    <field name="mobile"/>
                    <field name="tracking_id"/>
                    <field name="email"/>
                </search>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.view_investor_followup_form">
            <field name="name">real_estate view_investor_followup_form</field>
            <field name="model">res.member</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <chatter/>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="real_estate.action_investors">
            <field name="name">Investors</field>
            <field name="res_model">res.member</field>
            <field name="domain">[('is_investor','=',1),('project_type','=','housing_society')]</field>
            <field name="context">
                {
                    'default_is_investor':1,
                    'default_project_type':'housing_society',
                    'current_view': 'realestate'
                }</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new Member.
                </p>
            </field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('real_estate.view_investor_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('real_estate.view_investor_form')})]"
            />
        </record>

        <!--
        <menuitem
                id="real_estate.investors"
                name="Investor"
                parent="real_estate.menu_investment_parent"
                action="real_estate.action_investors"
                sequence='1'
        />
        -->

</odoo>
