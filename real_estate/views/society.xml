        <record model="ir.actions.act_window" id="real_estate.action_society">
            <field name="name">Societies</field>
            <field name="res_model">society</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add an New Society.
              </p><p>
                The main system you want to implement for Real Estate Management System.
              </p>
            </field>
            <field name="domain">
                [
                    ('is_society','=',1),
                    ('project_type','=','housing_society')
                ]
            </field>
            <field name="context">
                {
                    'default_is_society':1,
                    'default_project_type':'housing_society',
                    'current_view': 'realestate'
                }
            </field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="real_estate.society"
            name="Societies"
            parent="real_estate.menu_society"
            action="real_estate.action_society"
            sequence='1'
        />

        <menuitem
            id="real_estate.society_phase"
            name="Phase"
            parent="real_estate.menu_society"
            action="real_estate.action_phase"
            sequence='2'
        />

