<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.file_attachment_form">
            <field name="name">real_estate file_attachment_form</field>
            <field name="model">file.attachment</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                 <field name="transfer_id" invisible="1"/>
                                 <field name="transfer_type"/>
                            </group>
                            <group>
                                <field name="doc_attachment_ids" widget="many2many_binary" class="oe_inline"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model='ir.ui.view' id="real_estate.file_attachment_tree">
            <field name="name">real_estate file_attachment_tree</field>
            <field name="model">file.attachment</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="transfer_type"/>
                    <field name="doc_attachment_ids"/>
                </list>
            </field>
        </record>

</odoo>