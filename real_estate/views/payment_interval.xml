<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.payment_interval_form">
            <field name="name">real_estate payment_interval_form</field>
            <field name="model">payment.interval</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_type" invisible="1"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="nom"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.payment_interval_tree">
            <field name="name">real_estate payment_interval_tree</field>
            <field name="model">payment.interval</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="nom"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.payment_interval_search">
            <field name="name">real_estate payment_interval_search</field>
            <field name="model">payment.interval</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="nom"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="real_estate.action_payment_interval">
            <field name="name">Payment Interval</field>
            <field name="res_model">payment.interval</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click create to add Payment Interval.
              </p>
            </field>
            <field name="domain">
                [
                    ('project_type','=','housing_society')
                ]
            </field>
            <field name="context">{ 'current_view': 'realestate', 'default_project_type':'housing_society'}</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="real_estate.payment_interval"
            name="Payment Interval"
            parent="real_estate.menu_price_plan"
            action="real_estate.action_payment_interval"
            sequence='20'
        />
</odoo>