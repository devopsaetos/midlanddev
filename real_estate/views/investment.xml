    <record model="ir.actions.act_window" id="real_estate.action_investment">
        <field name="name">Investment</field>
        <field name="res_model">investment</field>

        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click create to add Investment data.
            </p>
        </field>
        <field name="domain">
            [
            ('project_type', '=', 'housing_society')
            ]
        </field>
        <field name="context">{'current_view': 'realestate', 'default_project_type': 'housing_society'}</field>
        <field name="view_mode">list,form</field>
    </record>

