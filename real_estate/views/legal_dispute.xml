<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <!-- Form View Of legal.dispute -->

    <record id="real_estate.legal_dispute_form" model="ir.ui.view">
        <field name="name">legal.dispute</field>
        <field name="model">legal.dispute</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Legal Dispute">
                <header>
                    <button name="make_file_disputed"
                            groups="real_estate.group_rsms_manager"
                            type="object"
                            string="Create"
                            class="oe_highlight"
                            invisible="state not in 'draft'"
                    />
                    <button name="resolved"
                            groups="real_estate.group_rsms_manager"
                            type="object"
                            string="Resolved"
                            class="oe_highlight"
                            invisible="state in ['draft', 'resolved']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="dispute_seq"/>
                            <field name="project_type" invisible="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="dispute_date"
                                   readonly="state != 'draft'"/>
                            <field name="court" readonly="state != 'draft'"/>
                            <field name="legal_team" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="filed_by" readonly="state != 'draft'"/>
                            <field name="case_type" readonly="state != 'draft'"/>
                            <field name="society_id" options="{'no_create': True}"
                                   domain="[
                                            ('is_society','=',1),
                                            ('project_type','=','housing_society')
                                           ]" readonly="state != 'draft'"/>
                            <field name="mark_disputed" invisible="1"/>
                        </group>
                    </group>

                    <field name="legal_dispute_line_ids" readonly="state != 'draft'">
                        <list name="dispute_tree_styles" editable="bottom">
                            <field name="file_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="phase_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[
                                            ('is_society','!=',1),
                                            ('project_type','=','housing_society')
                                           ]"/>
                            <field name="sector_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('project_type','=','housing_society')]"/>
                            <field name="street_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="inventory_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('project_type','=','housing_society')]"/>
                            <field name="category_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('project_type','=','housing_society')]"/>
                            <field name="unit_category_type_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('project_type','=','housing_society')]"/>
                            <field name="size_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('project_type','=','housing_society')]"/>
                            <field name="unit_class_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('project_type','=','housing_society')]"/>
                            <field name="no_of_units" class="real_estate_dispute_tree_styles"/>
                        </list>
                    </field>
                    <notebook>
                        <page string="History">
                            <field name="dispute_info_ids">
                                <list editable="bottom">
                                    <field name="hearing_date"/>
                                    <field name="outcome"/>
                                    <field name="next_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="real_estate.legal_dispute_tree" model="ir.ui.view">
        <field name="name">legal.dispute</field>
        <field name="model">legal.dispute</field>
        <field name="arch" type="xml">
            <list>
                <field name="dispute_seq"/>
                <field name="filed_by"/>
                <field name="case_type"/>
            </list>
        </field>
    </record>

    <record id="real_estate.legal_dispute_action" model="ir.actions.act_window">
        <field name="name">Legal Dispute</field>
        <field name="res_model">legal.dispute</field>
        <field name="view_mode">list,form</field>
        <field name="view_id"/>
        <field name="domain">
            [
            ('project_type','=','housing_society')
            ]
        </field>
        <field name="context">{'default_project_type':'housing_society', 'current_view': 'realestate'}</field>
    </record>

    <menuitem
            id="real_estate.legal_dispute_menu"
            name="Legal Disputes"
            action="real_estate.legal_dispute_action"
            parent="real_estate.menu_land_records"
            sequence="5"
    />
</odoo>