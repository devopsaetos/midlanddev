<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.street_type_form">
            <field name="name">real_estate street_type_form</field>
            <field name="model">street.type</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="code"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.street_type_tree">
            <field name="name">real_estate street_type_tree</field>
            <field name="model">street.type</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>

