<!--                <search>-->
<!--                    <field name="name"/>-->
<!--                    <field name="code"/>-->
<!--                </search>-->
<!--            </field>-->
<!--        </record>-->

        <record model="ir.actions.act_window" id="real_estate.action_street_type">
            <field name="name">Street Type</field>
            <field name="res_model">street.type</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click create to add Street Type.
              </p>
            </field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="real_estate.street_type"
            name="Street Type"
            parent="real_estate.menu_inventory"
            action="real_estate.action_street_type"
            sequence='8'
        />
        
</odoo>