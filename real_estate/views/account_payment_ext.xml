<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.view_account_payment_form">
            <field name="name">real_estate view_account_payment_form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <!-- Commented out: cheque_status field doesn't exist in Odoo 19 base account.payment view
                <xpath expr="//field[@name='cheque_status']" position="before">
                    <field name="payment_amount_cal" invisible="1"/>
                    <field name="allow_bank_finance" invisible="1"/>
                    <field name="finance_by" invisible="allow_bank_finance != True" readonly="state != 'draft'"/>
                </xpath>
                -->
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="payment_amount_cal" invisible="1"/>
                    <field name="allow_bank_finance" invisible="1"/>
                    <field name="finance_by" invisible="allow_bank_finance != True" readonly="state != 'draft'"/>
<!--                    Visible on payment form-->
                    <field name="file_id" invisible="payment_type != 'inbound' or payment_category == 'advance_payment'" options="{'no_create': True}"/>
                    <field name="investment_id" invisible="payment_type != 'inbound' or payment_category == 'advance_payment'" options="{'no_create': True}"/>
                </xpath>
                <!-- Commented out: communication field doesn't exist in Odoo 19 base account.payment view
                <xpath expr="//field[@name='communication']" position="attributes">
                    <attribute name="attrs">
                        {'required':[('advance_against','=', 'other')]}
                    </attribute>

                </xpath>
                -->
            </field>
        </record>
</odoo>