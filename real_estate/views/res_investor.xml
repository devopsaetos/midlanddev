<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="investor_registration_form_view">
            <field name="name">res.investor.form</field>
            <field name="model">res.investor</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_process,approve"/>
                        <field name="is_invoice_generation" invisible="1"/>
                        <button name="in_process" type="object" class="oe_highlight" string="In Process"
                                invisible="state != 'draft'"/>
                        <button name="approve" type="object" class="oe_highlight" string="Approve"
                                invisible="state != 'in_process'"/>
                        <button name="%(action_report_dealer_registration)d" type="action"
                                string="Print Registration Form" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button
                                    name="open_invoices"
                                    type="object"
                                    class="oe_stat_button"
                                    string="Payments"
                                    icon="fa-pencil-square-o"
                                    invisible="not is_invoice_generation">
                                <field name="no_of_invoices"/>
                            </button>
                            <button
                                    name="toggle_active"
                                    type="object"
                                    class="oe_stat_button" icon="fa-archive">
                                <field
                                        name="active"
                                        widget="boolean_button"
                                        options='{"terminology": "archive"}'
                                />
                            </button>
                        </div>
                        <field
                                name="image_1920"
                                widget='image'
                                class="oe_avatar"
                                style="width:100px; height:100px"
                                readonly="state == 'approve'"
                        />

                        <div class="oe_title">
                            <h1>
                                <field name="investor_id"
                                       required="1"
                                       default_focus="1"
                                       placeholder="Investor Name"
                                       readonly="state != 'draft'"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="ref" readonly="1"/>
                                <field name="investor_type" required="1"/>
                                <field name="main_investor_id"
                                       invisible="investor_type != 'sub_dealer'" readonly="state != 'draft'"
                                       required="investor_type == 'sub_dealer'"
                                       options="{'no_open': True,'no_create': True}"
                                />
                                <!-- <field name="investment_category"
                                       required="1"
                                       options="{'no_open': True,'no_create': True}"
                                /> -->
                            </group>
                            <group>
                                <field name="company_type"
                                       readonly="state != 'draft'"
                                       string="Dealer Type" required="1"/>
                                <field name="marketing_company_id"
                                       invisible="1" readonly="state != 'draft'"
                                       string="Marketing Company"
                                       options="{'no_open': True,'no_create': True}"
                                       domain="[]"
                                />
                                <field name="show_sale_summary"
                                       invisible="investor_type != 'sub_dealer'"
                                       required="investor_type == 'sub_dealer'"
                                />
                            </group>
                        </group>
                        <group invisible="company_type not in 'person'">
                            <group name='general_info' string="General Info">
                                <field name="owner_name" required="company_type not in 'person'"/>
                                <field name='relation_name' string="Spouse/Father"
                                       invisible="company_type != 'person'" readonly="state != 'draft'"/>
                                <field name="ntn" string="NTN Number"/>
                            </group>
                            <group name='contact_info' invisible="company_type not in 'person'"
                                   string="Contact Info">
                                <field
                                        name="email"
                                        string="Email"
                                        widget="email"
                                        placeholder='for_example123@mail.com'
                                        readonly="state != 'draft'"
                                />
                                <field
                                        name="linkedin"
                                        string="LinkedIn"
                                        widget="url"
                                        placeholder='https://linkedin.com/in/...'
                                        readonly="state != 'draft'"
                                        invisible="1"
                                />
                                <field
                                        name="mobile"
                                        readonly="state != 'draft'" required="company_type == 'person'"
                                        placeholder='+923008765432'
                                        widget="mask"
                                        data-inputmask="'mask': '+99-999-9999999'"
                                        class="o_phone_number"/>
                                <field
                                        name="phone"
                                        widget="mask"
                                        data-inputmask="'mask': '9999999999'"
                                        placeholder='042987654'
                                        class="o_phone_number" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group>
                            <group name='primary_address' string="Primary Address">
                                <label for="street" string="Address"/>
                                <div class="o_address_format">
                                    <field name="street" placeholder="Street..." class="o_address_street"
                                           readonly="state != 'draft'"/>
                                    <field name="street2" placeholder="Street 2..." class="o_address_street"
                                           readonly="state != 'draft'"/>
                                    <field name="city_id" placeholder="City" class="o_address_city"
                                           options="{'no_open': True}" readonly="state != 'draft'"/>
                                    <field name="state_id" string="Province" class="o_address_state"
                                           placeholder="State" options="{'no_open': True}"
                                           context="{'country_id': country_id, 'zip': zip}"
                                           readonly="state != 'draft'"/>
                                    <field name="zip" placeholder="ZIP" class="o_address_zip"
                                           readonly="state != 'draft'"/>
                                    <field name="country_id" placeholder="Country" class="o_address_country"
                                           options="{'no_open': True, 'no_create': True}"
                                           readonly="state != 'draft'"/>
                                </div>
                            </group>
                            <group name='corespondence_address' string="Correspondence Address">
                                <label for="corespondence_street" string="Address"/>
                                <div class="o_address_format">
                                    <field name="corespondence_street" placeholder="Street..."
                                           class="o_address_street" force_save="1" readonly="state != 'draft'"/>
                                    <field name="corespondence_street2" placeholder="Street 2..."
                                           class="o_address_street" force_save="1" readonly="state != 'draft'"/>
                                    <field name="corespondence_city_id" options="{'no_open': True}"
                                           placeholder="City" class="o_address_city" force_save="1"
                                           readonly="state != 'draft'"/>
                                    <field name="corespondence_state_id" string="Province"
                                           class="o_address_state" placeholder="State"
                                           options="{'no_open': True}"
                                           context="{'country_id': country_id, 'zip': zip}" force_save="1"
                                           readonly="state != 'draft'"/>
                                    <field name="corespondence_zip" placeholder="ZIP" class="o_address_zip"
                                           force_save="1" readonly="state != 'draft'"/>
                                    <field name="corespondence_country_id" placeholder="Country"
                                           class="o_address_country"
                                           options="{'no_open': True, 'no_create': True}" force_save="1"
                                           readonly="state != 'draft'"/>
                                </div>
                                <field name="is_same" string="Same As Primary ?" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group name="id_info" invisible="company_type not in 'person'">
                            <group string="Identification Info">
                                <field name='identification_type'
                                       readonly="state != 'draft'"/>
                                <field name='relation_name' string="Mother/Father"
                                       invisible="identification_type != 'parent_cnic'" readonly="state != 'draft'"/>
                                <field
                                        widget="mask"
                                        data-inputmask="'mask': '99999-9999999-9'"
                                        name='cnic' string="CNIC Number"
                                        invisible="identification_type not in ('cnic','parent_cnic')"
                                        readonly="state != 'draft'"/>
                                <field
                                        widget="mask"
                                        data-inputmask="'mask': '999999-999999-9'"
                                        name='nicop'
                                        invisible="identification_type != 'ni_cop'" readonly="state != 'draft'"/>
                                <field name='cnic_expiry_date'
                                       string="CNIC Expiry Date"
                                       invisible="identification_type not in ('cnic','parent_cnic')"
                                       readonly="state != 'draft'"/>
                                <field name='passport'
                                       invisible="identification_type != 'passport'" readonly="state != 'draft'"/>
                                <field name='passport_expiry_date'
                                       invisible="identification_type != 'passport'" readonly="state != 'draft'"/>
                                <field name='form_b'
                                       widget="mask"
                                       data-inputmask="'mask': '99999-9999999-9'"
                                       invisible="identification_type != 'form_b'" readonly="state != 'draft'"
                                />
                            </group>
                            <group string="Authorized Person">
                                <field name="kin_name" string="Name"/>
                                <field name="kin_mobile" string="Mobile" widget="mask"
                                       data-inputmask="'mask': '9999-9999999'"/>
                                <field name="kin_cnic" string="CNIC" widget="mask"
                                       data-inputmask="'mask': '99999-9999999-9'"/>
                                <field name="document"/>
                            </group>
                        </group>
                        <group string="Scan Copy">
                            <group>
                                <field name='cnic_front'
                                       string="CNIC Front"
                                       widget='image'
                                       style="width:100px; height:100"
                                       invisible="identification_type not in ('cnic','parent_cnic','ni_cop')"
                                       readonly="state != 'draft'"
                                />
                                <field name='passport_front'
                                       invisible="identification_type != 'passport'" readonly="state != 'draft'"
                                       widget='image'
                                       style="width:100px; height:100px"
                                />
                                <field name='form_b_front'
                                       invisible="identification_type != 'form_b'" readonly="state != 'draft'"
                                       widget='image'
                                       style="width:100px; height:100px"
                                />
                            </group>
                            <group>
                                <field name='cnic_back'
                                       string="CNIC Back"
                                       widget='image'
                                       style="width:100px; height:100"
                                       invisible="identification_type not in ('cnic','parent_cnic','ni_cop')"
                                       readonly="state != 'draft'"
                                />
                            </group>
                        </group>
                        <notebook>
                            <page string="Registration Details" name="registration_details">
                                <button name="create_registration_invoice" string="Create Payment" class="oe_highlight"
                                        type="object"
                                        invisible="is_invoice_generation"/>
                                <field name="fees_line_ids">
                                    <list editable="bottom">
                                        <field name="amenity_id" string="Fee Type"
                                               options="{'no_open': True,'no_create': True}"/>
                                        <field name="refund_policy"/>
                                        <field name="date"/>
                                        <field name="mode_of_payments"/>
                                        <field name="journal_id"/>
                                        <field name="total_amount" string="Amount"/>
                                        <field name="remarks"/>
                                        <field name="move_id" string="Invoice#" force_save="1" readonly="1"
                                               invisible="1"/>
                                        <field name="payment_id" string="Payment #" force_save="1" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Authorized Person" name="authorized_person_lines">
                                <field name="authorised_representative_ids">
                                    <list editable="bottom">
                                        <field name="name" string="Name" required="1"/>
                                        <field name="mobile" string="Mobile" required="1" widget="mask"
                                               data-inputmask="'mask': '9999-9999999'"/>
                                        <field name="cnic" string="CNIC" required="0" widget="mask"
                                               data-inputmask="'mask': '99999-9999999-9'"/>
                                        <field name="document"/>
                                        <field name="status"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="name" string="Name" required="1"/>
                                                    <field name="mobile" string="Mobile" required="1" widget="mask"
                                                           data-inputmask="'mask': '9999-9999999'"/>
                                                    <field name="cnic" string="CNIC" required="1" widget="mask"
                                                           data-inputmask="'mask': '99999-9999999-9'"/>
                                                    <field name="document"/>
                                                    <field name="status"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Joint Owners"
                                  invisible="company_type != 'company'"
                                  autofocus="autofocus">
                                <field name="cnic_line_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="member_name" required="1"/>
                                        <field name="cnic" widget="mask"
                                               data-inputmask="'mask': '99999-9999999-9'" required="1"/>
                                        <field name="cnic_expiry_date"/>
                                        <field name="cnic_front"/>
                                        <field name="cnic_back"/>
                                        <field name="phone" widget="mask" placeholder="+92-300-2132132"/>
                                        <field name="name" required="1"/>
                                        <field name="father_spouse_cnic" widget="mask"
                                               data-inputmask="'mask': '99999-9999999-9'" required="0"/>
                                        <field name="ownership" string="Owner Percentage"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record model="ir.ui.view" id="investor_registration_tree_view">
            <field name="name">res.investor.tree</field>
            <field name="model">res.investor</field>
            <field name="priority">40</field>
            <field name="arch" type="xml">
                <list delete="false">
                    <field name="ref"/>
                    <field name="investor_id"/>
                    <field name="cnic"/>
                    <field name="mobile"/>
                    <field name="email"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        <record model="ir.actions.act_window" id="action_investor_registration">
            <field name="name">Investors</field>
            <field name="res_model">res.investor</field>
            <field name="domain">[]</field>
            <field name="context">
                {
                'default_company_type': 'person'
                }
            </field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new Investor.
                </p>
            </field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('investor_registration_tree_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('investor_registration_form_view')})]"
            />
        </record>
    </data>
</odoo>
