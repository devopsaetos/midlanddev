        <record model="ir.actions.act_window" id="real_estate.action_sector">
            <field name="name">Sector</field>
            <field name="res_model">sector</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add an New Sector.
              </p><p>
                The Sector will be created in context with the Phases and Societies.
              </p>
            </field>
            <field name="domain">
                [
                    ('project_type','=','housing_society')
                ]
            </field>
            <field name="context">
                {
                    'search_default_group_by_society_id': 1,
                    'search_default_group_by_phase_id': 1,
                    'default_project_type':'housing_society',
                    'current_view': 'realestate'
                }
            </field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="real_estate.sector"
            name="Sector"
            action="real_estate.action_sector"
            parent="real_estate.menu_society"
            sequence="4"
        />

