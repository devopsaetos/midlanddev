<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="real_estate.sector_form">
            <field name="name">real_estate sector_form</field>
            <field name="model">sector</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="project_type" invisible='1'/>
                        <group>
                            <group>
                                <field name="name"/>
                                <field 
                                    name="society_id" 
                                    options="{'no_create': True, 'no_open': True}"
                                    domain="[('is_society', '=', True),('project_type', '=', 'housing_society')]"
                                    />
                                <field
                                        name="company_id"
                                        options="{'no_create': True, 'no_open': True}"
                                        required="1"
                                />
                                <field
                                    name="branch_id"
                                    options="{'no_create': True, 'no_open': True}"
                                    required="1"
                                />
                                <field name="total_plots"/>
                            </group>
                            <group>
                                <field name="code"/>
                                <field
                                    name="phase_id"
                                    options="{'no_create': True, 'no_open': True}"
                                    domain="[('is_society', '!=', True),('project_type', '=', 'housing_society')]"
                                />
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page name="plot_inventory" string="Units" autofocus="autofocus">
                                <field name="plot_inventory_ids" readonly = '1'>
                                    <list>
                                        <field name="serial_number" string="Plot No."/>
                                        <field name='street_id'/>
                                        <field name="category_id"/>
                                        <field name="unit_category_type_id" string="Product"/>
                                        <field name="size_id" string="Size"/>
                                        <field name="unit_class_id" string="Type"/>
                                        <field name="standard_area" string="Total Area (sft)"/>
                                        <!-- <field name="name" invisible="1"/> -->
                                        <!-- <field name="demarcation_id" invisible="1"/> -->
                                        <field name="possession_status" string="Status"/>
                                    </list>
                                </field>
                            </page>
                            <page name="files" string="Files">
                                <field name="file_ids" readonly = '1'>
                                    <list>
                                        <field name="name"/>
                                        <field name='street_id'/>
                                        <field name="category_id"/>
                                        <field name="unit_category_type_id" string="Product"/>
                                        <field name="size_id" string="Size"/>
                                        <field name="unit_class_id" string="Type"/>
                                        <!-- <field name="name" invisible="1"/> -->
                                        <!-- <field name="demarcation_id" invisible="1"/> -->
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_estate.sector_tree">
            <field name="name">real_estate sector_tree</field>
            <field name="model">sector</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="phase_id"/>
                    <field name="total_plots"/>
                    <field name="society_id"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

