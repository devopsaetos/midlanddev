<odoo>
        <record id="real_estate.member_rule" model="ir.rule">
            <field name="name">Member multi-company</field>
            <field name="model_id" ref="real_estate.model_res_member"/>
            <field name="domain_force">['|',('member_company_id','in',company_ids),('member_company_id','=',False)]
            </field>
        </record>

        <record id="real_estate.file_rule" model="ir.rule">
            <field name="name">File multi-company</field>
            <field name="model_id" ref="model_file"/>
            <field name="domain_force">
                [
                '|',
                ('society_id.company_id','=',False),
                ('society_id.company_id','in',company_ids)
                ]
            </field>
        </record>

        <record id="real_estate.society_rule" model="ir.rule">
            <field name="name">Society multi-company</field>
            <field name="model_id" ref="model_society"/>
            <field name="domain_force">
                [
                ('is_society','=',1),
                ('company_id','in',company_ids)
                ]

            </field>
            <field name="groups"
                   eval="[(4, ref('real_estate.group_rsms_user')), (4, ref('real_estate.group_rsms_manager'))]"/>
        </record>

        <record id="real_estate.phase_rule" model="ir.rule">
            <field name="name">Phase multi-company</field>
            <field name="model_id" ref="model_society"/>
            <field name="domain_force">
                [
                ('project_type','in',['skyscraper', 'housing_society']),
                ('society_id.company_id','in',company_ids)
                ]
            </field>
            <field name="groups"
                   eval="[(4, ref('real_estate.group_rsms_user')), (4, ref('real_estate.group_rsms_manager'))]"/>
        </record>

        <record id="real_estate.sector_rule" model="ir.rule">
