<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="real_estate.module_category_real_estate">
        <field name="name">Real Estate</field>
        <field name="sequence">0</field>
        <field name="visible" eval="0"/>
    </record>

    <record id="real_estate.group_rsms_user" model="res.groups">
        <field name="name">User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">the user will have the major access to the Real Estate Management System</field>
    </record>

    <record id="real_estate.group_rsms_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_rsms_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>
        <field name="comment">the user will have the all access to the Real Estate Management System.</field>
    </record>

    <record id="real_estate.group_plot_sale_manager" model="res.groups">
        <field name="name">Followup Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_rsms_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>
        <field name="comment">the user will have the all access to the Real Estate Followup System.</field>
    </record>

    <record id="group_unit_size_in_range" model="res.groups">
        <field name="name">Range Size</field>
    </record>

    <record id="group_unit_size_in_specific" model="res.groups">
        <field name="name">Specific Size</field>
    </record>

    <record id="real_estate.group_user_base_pricing" model="res.groups">
        <field name="name">User Base Pricing</field>
        <field name="comment">the user will have the access to the Real Estate Management System Price List</field>
    </record>

    <record id="real_estate.group_initiate_transfer_req" model="res.groups">
        <field name="name">Initiate Transfer Request</field>
        <field name="comment">The member of the groups will "Initiate Transfer Request".</field>
    </record>

    <record id="real_estate.group_approve_transfer_req" model="res.groups">
        <field name="name">Approve Transfer Request</field>
        <field name="comment">The member of the groups will "Approve Transfer Request".</field>
    </record>

    <record id="real_estate.group_prepare_transfer_app" model="res.groups">
        <field name="name">Prepare Transfer Application</field>
        <field name="comment">The member of the groups will "Prepare Transfer Application".</field>
    </record>

    <record id="real_estate.group_approve_transfer_app" model="res.groups">
        <field name="name">Approve Transfer Application</field>
        <field name="comment">The member of the groups will "Approve Transfer Application".</field>
    </record>

    <record id="real_estate.group_token_expiry" model="res.groups">
        <field name="name">Token Expiry</field>
        <field name="comment">Member of the groups are allowed to expire the token.</field>
    </record>

    <record id="real_estate.group_can_create_edit_delete_record" model="res.groups">
        <field name="name">CED Record</field>
        <field name="comment">Member of this groups are allowed to create, edit and delete the record.</field>
    </record>

    <record id="real_estate.group_can_create_record" model="res.groups">
        <field name="name">Create Member</field>
        <field name="comment">Member of this groups are allowed to only create record they are not allowed to edit .</field>
    </record>
    <!--    Groups For Merger -->
    <record id="real_estate.group_initiate_merger_req" model="res.groups">
        <field name="name">Initiate Merger Request</field>
        <field name="comment">The member of the groups will "Initiate Merger Request".</field>
    </record>

    <record id="real_estate.group_approve_merger_req" model="res.groups">
        <field name="name">Approve Merger Request</field>
        <field name="comment">The member of the groups will "Approve Merger Request".</field>
    </record>

    <record id="real_estate.group_file_approve" model="res.groups">
        <field name="name">File Approve Users</field>
        <field name="comment">Member of this groups are allowed to approve file records.</field>
    </record>

    <record id="real_estate.create_inventory_users" model="res.groups">
        <field name="name">Create Inventory Users</field>
        <field name="comment">Member of this groups are allowed to create inventory records.</field>
    </record>

     <record id="real_estate.approve_inventory_users" model="res.groups">
        <field name="name">Approve Inventory Users</field>
        <field name="comment">Member of this groups are allowed to approve inventory records.</field>
    </record>

    <record id="real_estate.group_file_process" model="res.groups">
        <field name="name">File Process Users</field>
        <field name="comment">Member of this groups are allowed to process file records.</field>
    </record>

     <record id="real_estate.group_transfer_disc_approvers" model="res.groups">
        <field name="name">Transfer Discount Approvers</field>
        <field name="comment">Member of this groups are allowed to transfer discount approve.</field>
    </record>

    <record id="real_estate.group_view_users" model="res.groups">
        <field name="name">View Users</field>
        <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>
        <field name="comment">Members of this group are allowed to view and access system users (Settings > Users).</field>
    </record>

</odoo>
