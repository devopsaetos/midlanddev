<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_form_subcontract_ext" model="ir.ui.view">
        <field name="name">purchase.order.form.subcontract</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <field name="currency_id" position="after">
                <field name="task_subcontract_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
            </field>
            <field name="product_id" position="after">
                <field name="task_subcontract_id" optional="hide"/>
                <field name="subcontract_line_id" optional="hide"/>
            </field>
        </field>
    </record>

</odoo>
