<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Subcontract Form ────────────────────────────────────────── -->
    <record id="task_subcontract_form_view" model="ir.ui.view">
        <field name="name">task.subcontract.form</field>
        <field name="model">task.subcontract</field>
        <field name="arch" type="xml">
            <form string="Sub Contractor Job">
                <header>
                    <button name="action_validate" string="Validate" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary" invisible="state != 'valid'"/>
                    <button name="action_open_create_po_wizard" string="Create Purchase Order"
                            type="object" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,valid,confirm"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="po_button_view" class="oe_stat_button"
                                icon="fa-file-text-o" type="object"
                                invisible="po_count == 0">
                            <field name="po_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="button_view_costsheet"
                                invisible="cost_sheet_count == 0"
                                icon="fa-usd">
                            <field name="cost_sheet_count" widget="statinfo" string="Cost Sheets"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="priority" widget="priority"/>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"
                                   readonly="context.get('from_task')"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="assigned_to"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="start_date"/>
                            <field name="close_date"/>
                        </group>
                        <group>
                            <field name="deadline"/>
                            <field name="task_id"
                                   readonly="context.get('from_task')"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                            <field name="check"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Purchase Order Lines">
                            <field name="purchase_line_ids">
                                <list string="Lines" editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="qty"/>
                                    <field name="order_qty" readonly="1"/>
                                    <field name="uom_id"/>
                                    <field name="rate"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Subcontract List ───────────────────────────────────────── -->
    <record id="task_subcontract_list_view" model="ir.ui.view">
        <field name="name">task.subcontract.list</field>
        <field name="model">task.subcontract</field>
        <field name="arch" type="xml">
            <list string="Sub Contractor Jobs">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="assigned_to"/>
                <field name="start_date"/>
                <field name="close_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'valid'"
                       decoration-success="state == 'confirm'"/>
            </list>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────────── -->
    <record id="action_job_subcontracts" model="ir.actions.act_window">
        <field name="name">Sub Contractor Jobs</field>
        <field name="res_model">task.subcontract</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
