<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_move_form_subcontract_ext" model="ir.ui.view">
        <field name="name">account.move.form.subcontract</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="ref" position="after">
                <field name="task_subcontract_id"
                       invisible="not task_subcontract_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="project_id"
                       invisible="not project_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="task_id"
                       invisible="not task_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
            </field>
        </field>
    </record>

</odoo>
