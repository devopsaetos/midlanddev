<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="maintenance_invoice_report.account_move_ext_form">
            <field name="name">account_move_ext_form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@class='oe_button_box']" position="inside">
                    <button
                            name="print_maintenance_charges_invoice"
                            type="object"
                            string="Maintenance Invoice"
                            icon="fa-print"
                            class="oe_stat_button"
                            invisible="property_invoice_type not in ['maintenance_charges', 'society_charges']"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>