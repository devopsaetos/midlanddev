<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Project Budget Form ────────────────────────────────────── -->
    <record id="project_budget_view_form" model="ir.ui.view">
        <field name="name">project.budget.form</field>
        <field name="model">project.budget</field>
        <field name="arch" type="xml">
            <form string="Project Budget">
                <header>
                    <button string="Confirm" type="object" name="action_confirm"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Approve" type="object" name="action_approved"
                            class="btn-primary"
                            groups="construction_budget.group_project_director"
                            invisible="state != 'confirmed'"/>
                    <button string="Reject" type="object" name="action_reject"
                            class="btn-danger"
                            invisible="state in ('draft', 'rejected')"/>
                    <button string="Reset to Draft" type="object" name="action_reset_to_draft"
                            class="btn-warning"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="sequence" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="state in ('approved','rejected')"/>
                            <field name="budget_from_task"
                                   required="1"
                                   readonly="state in ('approved','rejected')"/>
                            <field name="project_id"
                                   readonly="context.get('active_id') or state in ('approved','rejected')"
                                   required="1"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            <field name="customer_id"
                                   readonly="1"
                                   options="{'no_quick_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Materials" name="material">
                            <field name="material_ids"
                                   readonly="state in ('approved','rejected')">
                                <list editable="bottom">
                                    <field name="task_id"
                                           options="{'no_quick_create': True, 'no_create_edit': True}"/>
                                    <field name="category_id"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="uom_id"/>
                                    <field name="number"/>
                                    <field name="length"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="quantity"/>
                                    <field name="rate"/>
                                    <field name="value" sum="Total Value"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tasks" name="tasks">
                            <field name="task_ids"
                                   readonly="state in ('approved','rejected')">
                                <list editable="bottom">
                                    <field name="task_id"/>
                                    <field name="material_value"/>
                                    <field name="service_value"/>
                                    <field name="ovherhead_value"/>
                                    <field name="total_value" sum="Total"/>
                                    <button name="detail_task_budgeting" type="object"
                                            icon="fa-th" string="Task Details"/>
                                </list>
                            </field>
                        </page>
                        <page string="Other Info" name="other_info">
                            <group>
                                <field name="company_id" readonly="1"
                                       groups="base.group_multi_company"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── Project Budget List ────────────────────────────────────── -->
    <record id="project_budget_view_list" model="ir.ui.view">
        <field name="name">project.budget.list</field>
        <field name="model">project.budget</field>
        <field name="arch" type="xml">
            <list string="Project Budgets" decoration-muted="state == 'rejected'">
                <field name="sequence"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="customer_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────────── -->
    <record id="project_budget_action" model="ir.actions.act_window">
        <field name="name">Project Budgets</field>
        <field name="res_model">project.budget</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ─── Menu ──────────────────────────────────────────────────── -->
    <menuitem id="menu_construction_project_budget"
              name="Project Budgets"
              parent="construction_costing.menu_construction_root"
              action="project_budget_action"
              sequence="10"/>

</odoo>
