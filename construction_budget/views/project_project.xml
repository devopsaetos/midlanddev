<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_form_budget_ext" model="ir.ui.view">
        <field name="name">project.project.form.budget</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <!-- "Create Project Budget" button in header -->
            <header position="inside">
                <button name="action_create_project_budget"
                        string="Create Project Budget"
                        type="object"
                        class="btn-info"
                        invisible="budget_count > 0"/>
            </header>
            <!-- Budget stat button in button_box -->
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object"
                        name="button_view_project_budget"
                        invisible="budget_count == 0"
                        icon="fa-file-text-o">
                    <field name="budget_count" widget="statinfo" string="Budget"/>
                </button>
            </div>
        </field>
    </record>

</odoo>
