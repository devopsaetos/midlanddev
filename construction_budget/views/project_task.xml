<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_form_budget_ext" model="ir.ui.view">
        <field name="name">project.task.form.budget</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <!-- Task Budget stat button -->
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object"
                        name="button_view_task_budget"
                        invisible="budget_count == 0"
                        icon="fa-calculator">
                    <field name="budget_count" widget="statinfo" string="Task Budget"/>
                </button>
            </div>
            <!-- Include For Budgets checkbox near task options -->
            <field name="description" position="before">
                <field name="include_budget"/>
            </field>
        </field>
    </record>

</odoo>
