<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_requisition_ext_form" model="ir.ui.view">
        <field name="name">maintenance_ext purchase_requisition_ext_form</field>
        <field name="model">material.purchase.requisition</field>
        <field name="inherit_id" ref="purchase_requisitions.material_purchase_requisition_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='requisition_description']" position="after">
                <field name="maintenance_request_id" readonly="state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>
