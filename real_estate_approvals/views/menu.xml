<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_investor_approvals_pending" model="ir.actions.act_window">
            <field name="name">Investor Approvals</field>
            <field name="res_model">res.investor</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'in_process'), ('approval_request_ids.approver_ids.user_id', '=', uid)]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No investor approvals waiting for you
                </p>
                <p>
                    Investors submitted for approval will appear here when you
                    are listed as an approver.
                </p>
            </field>
        </record>

        <menuitem id="menu_investor_approvals_pending"
                  name="Investor Approvals"
                  parent="approvals.approvals_menu_root"
                  action="action_investor_approvals_pending"
                  sequence="15"/>
    </data>
</odoo>
