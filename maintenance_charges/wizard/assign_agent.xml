<odoo>

    <record model="ir.ui.view" id="maintenance_agent_form">
        <field name="name">maintenance_agent.form</field>
        <field name="model">maintenance.agent.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Agent">
                <sheet>
                    <div class="oe_title oe_state_size">
                        <h1>
                            <field name="maintenance_recovery_agent_id" options="{'no_create': True, 'no_open': True}"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="society_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('is_society','=',1),('project_type','=','housing_society')]"/>
                            <field name="sector_id" options="{'no_create':True, 'no_open':True}"
                                   domain="[('project_type','=','housing_society')]"/>
                            <field name="unit_category_type_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="unit_class_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="phase_id" options="{'no_create': True, 'no_open': True}"
                                   domain="[('is_society','!=',1)]"/>
                            <field name="category_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="size_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <notebook collspan="4">
                        <page string="Streets">
                            <field name="street_ids" options="{'no_create': True, 'no_open': True}">
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="assign_agent"  string="Assign" class="oe_highlight"  type="object"/>
                    <button string="Discard" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_maintenance_agent_wizard" model="ir.actions.act_window">
        <field name="name">Assign Agent</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">maintenance.agent.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


    <menuitem id="maintenance_charges.menu_maintenance_agent"
              name="Assign Agent"
              parent="maintenance_charges.maintenance_charges_main_menu"
              action="action_maintenance_agent_wizard"
    />

</odoo>