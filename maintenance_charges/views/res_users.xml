<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.ui.view" id="maintenance_charges.res_users_form">
        <field name="name">maintenance_charges res_users_form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- In current Odoo 19 core (base.view_users_form), the 'oe_title' div no longer
                 contains a group/field[@name='partner_id'] structure (it now only holds the
                 name/login/email/phone header fields); partner_id lives in a separate <group>
                 further down the form. Xpath updated to target that group instead. -->
            <xpath expr="//group/field[@name='partner_id']" position="after">
                <field name="maintenance_recovery_agent"/>
            </xpath>
        </field>
    </record>
</odoo>