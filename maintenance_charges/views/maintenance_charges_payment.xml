<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="maintenance_charges_payment_view_form" model="ir.ui.view">
            <field name="name">maintenance_charges maintenance_charges_payment_view_form</field>
            <field name="model">maintenance.charges.payment</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_payment,paid"/>
                        <button class='btn btn-primary'
                                name="receive_payment"
                                type="object"
                                string="Receive Payment"
                                groups="maintenance_charges.group_maintenance_payment_collector,maintenance_charges.group_maintenance_payment_manager"
                                invisible="state == 'paid'"/>
                        <button class='btn btn-primary'
                                name="print_receipt"
                                type="object"
                                string="Print Receipt"
                                invisible="state != 'paid'"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="payment_receipt" type="object" widget="statinfo"
                                    icon="fa-pencil-square-o" string="Receipt"
                                    invisible="1"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="unit_class_id" string="Type"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="inventory_id" string="Unit No."
                                       readonly="state != 'draft'"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="file_id" readonly="state != 'draft'"
                                       options="{'no_create': True, 'no_open': True}" invisible="1"/>
                                <field name="membership_id" string="Member"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="sector_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="category_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="size_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="unit_category_type_id" string="Product"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="remarks" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="product_id" options="{'no_create': True, 'no_open': True}" readonly="0"
                                       required="is_advance_payment != False"/>
                                <field name="date" required="1" readonly="state != 'draft'"/>
                                <field name="journal_id" required="1" readonly="state != 'draft'"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="mode_of_payments" readonly="state != 'draft'"/>
                                <field name="payment_id" string="Payment" readonly="1" invisible="1"/>
                                <field name="payment_ref" string="Payment Ref #" readonly="1"/>

                                <field name="maintenance_recovery_agent_id" string="Recovery Agent"
                                       options="{'no_create': True, 'no_open': True}"
                                       readonly="state != 'draft'"/>
                                <field name="is_advance_payment"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page name="maintenance_charges_invoices" string="Invoices"
                                  invisible="is_advance_payment != False" readonly="state != 'draft'">
                                <field name="invoice_ids" options="{'no_create': True, 'no_open': True}">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="partner_id" invisible="0"
                                               options="{'no_create': True, 'no_open': True}"/>
                                        <field name="date"/>
                                        <!-- <field name="fiscal_month_id" options="{'no_create': True, 'no_open': True}"
                                               readonly="1"/> -->
                                        <!-- fiscal_month_id does not exist on account.move: it belongs to daily.maintenance.batch
                                             (maintenance_recovery_batch, which depends on this module, not the other way round),
                                             and its comodel fiscal.month is not defined anywhere in this project. Pre-existing gap
                                             from before the Odoo 19 migration, kept commented rather than deleted. -->
                                        <field name="invoice_partner_display_name"
                                               invisible="context.get('default_type') not in ('in_invoice', 'in_refund','in_receipt')"
                                               groups="base.group_user" string="Vendor"/>
                                        <field name="invoice_partner_display_name"
                                               invisible="context.get('default_type') not in ('out_invoice', 'out_refund','out_receipt')"
                                               groups="base.group_user" string="Customer"/>
                                        <field name="invoice_date" optional="show"
                                               invisible="context.get('default_type') not in ('in_invoice', 'in_refund','in_receipt')"
                                               string="Bill Date"/>
                                        <field name="invoice_date" optional="show"
                                               invisible="context.get('default_type') not in ('out_invoice', 'out_refund','out_receipt')"
                                               string="Invoice Date"/>
                                        <field name="invoice_user_id" optional="show"
                                               invisible="context.get('default_type') not in ('out_invoice', 'out_refund','out_receipt')"
                                               string="Sales Person"/>
                                        <field name="invoice_date_due" optional="show"/>
                                        <field name="amount_untaxed_signed" string="Tax Excluded"
                                               sum="Total" optional="hide"/>
                                        <field name="amount_tax_signed" string="Tax" sum="Total"
                                               optional="hide"/>
                                        <field name="amount_total_signed" string="Total" sum="Total"
                                               optional="show"/>
                                        <field name="amount_residual_signed" string="Amount Due"
                                               sum="Amount Due" optional="show"/>
                                        <field name="currency_id" invisible="1"/>
                                        <field name="company_currency_id" invisible="1"/>
                                        <field name="state" optional="hide"/>
                                        <!-- <field name="invoice_payment_state" optional="show"/> -->
                                        <!-- invoice_payment_state does not exist on account.move; the real field is payment_state -->
                                        <field name="payment_state" optional="show"/>
                                        <!-- <field name="type"
                                               invisible="context.get('default_type', True)"/> -->
                                        <!-- account.move's "type" field was renamed "move_type" -->
                                        <field name="move_type"
                                               invisible="context.get('default_move_type', True)"/>
                                    </list>
                                </field>
                            </page>
                            <page name="advance_lines" string="Advance Payment"
                                  invisible="is_advance_payment != True" readonly="state != 'draft'">
                                <field name="maintenance_advance_payment_ids">
                                    <list editable="bottom">
                                        <field name="from_date" required="1"/>
                                        <field name="to_date" required="1"/>
                                        <field name="amount"/>
                                        <field name="discount_type"/>
                                        <field name="discount_amount"/>
                                        <field name="net_amount"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="maintenance_charges_payment_view_tree" model="ir.ui.view">
            <field name="name">maintenance_charges maintenance_charges_payment_view_tree</field>
            <field name="model">maintenance.charges.payment</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="file_id" options="{'no_create': True, 'no_open': True}" invisible="1"/>
                    <field name="membership_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="category_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="unit_category_type_id" string="Product"
                           options="{'no_create': True, 'no_open': True}"/>
                    <field name="size_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="date" options="{'no_create': True, 'no_open': True}"/>
                    <field name="journal_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="mode_of_payments"/>
                </list>
            </field>
        </record>

        <record id="maintenance_charges_payment_view_search" model="ir.ui.view">
            <field name="name">maintenance_charges maintenance_charges_request_view_search</field>
            <field name="model">maintenance.charges.payment</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Serial #"/>
                    <field name="file_id"/>
                    <field name="sector_id"/>
                    <field name="category_id"/>
                    <field name="unit_category_type_id" string="Product"/>
                    <field name="size_id"/>
                    <field name="date" string="Date"/>
                    <!-- Odoo 19: <group> in search views no longer accepts expand="0"/string="Group By" attributes (RelaxNG schema rejects them); the web client renders the collapsible "Group By" section automatically. -->
                    <group>
                        <filter name="group_by_sector" string="Sector" domain="[]" context="{'group_by':'sector_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_maintenance_charges_payment">
            <field name="name">Maintenance Charges Payment</field>
            <field name="res_model">maintenance.charges.payment</field>
            <field name="view_mode">list,form,search</field>
            <field name="context">
                {
                'search_default_group_by_sector': 1,
                }
            </field>
        </record>

        <menuitem
                id="maintenance_charges.maintenance_charges_payment"
                name="Maintenance Charges Payment"
                groups="maintenance_charges.group_maintenance_payment_collector,maintenance_charges.group_maintenance_payment_manager"
                parent="maintenance_charges.maintenance_charges_main_menu"
                action="action_maintenance_charges_payment"
                sequence='3'
        />
    </data>
</odoo>