<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="maintenance_charges.view_account_payment_form">
            <field name="name">maintenance_charges view_account_payment_form</field>
            <field name="model">file</field>
            <field name="inherit_id" ref="real_estate.file_form"/>
            <field name="arch" type="xml">
                <xpath expr="/form/sheet/notebook/page[2]" position="inside">
                    <!--                <xpath expr="//page[@name='file']" position="after">-->
                    <group name="maintenance_charges" string="Maintenance Charges">
                        <group>
                            <field name="maintenance_recovery_agent_id" readonly="file_status == 'approve'"/>
                        </group>
                        <field name="maintenance_history_ids" nolabel="1" readonly="file_status == 'approve'">
                            <list decoration-info="invoice_created == True">
                                <field name="installment_number" string="Sr. No"/>
                                <field name="double_check_paid_amount" invisible="1"/>
                                <field name="date"/>
                                <field name="payment_date" string="Payment date" readonly="1"/>
                                <field name="amount" sum="Total"/>
                                <field name="invoice_created" invisible="1"/>
                                <field name="invoice_id" string="Invoice" invisible="0"/>
                                <field name="state" string="Invoice Status" invisible="1"/>
                                <field name="amount_paid" sum="Amount Paid" readonly="1"/>
                                <field name="residual" sum="Remaining Amount" readonly="1"/>
                                <field name="payment_status" string="Status"/>
                            </list>
                        </field>
                    </group>
                </xpath>
                <xpath expr="//field[@name='merger_ref']" position="after">
                    <field name="service_charge" force_save="1"/>
                    <field name="assumption" force_save="1" invisible="1"/>
                    <field name="exemption" force_save="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>