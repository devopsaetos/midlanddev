<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_hide_bill_report" model="ir.ui.view">
        <field name="name">account.move.form.hide.bill.report</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@id='account_invoice_payment_btn']" position="after">
                <button name="%(western_custom_reports.action_report_invoice_report_custom)d"
                        string="Print"
                        type="action"
                        class="btn btn-secondary"
                        groups="account.group_account_invoice"
                        invisible="state != 'posted' or move_type not in ('out_invoice', 'out_refund')"
                        data-hotkey="p"/>

                <!--                <button name="%(western_custom_reports.action_report_invoice_custom)d"-->
                <!--                        string="Print"-->
                <!--                        type="action"-->
                <!--                        class="btn btn-secondary"-->
                <!--                        groups="account.group_account_invoice"-->
                <!--                        invisible="state != 'posted' or move_type not in ('in_invoice', 'in_refund')"-->
                <!--                        data-hotkey="p"/>-->
            </xpath>
        </field>
    </record>


    <record id="view_move_form_inherit_custom_print" model="ir.ui.view">
        <field name="name">account.move.form.inherit.custom.print</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_print_pdf']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//button[@id='account_invoice_payment_btn']" position="after">
                <button name="%(western_custom_reports.action_report_invoice_custom)d"
                        string="Print"
                        type="action"
                        class="btn-primary"
                        groups="account.group_account_invoice"
                        invisible="state != 'posted' or move_type not in ('in_invoice', 'in_refund')"
                        data-hotkey="p"/>
            </xpath>
        </field>
    </record>
</odoo>
