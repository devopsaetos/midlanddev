<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paper Format (unchanged) -->
    <record id="paperformat_general_items" model="report.paperformat">
        <field name="name">General Items Custom A4</field>
        <field name="format">A4</field>
        <field name="default" eval="False"/>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">6</field>
        <field name="margin_right">6</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action (unchanged) -->
    <record id="action_report_general_items" model="ir.actions.report">
        <field name="name">PDF General Items</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">western_custom_reports.general_items_pdf</field>
        <field name="report_file">western_custom_reports.general_items</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">(object.name or 'General Items')</field>
        <field name="paperformat_id" ref="western_custom_reports.paperformat_general_items"/>
        <field name="domain">[('move_type', 'in', ['in_invoice', 'in_refund'])]</field>
    </record>

    <!-- Updated Template – removed discount, taxes, amount -->
    <template id="general_items_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">

                        <!-- CSS – removed .tc for taxes/discount where possible -->
                        <style type="text/css">
                            .page { font-family: Arial, Helvetica, sans-serif; font-size: 9.5pt; color: #1a1a1a;
                            line-height: 1.4; }
                            .hdr-wrap { width: 100%; margin-bottom: 12px; overflow: hidden; }
                            .hdr-left { float: left; width: 70%; }
                            .hdr-right { float: right; width: 100px; text-align: right; }
                            .hdr-clear { clear: both; height: 0; font-size: 0; line-height: 0; }
                            .co-name { font-weight: bold; font-size: 11pt; line-height: 1.3; margin-bottom: 4px; }
                            .co-info { font-size: 8.5pt; line-height: 1.5; color: #333; }
                            .co-info a { color: #0066cc; text-decoration: underline; }
                            .strip-transno { font-size: 9.5pt; font-weight: bold; }
                            .strip-title { font-size: 18pt; font-weight: bold; text-align: center; color: #1a1a1a; }
                            .strip-date { font-size: 9.5pt; font-weight: bold; text-align: right; }
                            .addr-outer { width: 100%; margin-bottom: 14px; overflow: hidden; }
                            .addr-header-td { background-color: #4682B4; color: #ffffff; font-weight: bold; font-size:
                            9.5pt; padding: 6px 12px; border-radius: 3px 3px 0 0; }
                            .addr-body-td { padding: 8px 12px; background: #ffffff; border-radius: 0 0 3px 3px; }
                            .addr-rows div { padding: 2px 0; font-size: 8.5pt; line-height: 1.45; }
                            .addr-lbl { width: 70px; color: #555; white-space: nowrap; font-weight: 500; display:
                            inline-block; margin-right: 8px; }
                            .info-tbl, .line-tbl { width: 100%; border-collapse: collapse; margin-bottom: 12px;
                            font-size: 8.5pt; }
                            .info-tbl th, .line-tbl th { background-color: #4682B4; color: #fff; font-weight: bold;
                            padding: 6px 8px; border: 1px solid #000; text-align: center; }
                            .info-tbl td, .line-tbl td { padding: 6px 8px; border: 1px solid #000; background: #fff;
                            vertical-align: top; }
                            .line-tbl td.tl { text-align: left; }
                            .line-tbl td.tr { text-align: right; }
                            .line-tbl tr.alt-row td { background-color: #f5f9fd; }
                            .line-tbl tr.tot-row td { font-weight: bold; border-top: 2px solid #000; background: #fff; }
                            .tot-wrap { width: 100%; margin-top: 12px; }
                            .tot-right { width: 35%; float: right; font-size: 9.5pt; }
                            .tot-row { padding: 5px 0; overflow: hidden; }
                            .tot-lbl { float: left; width: 60%; text-align: right; padding-right: 12px; font-weight:
                            bold; color: #333; }
                            .tot-val { float: right; width: 38%; text-align: right; font-weight: bold; color: #000; }
                            .tot-clear { clear: both; height: 0; font-size: 0; line-height: 0; }
                        </style>

                        <!-- Header (unchanged) -->
                        <div class="hdr-wrap">
                            <div class="hdr-left">
                                <span class="co-name">
                                    <t t-esc="o.company_id.name or 'Company Name'"/>
                                </span>
                                <div class="co-info">
                                    <t t-if="o.company_id.street">
                                        <t t-esc="o.company_id.street"/>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.street2">
                                        <t t-esc="o.company_id.street2"/>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.city">
                                        <t t-esc="o.company_id.city"/>
                                    </t>
                                    <t t-if="o.company_id.state_id">,
                                        <t t-esc="o.company_id.state_id.name"/>
                                    </t>
                                    <t t-if="o.company_id.zip">
                                        <t t-esc="o.company_id.zip"/>
                                    </t>
                                    <br/>
                                    <t t-if="o.company_id.country_id">
                                        <t t-esc="o.company_id.country_id.name"/>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.email">
                                        <a t-att-href="'mailto:' + o.company_id.email" t-esc="o.company_id.email"/>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.website">
                                        <a t-att-href="o.company_id.website" t-esc="o.company_id.website"/>
                                        <br/>
                                    </t>
                                </div>
                            </div>
                            <div class="hdr-right">
                                <div class="logo-box">
                                    <t t-if="o.company_id.logo">
                                        <img t-att-src="image_data_uri(o.company_id.logo)"
                                             style="max-height:60px; max-width:100%;"/>
                                    </t>
                                    <t t-else="">
                                        <span class="logo-line1">-□X-</span>
                                        <span class="logo-line2">wts</span>
                                    </t>
                                </div>
                            </div>
                            <div class="hdr-clear"></div>
                        </div>

                        <!-- Transaction Strip (unchanged) -->
                        <div style="margin-bottom:12px;">
                            <div style="display:table; width:100%; table-layout:fixed; border-bottom:2px solid #000; padding-bottom:6px;">
                                <div style="display:table-row;">
                                    <div style="display:table-cell; width:30%; vertical-align:middle;">
                                        <span class="strip-transno">Transaction No :
                                            <t t-esc="o.name or 'INVXXXX'"/>
                                        </span>
                                    </div>
                                    <div style="display:table-cell; width:40%; text-align:center; vertical-align:middle;">
                                        <span class="strip-title">GENERAL ITEMS</span>
                                    </div>
                                    <div style="display:table-cell; width:30%; text-align:right; vertical-align:middle;">
                                        <span class="strip-date">Date :
                                            <t t-esc="o.invoice_date.strftime('%m/%d/%Y') if o.invoice_date else 'N/A'"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Addresses (unchanged) -->
                        <div class="addr-outer">
                            <div style="width:48%; float:left;">
                                <div class="addr-header-td">Bill to Vendor</div>
                                <div class="addr-body-td">
                                    <div class="addr-rows">
                                        <div>
                                            <span class="addr-lbl">Name</span>
                                            <t t-esc="o.partner_id.name"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">Address</span>
                                            <t t-esc="o.partner_id.street or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">City</span>
                                            <t t-esc="o.partner_id.city or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">State</span>
                                            <t t-esc="o.partner_id.state_id.name or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">Country</span>
                                            <t t-esc="o.partner_id.country_id.name or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">Phone</span>
                                            <t t-esc="o.partner_id.phone or ''"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div style="width:4%; float:left;"> </div>
                            <div style="width:48%; float:left;">
                                <div class="addr-header-td">Ship to Party</div>
                                <div class="addr-body-td">
                                    <div class="addr-rows">
                                        <div>
                                            <span class="addr-lbl">Name</span>
                                            <t t-esc="o.company_id.name or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">Address</span>
                                            <t t-esc="o.company_id.street or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">City</span>
                                            <t t-esc="o.company_id.city or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">State</span>
                                            <t t-esc="o.company_id.state_id.name or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">Country</span>
                                            <t t-esc="o.company_id.country_id.name or ''"/>
                                        </div>
                                        <div>
                                            <span class="addr-lbl">Phone</span>
                                            <t t-esc="o.company_id.phone or ''"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div style="clear:both;"></div>
                        </div>

                        <!-- Info Table (removed Incoterms & Taxes related if any) -->
                        <table class="info-tbl">
                            <tr>
                                <th>Vendor #</th>
                                <th>Payment Terms</th>
                                <th>Currency</th>
                            </tr>
                            <tr>
                                <td>
                                    <t t-esc="o.partner_id.name"/>
                                </td>
                                <td>
                                    <t t-esc="o.invoice_payment_term_id.name or 'N/A'"/>
                                </td>
                                <td>
                                    <t t-esc="o.currency_id.name"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Main Lines Table – only Account, Label, Debit, Credit, Balance -->
                        <table class="line-tbl">
                            <thead>
                                <tr>
                                    <th style="width:18%;">Account</th>
                                    <th style="width:50%;">Label</th>
                                    <th style="width:14%;">Debit</th>
                                    <th style="width:14%;">Credit</th>
                                    <th style="width:14%;">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="row_num" t-value="0"/>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <t t-set="row_num" t-value="row_num + 1"/>
                                    <tr t-att-class="'alt-row' if row_num % 2 == 0 else ''">
                                        <td class="tl">
                                            <t t-esc="line.account_id.code or ''"/>
                                            -
                                            <t t-esc="line.account_id.name or ''"/>
                                        </td>
                                        <td class="tl">
                                            <t t-esc="line.name or ''"/>
                                        </td>
                                        <td class="tr">
                                            <t t-esc="'%.2f' % line.debit"/>
                                        </td>
                                        <td class="tr">
                                            <t t-esc="'%.2f' % line.credit"/>
                                        </td>
                                        <td class="tr">
                                            <t t-esc="'%.2f' % line.balance"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr class="tot-row">
                                    <td colspan="2" style="text-align:right; font-weight:bold;">Total</td>
                                    <td class="tr" style="font-weight:bold;">
                                        <t t-esc="'%.2f' % sum(line.debit for line in o.line_ids)"/>
                                    </td>
                                    <td class="tr" style="font-weight:bold;">
                                        <t t-esc="'%.2f' % sum(line.credit for line in o.line_ids)"/>
                                    </td>
                                    <td class="tr" style="font-weight:bold;">
                                        <t t-esc="'%.2f' % o.amount_total"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Simplified Totals (right side) -->
                        <div class="tot-wrap">
                            <div class="tot-right">
                                <div class="tot-row">
                                    <span class="tot-lbl">Total Debit</span>
                                    <span class="tot-val">
                                        <t t-esc="'%.2f' % sum(line.debit for line in o.line_ids)"/>
                                    </span>
                                    <div class="tot-clear"></div>
                                </div>
                                <div class="tot-row">
                                    <span class="tot-lbl">Total Credit</span>
                                    <span class="tot-val">
                                        <t t-esc="'%.2f' % sum(line.credit for line in o.line_ids)"/>
                                    </span>
                                    <div class="tot-clear"></div>
                                </div>
                                <div class="tot-row">
                                    <span class="tot-lbl">Total Balance</span>
                                    <span class="tot-val">
                                        <t t-esc="'%.2f' % (sum(line.debit for line in o.line_ids) - sum(line.credit for line in o.line_ids))"/>
                                    </span>
                                    <div class="tot-clear"></div>
                                </div>
                            </div>
                            <div class="tot-clear"></div>
                        </div>

                        <!-- Notes (unchanged) -->
                        <div style="margin-top:10px; padding-top:10px; clear:both;">
                            <span style="font-weight:bold; font-size:14pt; color:#1a1a1a; display:block; margin-bottom:5px;">
                                Notes:
                            </span>
                            <p style="font-weight:bold; font-size:10.5pt; color:#333; line-height:1.4; margin:0;">
                                Invoices shall be rendered on completion of services or delivery of goods and shall
                                contain the Purchase Order Number, item number, description of goods or services,
                                quantities, unit prices, date(s) rendered and total purchase price. Each invoice must
                                refer to one, and only one, purchase order.
                            </p>
                        </div>

                        <!-- Footer -->
                        <div class="footer">
                            <div style="text-align:right; font-size:10px;">
                                Page
                                <span class="page"/>
                                of
                                <span class="topage"/>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>