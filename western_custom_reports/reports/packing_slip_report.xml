<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="purchase_custom_pdf">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <div class="page">

                            <style type="text/css">
                                .page { font-family: Arial, Helvetica, sans-serif; font-size: 9.5pt; color: #1a1a1a;
                                line-height: 1.4; }
                                .hdr-wrap { width: 100%; margin-bottom: 12px; overflow: hidden; }
                                .hdr-left { float: left; width: 50%; }
                                .hdr-right { float: right; width: 48%; text-align: right; }
                                .hdr-clear { clear: both; height: 0; font-size: 0; line-height: 0; }
                                .co-name { font-weight: bold; font-size: 11pt; line-height: 1.3; margin-bottom: 4px; }
                                .co-info { font-size: 8.5pt; line-height: 1.5; color: #333; }
                                .co-info a { color: #0066cc; text-decoration: underline; }
                                .logo-box { text-align: right; margin-top: 10px; }
                                .logo-box img { max-height: 100px; max-width: 250px; width: auto; height: auto; display: inline-block; }
                                .logo-box-text { text-align: right; }
                                .logo-box-text .lb-name { color: #1a1a1a; font-size: 11pt; font-weight: bold; display: block; margin-top: 8px; line-height: 1.3; }
                                .logo-box-text .lb-addr { color: #333; font-size: 7.5pt; display: block; line-height: 1.5; margin-top: 3px; }
                                .logo-box-text .lb-email { color: #0066cc; font-size: 7.5pt; display: block; text-decoration: underline; }
                                .strip-transno { font-size: 9.5pt; font-weight: bold; }
                                .strip-title { font-size: 18pt; font-weight: bold; text-align: center; color: #1a1a1a; }
                                .strip-date { font-size: 9.5pt; font-weight: bold; text-align: right; }
                                .addr-outer { width: 100%; margin-bottom: 14px; overflow: hidden; }
                                .addr-header-td { background-color: #4682B4; color: #ffffff; font-weight: bold; font-size: 9.5pt; padding: 6px 12px; border-radius: 3px 3px 0 0; }
                                .addr-body-td { padding: 8px 12px; background: #ffffff; border-radius: 0 0 3px 3px; }
                                .addr-rows div { padding: 2px 0; font-size: 8.5pt; line-height: 1.45; }
                                .addr-lbl { width: 70px; color: #555; white-space: nowrap; font-weight: 500; display: inline-block; margin-right: 8px; }
                                .info-tbl { width: 100%; border-collapse: collapse; margin-bottom: 0px; font-size: 8.5pt; }
                                .line-tbl { width: 100%; border-collapse: collapse; margin-bottom: 12px; font-size: 8.5pt; margin-top: -1px; }
                                .info-tbl th, .line-tbl th { background-color: #4682B4; color: #fff; font-weight: bold; padding: 6px 8px; border: 1px solid #000; }
                                .info-tbl td { padding: 6px 8px; border: 1px solid #000; border-bottom: 0px; text-align: center; background: #fff; vertical-align: top; }
                                .line-tbl td { padding: 6px 8px; border: 1px solid #000; text-align: center; background: #fff; vertical-align: top; }
                                .line-tbl .td-t { font-weight: bold; border-top: 1px solid #000; }
                                .tot-row { overflow: hidden; padding: 1px 0; font-size: 9pt; }
                                .tot-row .t-lbl { float: left; width: 55%; color: #000; }
                                .tot-row .t-val { float: left; width: 45%; text-align: right; color: #000; }
                                .tot-row-grand { overflow: hidden; padding: 4px 0; font-size: 10pt; font-weight: bold; border-top: 0px solid #000; margin-top: 3px; }
                                .tot-row-grand .t-lbl { float: left; width: 55%; color: #000; }
                                .tot-row-grand .t-val { float: left; width: 45%; text-align: right; color: #000; }
                                .notes-section { margin-top: 16px; padding-top: 10px; clear: both; }
                            </style>

                            <!-- ===== HEADER ===== -->
                            <div class="hdr-wrap">
                                <div class="hdr-left">
                                    <span class="co-name">
                                        <t t-esc="o.company_id.name or 'Company Name'"/>
                                    </span>
                                    <div class="co-info">
                                        <t t-if="o.company_id.street">
                                            <t t-esc="o.company_id.street"/><br/>
                                        </t>
                                        <t t-if="o.company_id.street2">
                                            <t t-esc="o.company_id.street2"/><br/>
                                        </t>
                                        <t t-if="o.company_id.city">
                                            <t t-esc="o.company_id.city"/>
                                        </t>
                                        <t t-if="o.company_id.state_id">,
                                            <t t-esc="o.company_id.state_id.name"/>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <t t-esc="o.company_id.zip"/>
                                        </t>
                                        <br/>
                                        <t t-if="o.company_id.country_id">
                                            <t t-esc="o.company_id.country_id.name"/><br/>
                                        </t>
                                        <t t-if="o.company_id.email">
                                            <a t-att-href="'mailto:' + o.company_id.email" t-esc="o.company_id.email"/><br/>
                                        </t>
                                        <t t-if="o.company_id.website">
                                            <a t-att-href="o.company_id.website" t-esc="o.company_id.website"/><br/>
                                        </t>
                                    </div>
                                </div>
                                <div class="hdr-right">
                                    <div class="logo-box">
                                        <t t-if="o.company_id.logo">
                                            <img t-att-src="image_data_uri(o.company_id.logo)"
                                                 style="max-height:120px; max-width:220px; width:auto; height:auto;"/>
                                        </t>
                                        <t t-else="">
                                            <div class="logo-box-text">
                                                <span class="lb-name">
                                                    <t t-esc="o.company_id.name or ''"/>
                                                </span>
                                                <span class="lb-addr">
                                                    <t t-if="o.company_id.street">
                                                        <t t-esc="o.company_id.street"/><br/>
                                                    </t>
                                                    <t t-if="o.company_id.street2">
                                                        <t t-esc="o.company_id.street2"/><br/>
                                                    </t>
                                                    <t t-if="o.company_id.city">
                                                        <t t-esc="o.company_id.city"/>
                                                    </t>
                                                    <t t-if="o.company_id.state_id">,
                                                        <t t-esc="o.company_id.state_id.name"/>
                                                    </t>
                                                    <t t-if="o.company_id.zip">
                                                        <t t-esc="o.company_id.zip"/>
                                                    </t>
                                                    <br/>
                                                    <t t-if="o.company_id.country_id">
                                                        <t t-esc="o.company_id.country_id.name"/>
                                                    </t>
                                                </span>
                                                <t t-if="o.company_id.email">
                                                    <a t-att-href="'mailto:' + o.company_id.email" class="lb-email">
                                                        <t t-esc="o.company_id.email"/>
                                                    </a>
                                                </t>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <div class="hdr-clear"></div>
                            </div>

                            <!-- ===== TRANSACTION STRIP ===== -->
                            <div style="margin-bottom:12px;">
                                <div style="display:table; width:100%; table-layout:fixed; border-bottom:2px solid #000; padding-bottom:6px;">
                                    <div style="display:table-row;">
                                        <div style="display:table-cell; width:30%; vertical-align:middle;">
                                            <span class="strip-transno">Transaction No :
                                                <t t-esc="o.name"/>
                                            </span>
                                        </div>
                                        <div style="display:table-cell; width:40%; text-align:center; vertical-align:middle;">
                                            <span class="strip-title">
                                                <t t-if="o.state in ['draft', 'sent']">REQUEST FOR QUOTATION</t>
                                                <t t-else="">PURCHASE ORDER</t>
                                            </span>
                                        </div>
                                        <div style="display:table-cell; width:30%; text-align:right; vertical-align:middle;">
                                            <span class="strip-date">Date :
                                                <t t-esc="o.date_order.strftime('%m/%d/%Y') if o.date_order else ''"/>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ===== ADDRESSES ===== -->
                            <div class="addr-outer">

                                <!-- BILL TO VENDOR -->
                                <div style="width:48%; float:left;">
                                    <div class="addr-header-td">Bill to Vendor</div>
                                    <div class="addr-body-td">
                                        <div class="addr-rows">
                                            <div>
                                                <span class="addr-lbl">Name</span>
                                                <!-- Company name (not contact person) -->
                                                <t t-esc="o.partner_id.commercial_partner_id.name or o.partner_id.name or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">Attention</span>
                                                <!-- Contact person name if different from company -->
                                                <t t-if="o.partner_id.parent_id">
                                                    <t t-esc="o.partner_id.name or ''"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="o.partner_id.name or ''"/>
                                                </t>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">Address</span>
                                                <!-- Address from commercial partner if contact has no address -->
                                                <t t-esc="(o.partner_id.street or o.partner_id.commercial_partner_id.street) or ''"/>
                                                <t t-if="o.partner_id.street2">,
                                                    <t t-esc="o.partner_id.street2"/>
                                                </t>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">City</span>
                                                <t t-esc="(o.partner_id.city or o.partner_id.commercial_partner_id.city) or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">State</span>
                                                <t t-esc="(o.partner_id.state_id.name or o.partner_id.commercial_partner_id.state_id.name) or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">ZIP</span>
                                                <t t-esc="(o.partner_id.zip or o.partner_id.commercial_partner_id.zip) or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">Country</span>
                                                <t t-esc="(o.partner_id.country_id.name or o.partner_id.commercial_partner_id.country_id.name) or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">Phone</span>
                                                <t t-esc="(o.partner_id.phone or o.partner_id.commercial_partner_id.phone) or ''"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div style="width:4%; float:left;">&#160;</div>

                                <!-- SHIP TO PARTY (Our Company) -->
                                <div style="width:48%; float:left;">
                                    <div class="addr-header-td">Ship to Party</div>
                                    <div class="addr-body-td">
                                        <div class="addr-rows">
                                            <div>
                                                <span class="addr-lbl">Name</span>
                                                <t t-esc="o.company_id.name or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">Address</span>
                                                <t t-esc="o.company_id.street or ''"/>
                                                <t t-if="o.company_id.street2">,
                                                    <t t-esc="o.company_id.street2"/>
                                                </t>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">City</span>
                                                <t t-esc="o.company_id.city or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">State</span>
                                                <t t-esc="o.company_id.state_id.name or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">ZIP</span>
                                                <t t-esc="o.company_id.zip or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">Country</span>
                                                <t t-esc="o.company_id.country_id.name or ''"/>
                                            </div>
                                            <div>
                                                <span class="addr-lbl">Phone</span>
                                                <t t-esc="o.company_id.phone or ''"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div style="clear:both;"></div>
                            </div>

                            <!-- ===== INFO TABLE ===== -->
                            <table class="info-tbl">
                                <thead>
                                    <tr>
                                        <th>Receive By</th>
                                        <th>Vendor #</th>
                                        <th>Payment Terms</th>
                                        <th>Currency</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><t t-esc="o.date_planned.strftime('%m/%d/%Y') if o.date_planned else ''"/></td>
                                        <td><t t-esc="o.partner_ref or ''"/></td>
                                        <td><t t-esc="o.payment_term_id.name or ''"/></td>
                                        <td><t t-esc="o.currency_id.name or ''"/></td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- ===== LINE ITEMS ===== -->
                            <table class="line-tbl">
                                <thead>
                                    <tr>
                                        <th style="width:5%;">No</th>
                                        <th style="width:15%;">Item</th>
                                        <th style="width:45%;">Description</th>
                                        <th style="width:10%;">Qty</th>
                                        <th style="width:10%;">Price</th>
                                        <th style="width:15%;">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.order_line" t-as="line">
                                        <t t-if="line.display_type == 'line_section'">
                                            <tr>
                                                <td colspan="6" style="background:#ffffff; font-weight:bold; font-size:9.5pt; padding:6px 8px; border:1px solid #000; text-align:left; border-top:1px solid #4682B4;">
                                                    <t t-esc="line.name"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-elif="line.display_type == 'line_note'">
                                            <tr>
                                                <td colspan="6" style="font-style:italic; font-size:8.5pt; color:#555; padding:5px 8px; border:1px solid #000; text-align:left; background:#ffffff;">
                                                    <t t-esc="line.name"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-else="">
                                            <tr>
                                                <td><t t-esc="line_index + 1"/></td>
                                                <td><t t-esc="line.product_id.default_code or ''"/></td>
                                                <td style="text-align:left;">
                                                    <t t-esc="line.name or line.product_id.name or ''"/>
                                                </td>
                                                <td><t t-esc="'{:,.0f}'.format(line.product_qty)"/></td>
                                                <td><t t-esc="'{:,.2f}'.format(line.price_unit)"/></td>
                                                <td><t t-esc="'{:,.2f}'.format(line.price_subtotal)"/></td>
                                            </tr>
                                        </t>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td class="td-t" colspan="4"></td>
                                        <td class="td-t" style="text-align:right; font-weight:bold;">Total</td>
                                        <td class="td-t">
                                            <t t-esc="'{:,.2f}'.format(o.amount_untaxed)"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>

                            <!-- ===== TOTALS — TAX FIX: compute from line.price_tax ===== -->
                            <t t-set="computed_tax" t-value="sum(
                                line.price_tax
                                for line in o.order_line
                                if not line.display_type
                            )"/>

                            <div style="width:100%; overflow:hidden;">
                                <table style="width:35%; float:right; border: 1px solid #000; border-top: 0px; border-collapse: collapse; font-size: 9pt; background-color: #fff; margin-top: 0px;">
                                    <tr>
                                        <td style="padding: 6px 10px; border: none !important;">
                                            <b>Subtotal</b>
                                        </td>
                                        <td style="padding: 6px 10px; border: none !important; text-align: right;">
                                            <t t-esc="'{0:,.2f}'.format(o.amount_untaxed)"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px 10px; border: none !important;">
                                            <b>Tax Amount</b>
                                        </td>
                                        <td style="padding: 6px 10px; border: none !important; text-align: right;">
                                            <t t-esc="'{0:,.2f}'.format(computed_tax)"/>
                                        </td>
                                    </tr>
                                    <tr style="background-color: #f9f9f9; border-top: 1px solid #000;">
                                        <td style="padding: 8px 10px; border: none !important; font-size: 10pt;">
                                            <b>Total <t t-esc="o.currency_id.name"/></b>
                                        </td>
                                        <td style="padding: 8px 10px; border: none !important; font-size: 10pt; text-align: right;">
                                            <b><t t-esc="'{0:,.2f}'.format(o.amount_untaxed + computed_tax)"/></b>
                                        </td>
                                    </tr>
                                </table>
                                <div style="clear:both;"/>
                            </div>

                            <!-- ===== TERMS AND CONDITIONS ===== -->
                            <t t-if="o.note">
                                <div style="margin-top:20px; margin-bottom:10px;">
                                    <div style="font-weight:bold; font-size:10pt; margin-bottom:4px;">Terms &amp; Conditions</div>
                                    <div style="font-size:8.5pt; line-height:1.6; color:#1a1a1a;">
                                        <t t-out="o.note"/>
                                    </div>
                                </div>
                            </t>

                            <!-- ===== FOOTER ===== -->
                            <div class="footer" style="width:100%; border-top:1px solid #ccc; padding-top:5px; margin-top:20px; font-size:10pt; color:#555;">
                                <div style="float:left;">Company Reg.No</div>
                                <div style="float:right; font-style:italic;">Page
                                    <span class="page"/> of <span class="topage"/>
                                </div>
                                <div style="clear:both;"></div>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="paperformat_custom_purchase" model="report.paperformat">
            <field name="name">Custom Purchase Order A4</field>
            <field name="format">A4</field>
            <field name="default" eval="False"/>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <record id="purchase.report_purchase_quotation" model="ir.actions.report">
            <field name="report_name">western_custom_reports.purchase_custom_pdf</field>
            <field name="paperformat_id" ref="western_custom_reports.paperformat_custom_purchase"/>
        </record>

        <record id="purchase.action_report_purchase_order" model="ir.actions.report">
            <field name="report_name">western_custom_reports.purchase_custom_pdf</field>
            <field name="paperformat_id" ref="western_custom_reports.paperformat_custom_purchase"/>
        </record>

    </data>
</odoo>