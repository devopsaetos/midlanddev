<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="invoice_custom_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <style type="text/css">
                            .page { font-family: Arial, Helvetica, sans-serif; font-size: 9.5pt; color: #1a1a1a; line-height: 1.4; }
                            .hdr-wrap { width: 100%; margin-bottom: 12px; overflow: hidden; }
                            .hdr-left { float: left; width: 70%; }
                            .hdr-right { float: right; width: 100px; text-align: right; }
                            .hdr-clear { clear: both; height: 0; font-size: 0; line-height: 0; }
                            .co-name { font-weight: bold; font-size: 11pt; line-height: 1.3; margin-bottom: 4px; }
                            .co-info { font-size: 8.5pt; line-height: 1.5; color: #333; }
                            .co-info a { color: #0066cc; text-decoration: underline; }
                            .logo-line1 { color: #fff; font-size: 9pt; font-weight: bold; display: block; margin-top: 8px; }
                            .logo-line2 { color: #fff; font-size: 14pt; font-weight: bold; letter-spacing: 4px; display: block; margin-top: 2px; }
                            .strip-transno { font-size: 9.5pt; font-weight: bold; }
                            .strip-title { font-size: 18pt; font-weight: bold; text-align: center; color: #1a1a1a; }
                            .strip-date { font-size: 9.5pt; font-weight: bold; text-align: right; }
                            .addr-outer { width: 100%; margin-bottom: 14px; overflow: hidden; }
                            .addr-header-td { background-color: #4682B4; color: #ffffff; font-weight: bold; font-size: 9.5pt; padding: 6px 12px; border-radius: 3px 3px 0 0; }
                            .addr-body-td { padding: 8px 12px; background: #ffffff; border-radius: 0 0 3px 3px; }
                            .addr-rows div { padding: 2px 0; font-size: 8.5pt; line-height: 1.45; }
                            .addr-lbl { width: 70px; color: #555; white-space: nowrap; font-weight: 500; display: inline-block; margin-right: 8px; }
                            .info-tbl, .line-tbl { width: 100%; border-collapse: collapse; margin-bottom: 12px; font-size: 8.5pt; }
                            .info-tbl th, .line-tbl th { background-color: #4682B4; color: #fff; font-weight: bold; padding: 6px 8px; border: 1px solid #000; text-align: center; }
                            .info-tbl td, .line-tbl td { padding: 6px 8px; border: 1px solid #000; background: #fff; vertical-align: top; text-align: center; }
                            .line-tbl td.tl { text-align: left; }
                            .line-tbl td.tr { text-align: right; }
                            .line-tbl td.tc { text-align: center; }
                            .line-tbl tr.alt-row td { background-color: #f5f9fd; }
                            .line-tbl tr.tot-row td { font-weight: bold; border-top: 2px solid #000; background: #fff; }
                            /* Totals */
                            .tot-wrap { width: 100%; margin-top: 12px; }
                            .tot-right { width: 45%; float: right; font-size: 9pt; }
                            .tot-row { padding: 4px 0; overflow: hidden; }
                            .tot-lbl { float: left; width: 58%; text-align: right; padding-right: 10px; font-weight: bold; color: #333; }
                            .tot-val { float: right; width: 40%; text-align: right; white-space: nowrap; font-weight: bold; color: #000; }
                            .tot-clear { clear: both; height: 0; font-size: 0; line-height: 0; }
                        </style>

                        <!-- HEADER -->
                        <div class="hdr-wrap">
                            <div class="hdr-left">
                                <span class="co-name"><t t-esc="o.company_id.name or 'Company Name'"/></span>
                                <div class="co-info">
                                    <t t-if="o.company_id.street"><t t-esc="o.company_id.street"/><br/></t>
                                    <t t-if="o.company_id.street2"><t t-esc="o.company_id.street2"/><br/></t>
                                    <t t-if="o.company_id.city"><t t-esc="o.company_id.city"/></t>
                                    <t t-if="o.company_id.state_id">, <t t-esc="o.company_id.state_id.name"/></t>
                                    <t t-if="o.company_id.zip"> <t t-esc="o.company_id.zip"/></t><br/>
                                    <t t-if="o.company_id.country_id"><t t-esc="o.company_id.country_id.name"/><br/></t>
                                    <t t-if="o.company_id.email"><a t-att-href="'mailto:' + o.company_id.email" t-esc="o.company_id.email"/><br/></t>
                                    <t t-if="o.company_id.website"><a t-att-href="o.company_id.website" t-esc="o.company_id.website"/><br/></t>
                                </div>
                            </div>
                            <div class="hdr-right">
                                <div class="logo-box">
                                    <t t-if="o.company_id.logo">
                                        <img t-att-src="image_data_uri(o.company_id.logo)" style="max-height:60px; max-width:100%;"/>
                                    </t>
                                    <t t-else="">
                                        <span class="logo-line1">-□X-</span>
                                        <span class="logo-line2">wts</span>
                                    </t>
                                </div>
                            </div>
                            <div class="hdr-clear"></div>
                        </div>

                        <!-- Transaction Strip -->
                        <div style="margin-bottom:12px;">
                            <div style="display:table; width:100%; table-layout:fixed; border-bottom:2px solid #000; padding-bottom:6px;">
                                <div style="display:table-row;">
                                    <div style="display:table-cell; width:30%; vertical-align:middle;">
                                        <span class="strip-transno">Transaction No : <t t-esc="o.name or 'INVXXXX'"/></span>
                                    </div>
                                    <div style="display:table-cell; width:40%; text-align:center; vertical-align:middle;">
                                        <span class="strip-title">VENDOR BILL</span>
                                    </div>
                                    <div style="display:table-cell; width:30%; text-align:right; vertical-align:middle;">
                                        <span class="strip-date">Date : <t t-esc="o.invoice_date.strftime('%m/%d/%Y') if o.invoice_date else 'N/A'"/></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ADDRESSES -->
                        <div class="addr-outer">
                            <div style="width:48%; float:left;">
                                <div class="addr-header-td">Bill to Vendor</div>
                                <div class="addr-body-td">
                                    <div class="addr-rows">
                                        <div><span class="addr-lbl">Name</span><t t-esc="o.partner_id.name"/></div>
                                        <div><span class="addr-lbl">Address</span><t t-esc="o.partner_id.street or ''"/></div>
                                        <div><span class="addr-lbl">City</span><t t-esc="o.partner_id.city or ''"/></div>
                                        <div><span class="addr-lbl">State</span><t t-esc="o.partner_id.state_id.name or ''"/></div>
                                        <div><span class="addr-lbl">Country</span><t t-esc="o.partner_id.country_id.name or ''"/></div>
                                        <div><span class="addr-lbl">Phone</span><t t-esc="o.partner_id.phone or ''"/></div>
                                    </div>
                                </div>
                            </div>
                            <div style="width:4%; float:left;">&#160;</div>
                            <div style="width:48%; float:left;">
                                <div class="addr-header-td">Ship to Party</div>
                                <div class="addr-body-td">
                                    <div class="addr-rows">
                                        <div><span class="addr-lbl">Name</span><t t-esc="o.company_id.name or ''"/></div>
                                        <div><span class="addr-lbl">Address</span><t t-esc="o.company_id.street or ''"/></div>
                                        <div><span class="addr-lbl">City</span><t t-esc="o.company_id.city or ''"/></div>
                                        <div><span class="addr-lbl">State</span><t t-esc="o.company_id.state_id.name or ''"/></div>
                                        <div><span class="addr-lbl">Country</span><t t-esc="o.company_id.country_id.name or ''"/></div>
                                        <div><span class="addr-lbl">Phone</span><t t-esc="o.company_id.phone or ''"/></div>
                                    </div>
                                </div>
                            </div>
                            <div style="clear:both;"></div>
                        </div>

                        <!-- Info Table -->
                        <table class="info-tbl">
                            <tr>
                                <th>Vendor #</th>
                                <th>Payment Terms</th>
                                <th>Incoterms</th>
                                <th>Currency</th>
                            </tr>
                            <tr>
                                <td><t t-esc="o.partner_id.name"/></td>
                                <td><t t-esc="o.invoice_payment_term_id.name or 'N/A'"/></td>
                                <td></td>
                                <td><t t-esc="o.currency_id.name"/></td>
                            </tr>
                        </table>

                        <!-- LINE ITEMS TABLE -->
                        <table class="line-tbl">
                            <thead>
                                <tr>
                                    <th style="width:4%;">No</th>
                                    <th style="width:11%;">Item</th>
                                    <th style="width:35%;">Description</th>
                                    <th style="width:7%;">Qty</th>
                                    <th style="width:10%;">Price</th>
                                    <th style="width:13%;">Tax</th>
                                    <th style="width:14%;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="row_num" t-value="0"/>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <t t-if="line.display_type == 'product'">
                                        <t t-set="row_num" t-value="row_num + 1"/>
                                        <tr t-att-class="'alt-row' if row_num % 2 == 0 else ''">
                                            <td class="tc"><t t-esc="row_num"/></td>
                                            <td class="tl"><t t-esc="line.product_id.default_code or ''"/></td>
                                            <td class="tl"><t t-esc="line.name or ''"/></td>
                                            <td class="tc"><t t-esc="'%.2f' % line.quantity"/></td>
                                            <td class="tr"><t t-esc="'%.2f' % line.price_unit"/></td>
                                            <td class="tc"><t t-esc="', '.join(t.name for t in line.tax_ids) if line.tax_ids else ''"/></td>
                                            <td class="tr"><t t-esc="'%.2f' % line.price_subtotal"/></td>
                                        </tr>
                                    </t>
                                </t>
                                <!-- Total row -->
                                <tr class="tot-row">
                                    <td colspan="3" style="text-align:right; font-weight:bold;">Total Qty</td>
                                    <td class="tc" style="font-weight:bold;">
                                        <t t-esc="'%.2f' % sum(line.quantity for line in o.line_ids if line.display_type == 'product')"/>
                                    </td>
                                    <td style="text-align:right; font-weight:bold;" colspan="2">Total</td>
                                    <td class="tr" style="font-weight:bold;"><t t-esc="'%.2f' % o.amount_untaxed"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- TOTALS BLOCK -->
                        <div class="tot-wrap">
                            <div class="tot-right">
                                <div class="tot-row">
                                    <span class="tot-lbl">Subtotal</span>
                                    <span class="tot-val"><t t-esc="'%.2f' % o.amount_untaxed"/></span>
                                    <div class="tot-clear"></div>
                                </div>
                                <div class="tot-row">
                                    <span class="tot-lbl">Tax Amount</span>
                                    <span class="tot-val"><t t-esc="'%.2f' % o.amount_tax"/></span>
                                    <div class="tot-clear"></div>
                                </div>
<!--                                <div class="tot-row">-->
<!--                                    <span class="tot-lbl">Amount Due</span>-->
<!--                                    <span class="tot-val"><t t-esc="'%.2f' % o.amount_residual"/></span>-->
<!--                                    <div class="tot-clear"></div>-->
<!--                                </div>-->
                            </div>
                            <div class="tot-clear"></div>

<!--                             Grand Total + Amount in Words – same row, no box-->
                            <div style="width:100%; border-top:0px solid #000; margin-top:6px; padding-top:5px; overflow:hidden;">
<!--                                <div style="float:left; width:52%; padding-top:1px;">-->
<!--                                    <span style="font-size:8pt; font-weight:bold; color:#333;">Amount in Words: </span>-->
<!--                                    <span style="font-size:8pt; font-style:italic; color:#1a1a1a;">-->
<!--                                        <t t-esc="o.currency_id.amount_to_text(o.amount_total)"/>-->
<!--                                    </span>-->
<!--                                </div>-->
                                <div style="float:right; width:36%;">
                                    <span style="float:left; width:55%; text-align:right; padding-right:10px; font-weight:bold; font-size:10pt; color:#333;">Total US Dollar</span>
                                    <span style="float:right; width:43%; text-align:right; font-weight:bold; font-size:10pt; color:#000; white-space:nowrap;">
                                        <t t-esc="'%.2f' % o.amount_total"/>
                                    </span>
                                    <div style="clear:both;"> </div>
                                </div>
                                <div style="clear:both;"> </div>
                            </div>
                        </div>

                    </div>

                    <!-- Notes Section -->
<!--                    <div style="margin-top:10px; padding-top:10px; clear:both;">-->
<!--                        <span style="font-weight:bold; font-size:14pt; color:#1a1a1a; display:block; margin-bottom:5px;">Notes:</span>-->
<!--                        <p style="font-weight:bold; font-size:10.5pt; color:#333; line-height:1.4; margin:0;">-->
<!--                            Invoices shall be rendered on completion of services or delivery of goods and shall contain-->
<!--                            the Purchase Order Number, item number, description of goods or services, quantities, unit-->
<!--                            prices, date(s) rendered and total purchase price. Each invoice must refer to one, and only-->
<!--                            one, purchase order.-->
<!--                        </p>-->
<!--                    </div>-->

                    <!-- Footer -->
                    <div class="footer">
                        <div style="text-align:right; font-size:10px;">
                            Page <span class="page"/> of <span class="topage"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="paperformat_custom_invoice" model="report.paperformat">
        <field name="name">Custom Invoice A4</field>
        <field name="format">A4</field>
        <field name="default" eval="False"/>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">6</field>
        <field name="margin_right">6</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_invoice_custom" model="ir.actions.report">
        <field name="name">PDF Custom Vendor Bill</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">western_custom_reports.invoice_custom_pdf</field>
        <field name="report_file">western_custom_reports.invoice</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="domain">[['move_type', 'in', ['in_invoice', 'in_refund']]]</field>
        <field name="print_report_name">(object.name or 'Invoice')</field>
        <field name="paperformat_id" ref="western_custom_reports.paperformat_custom_invoice"/>
    </record>
</odoo>