<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="file_financials.investment_rebate_request_form">
            <field name="name">file_financials_report.investment_rebate_request_form</field>
            <field name="model">investment.rebate.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar"/>
                        <button string="Validate" name="validate" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" nolabel="1" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="deal_closure" required="1"/>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                            <group>
                                <field name="investor_id"/>
                                <field name="investment_id"/>
                            </group>
                            <field name="request_line_ids" nolabel="1" create="false">
                                <list editable="bottom">
                                    <field name="select"/>
                                    <field name="investment_rebate_line_id" readonly="1" invisible="1"/>
                                    <field name="agent_type" readonly="1"/>
                                    <field name="transaction_type" readonly="1"/>
                                    <field name="investor_id" readonly="1"/>
                                    <field name="investment_id" readonly="1"/>
                                    <field name="calculated_rebate" readonly="1" sum="Total"/>
                                    <field name="settlement_option" required=""/>
                                    <field name="actual_amount" sum="Total"/>
                                    <field name="move_id" readonly="1" force_save="1" string="Entry #"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <!--        Tree View-->
        <record model="ir.ui.view" id="file_financials.investment_rebate_request_tree">
            <field name="name">file_financials.investment_rebate_request_tree</field>
            <field name="model">investment.rebate.request</field>
            <field name="arch" type="xml">
                <list create="false" edit="false" delete="false">
                    <field name="name"/>
                    <field name="deal_closure"/>
                    <field name="create_date"/>
                    <field name="create_uid"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record model="ir.actions.act_window" id="file_financials.action_investment_rebate_request">
            <field name="name">Rebate Request</field>
            <field name="res_model">investment.rebate.request</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem
                name="Rebate Settlement"
                id="file_financials.investment_rebate_request_menu_item"
                parent="file_financials.rebate_menu_item"
                action="file_financials.action_investment_rebate_request"
        />
        <record id="rebate_request_sequence" model="ir.sequence">
            <field name="name">Rebate Request Sequence</field>
            <field name="code">rebate.request.sequence</field>
            <field name="prefix">RBT-</field>
            <field name="padding">6</field>
        </record>
    </data>
</odoo>