<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="file_financials.owner_mobile_numbers_form_view">
            <field name="name">file_financials.owner_mobile_numbers_form_view</field>
            <field name="model">owner.mobile</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" force_save="1"/>
                                <field name="company_id" force_save="1" readonly="1"/>
                            </group>
                            <group>
                                <field name="number" force_save="1" placeholder='+923001234567' widget="mask" data-inputmask="'mask': '+99-999-9999999'"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record model="ir.ui.view" id="file_financials.owner_mobile_numbers_tree_view">
            <field name="name">file_financials.owner_mobile_numbers_tree_view</field>
            <field name="model">investment.platter</field>
            <field name="arch" type="xml">
                <list delete="false">
                    <field name="name"/>
                    <field name="number"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>
        <record model="ir.actions.act_window" id="file_financials.owner_mobile_numbers_action">
            <field name="name">Owners Mobile</field>
            <field name="res_model">owner.mobile</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new Number.
                </p>
            </field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('file_financials.owner_mobile_numbers_tree_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('file_financials.owner_mobile_numbers_form_view')})]"
            />
        </record>
<!--        <menuitem-->
<!--                name="Owners Mobile"-->
<!--                id="file_financials.owner_mobile_numbers_menu_item"-->
<!--                parent="real_estate.menu_price_plan"-->
<!--                action="file_financials.owner_mobile_numbers_action"/>-->
    </data>
</odoo>
