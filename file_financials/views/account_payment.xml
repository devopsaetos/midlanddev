<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="file_financials.view_account_payment_form">
            <field name="name">file_financials.view_account_payment_form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="real_estate.view_account_payment_form"/>
            <field name="arch" type="xml">
<!--                <xpath expr="//button[@name='button_journal_entries']" position="before">-->
<!--                    <button class="oe_stat_button" name="open_installment_wizard" string="Generate Invoices" type="object"-->
<!--                            invisible="state != 'draft' or payment_type != 'inbound'" icon="fa-bars"/>-->
<!--                </xpath>-->
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="is_sub_investor_payment"
                           readonly="state != 'draft'"
                    />
                </xpath>
                <xpath expr="//field[@name='journal_id']" position="before">
                    <field name="sub_investor_id"
                           domain="[('investor_type', '=', 'sub_dealer'), ('main_investor_id', '=', partner_id)]"
                           invisible="not is_sub_investor_payment" readonly="state != 'draft'" required="is_sub_investor_payment"
                           options="{'no_create': True, 'no_edit': True, 'no_open': True}"
                    />
                </xpath>
                <xpath expr="//field[@name='investment_id']" position="before">
                    <field name="payment_nature" invisible="1"/>
                    <field name="advance_payment_id" invisible="1"/>
                    <field name="category_id" invisible="1"/>
                </xpath>
<!--                <xpath expr="//field[@name='communication']" position="before">-->
<!--                    <field name="invoice_creation_quantity"-->
<!--                           invisible="not is_advance_payment or payment_type != 'inbound'"-->
