<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="file_financials.dealer_rebate_form">
            <field name="name">file_financials.dealer_rebate_form</field>
            <field name="model">dealer.rebate</field>
            <field name="arch" type="xml">
                <form duplicate="false">
                    <header>
                        <button name="set_to_active" type="object" string="Active" class="oe_highlight"
                                invisible="state == 'active'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <field name="name" invisible="0"/>
                        </div>
                        <group>
                            <field name="policy_name"
                                   placeholder="Policy"
                                   required="1"
                                   readonly="state == 'active'"/>
                            <group>
                                <field name="effective_from" required="1"
                                       readonly="state == 'active'"/>
                            </group>
                            <group>
                                <field name="effective_to" readonly="state == 'active'"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="rebate_lines" string="Rebate Details">
                                <field name="rebate_line_ids" readonly="state == 'active'">
                                    <list editable="bottom">
                                        <field name="sector_id" string="Block" invisible="1"/>
                                        <field name="category_id" invisible="1"/>
                                        <field name="agent_type"/>
                                        <field name="transaction_type"/>
                                        <field name="settlement_option"/>
                                        <field name="calculation_basis"/>
                                        <field name="rate_calculation" invisible="1"/>
                                        <field name="total_rebate" sum="Total" string="Rebate"/>
                                        <field name="rebate_at_deal" invisible="1"/>
                                        <field name="rebate_at_sale" invisible="1"/>
                                        <field name="rebate_given" readonly="1" force_save="1" invisible="1"/>
                                        <field name="move_id" readonly="1" force_save="1" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page name="other_info" string="Other Info">
                                <group name="company_detail" string="Company Info">
                                    <group>
                                        <field name="company_id"/>
                                    </group>
                                    <group>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="file_financials.dealer_rebate_tree">
            <field name="name">file_financials rebate_tree</field>
            <field name="model">dealer.rebate</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="policy_name"/>
                    <field name="effective_from"/>
                    <field name="effective_to"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="file_financials.rebate_search">
            <field name="name">file_financials rebate_search</field>
            <field name="model">dealer.rebate</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="effective_from"/>
                    <field name="effective_to"/>
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="file_financials.action_investment_rebate_policy">
            <field name="name">Rebate Policy</field>
            <field name="res_model">dealer.rebate</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click On Create To Add Dealer Rebate Policy
                </p>
            </field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('file_financials.dealer_rebate_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('file_financials.dealer_rebate_form')})]"
            />
        </record>

        <menuitem
                id="file_financials.menu_rebate_policy"
                name="Rebate Policy"
                parent="file_financials.rebate_menu_item"
                action="file_financials.action_investment_rebate_policy"
        />
    </data>
</odoo>