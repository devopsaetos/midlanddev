<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="file_financials.investment_platter_form_view">
            <field name="name">file_financials.investment_platter_form_view</field>
            <field name="model">investment.platter</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" default_focus="1" placeholder="Name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="number" readonly="1" force_save="1"/>
                                <field name="investment_category_id" force_save="1" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="society_id"
                                       domain="[('project_type','=','housing_society'),('is_society','=',True)]"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="phase_id"
                                       domain="[('project_type','=','housing_society'),('is_society','!=',True)]"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="company_id" force_save="1" readonly="1"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page string="Details">
                                <field name="platter_line_ids">
                                    <list editable="bottom" class="tree_styles">
                                        <field name="sector_id"
                                               domain="[('project_type','=','housing_society')]"
                                               options="{'no_create': True, 'no_open': True}"/>
                                        <field name="street_id" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="category_id" domain="[('project_type','=','housing_society')]"
                                               readonly="inventory_id" required="not inventory_id"
                                               options="{'no_create': True, 'no_open': True}"/>
                                        <field name="unit_category_type_id" string="Product"
                                               readonly="inventory_id" required="not inventory_id"
                                               domain="[('project_type','=','housing_society')]"
                                               options="{'no_create': True, 'no_open': True}"/>
                                        <field name="size_id" readonly="inventory_id"
                                               domain="[('project_type','=','housing_society')]"
                                               options="{'no_create': True, 'no_open': True}"/>
                                        <field name="inventory_id" force_save="1" invisible="1"/>
                                        <field name="no_of_units"/>
                                        <field name="list_price" readonly="0" invisible="1"/>
                                        <field name="price_list_id" force_save="1" invisible="1"/>
                                        <field name="investor_price" force_save="1"/>
                                        <field name="deal_price" sum="Total"/>
                                        <field name="own_plan" invisible="1" force_save="1"/>
                                        <field name="predefine_plan_id"/>
                                        <field name="booking_value" sum="Total"/>
                                        <field name="confirmation_value" sum="Total"/>
                                        <field name="posession_value" invisible="1" force_save="1" sum="Total"/>
                                        <field name="balloting_value" invisible="1" force_save="1" sum="Total"/>
                                        <field name="final_value" invisible="1" force_save="1" sum="Total"/>
                                        <field name="company_id" invisible="1" force_save="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record model="ir.ui.view" id="file_financials.investment_platter_tree_view">
            <field name="name">file_financials.investment_platter_tree_view</field>
            <field name="model">investment.platter</field>
            <field name="arch" type="xml">
                <list delete="false">
                    <field name="number"/>
                    <field name="name"/>
                    <field name="investment_category_id"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>
        <record model="ir.actions.act_window" id="file_financials.action_investment_platter">
            <field name="name">Investment Platter</field>
            <field name="res_model">investment.platter</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new Platter.
                </p>
            </field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('file_financials.investment_platter_tree_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('file_financials.investment_platter_form_view')})]"
            />
        </record>
        <menuitem
                name="Platter"
                id="file_financials.investment_platter_menu_item"
                parent="real_estate.menu_price_plan"
                action="file_financials.action_investment_platter"/>
        <record id="investment_platter_sequence" model="ir.sequence">
            <field name="name">Investment Platter Sequence</field>
            <field name="code">investment.platter.sequence</field>
            <field name="prefix">IPT-</field>
            <field name="padding">6</field>
        </record>
    </data>
</odoo>
