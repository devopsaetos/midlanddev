<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="file_financials.investment_category_form_view">
            <field name="name">file_financials.investment_category_form_view</field>
            <field name="model">investment.category</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" default_focus="1" placeholder="Category Name .."/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="minimum_amount"/>
                                <field name="maximum_amount"/>
                            </group>
                            <group>
                                <field name="company_id" readonly="1" force_save="1"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record model="ir.ui.view" id="file_financials.investment_category_tree_view">
            <field name="name">file_financials.investment_category_tree_view</field>
            <field name="model">investment.category</field>
            <field name="arch" type="xml">
                <list delete="false">
                    <field name="name"/>
                    <field name="minimum_amount"/>
                    <field name="maximum_amount"/>
                </list>
            </field>
        </record>
        <record model="ir.actions.act_window" id="file_financials.action_investment_category">
            <field name="name">Investment Category</field>
            <field name="res_model">investment.category</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new Investment Category.
                </p>
            </field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('file_financials.investment_category_tree_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('file_financials.investment_category_form_view')})]"
            />
        </record>
        <menuitem
                name="Investment Categories"
                id="file_financials.investment_category_menu_item"
                parent="file_financials.configuration_menu_item"
                action="file_financials.action_investment_category"
                sequence='2'/>
    </data>
</odoo>
