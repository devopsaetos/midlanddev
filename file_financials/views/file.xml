<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
<!--        <record model="ir.ui.view" id="file_financials.allotment_file_form_view_ext">-->
<!--        <field name="name">file_financials.allotment_file_form_view_ext</field>-->
