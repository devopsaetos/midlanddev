<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--        Tree View-->
        <record model="ir.ui.view" id="file_financials.sub_dealer_inventory_management_tree_view">
            <field name="name">file_financials.sub_dealer_inventory_management_tree_view</field>
            <field name="model">subdealer.inventory.management</field>
            <field name="arch" type="xml">
                <list delete="false">
                    <field name="name"/>
                    <field name="transaction_type"/>
                    <field name="date"/>
                    <field name="investor_id"/>
                    <field name="main_investor_id"/>
                    <field name="investment_id"/>
                    <field name="create_uid"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        <!--        Form View-->
        <record model="ir.ui.view" id="file_financials.sub_dealer_inventory_management_form_view">
            <field name="name">file_financials.sub_dealer_inventory_management_form_view</field>
            <field name="model">subdealer.inventory.management</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form delete="false">
                    <header>
                        <field name="state" widget="statusbar"/>
                        <button string="Send for Approval" name="in_approval" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button string="Reset to Draft" name="draft" type="object" class="btn-primary" invisible="state != 'in_approval'"/>
                        <button string="Approve" name="approve_request" type="object" class="btn-primary" invisible="state != 'in_approval'"/>
                        <button string="Process" name="process_request" type="object" class="btn-primary" invisible="state != 'approved'"/>
                        <button string="Cancel" name="cancel" type="object" class="btn-primary" invisible="state not in ['draft', 'in_approval']"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" nolabel="1" readonly="1" force_save="1"/>
                            </h1>
                        </div>
                        <group readonly="state != 'draft'">
                            <group>
                                <field name="investor_id" required="1" force_save="1" options="{'no_create_edit': True, 'no_open': True}"/>
                                <field name="main_investor_id" required="1" readonly="1" force_save="1" options="{'no_create_edit': True, 'no_open': True}"/>
                                <field name="category_ids" required="1" force_save="1" options="{'no_create_edit': True, 'no_open': True}" widget="many2many_tags"/>
                                <field name="transaction_type" required="1" force_save="1"/>
                                <field name="request_platform" required="1" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="date" required="1" force_save="1"/>
                                <field name="investment_id" required="1" force_save="1" domain="[('partner_id', '=', main_investor_id), ('state', 'not in', ['draft', 'closed', 'cancel'])]"
                                       options="{'no_create_edit': True, 'no_open': True}"/>
                                <field name="unit_category_type_ids" required="1" force_save="1" options="{'no_create_edit': True, 'no_open': True}" widget="many2many_tags"/>
                                <field name="company_id" required="1" readonly="1" force_save="1" options="{'no_create_edit': True, 'no_open': True}"/>
                            </group>
                            <field name="investor_file_ids" required="1" nolabel="1" force_save="1"
                                   options="{'no_create_edit': True, 'no_open': True}">
                                <list editable="top">
                                    <field name="name"/>
                                    <field name="booking_date"/>
                                    <field name="category_id" string="Category"/>
                                    <field name="unit_category_type_id" string="Product"/>
                                    <field name="inventory_id"/>
                                    <field name="sector_id"/>
                                    <field name="phase_id"/>
                                    <field name="society_id"/>
                                    <field name="payment_type"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="file_financials.sub_dealer_inventory_management_action_id">
            <field name="name">Sub Dealer Inventory</field>
            <field name="res_model">subdealer.inventory.management</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_request_platform': 'system'}</field>
        </record>
        <menuitem
                id="file_financials.sub_dealer_management_menu_item"
                name="Sub Dealer Management"
                parent="file_financials.process_menu_item"
                sequence="8"
        />
        <menuitem
                name="Sub Dealer Inventory"
                id="file_financials.sub_dealer_inventory_management_menu"
                parent="file_financials.sub_dealer_management_menu_item"
                action="file_financials.sub_dealer_inventory_management_action_id"
        />
        <record id="sub_dealer_inventory_management_sequence" model="ir.sequence">
            <field name="name">Sub Dealer Inventory Management Sequence</field>
            <field name="code">subdealer.inventory.management.sequence</field>
            <field name="prefix">SD-INV-MGT-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>