<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequences for File Tracking Number -->
        <record id="seq_building_file_tracking_number" model="ir.sequence">
            <field name="name">File Tracking Number for Building</field>
            <field name="code">file.tracking.building</field>
            <field name="prefix"></field>
            <field name="padding">7</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_skyscraper_file_number" model="ir.sequence">
            <field name="name">File Number (Skyscraper)</field>
            <field name="code">file.skyscraper</field>
            <field name="prefix">BLD-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>