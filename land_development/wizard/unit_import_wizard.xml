<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_unit_import_wizard_form" model="ir.ui.view">
            <field name="name">land.development.unit.import.form</field>
            <field name="model">land.development.unit.import</field>
            <field name="arch" type="xml">
                <form string="Import Units">
                    <p>
                        Upload an Excel file exported from the Unit list (Serial Number column is
                        used to match each row to its unit). Unit Number, Net Area, Balcony Area,
                        Total Area (sft), Actual Area, State and Possession Status will be updated.
                    </p>
                    <group>
                        <field name="filename" invisible="1"/>
                        <field name="file" filename="filename"/>
                    </group>
                    <footer>
                        <button string="Import" name="action_import" type="object" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_unit_import_wizard" model="ir.actions.act_window">
            <field name="name">Import Units</field>
            <field name="res_model">land.development.unit.import</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_unit_import_wizard"
                  name="Import Units"
                  action="action_unit_import_wizard"
                  parent="land_development.menu_unit_inventory"
                  sequence="3"/>

        <record id="action_export_units_xlsx" model="ir.actions.server">
            <field name="name">Export Units to Excel</field>
            <field name="model_id" ref="real_estate.model_plot_inventory"/>
            <field name="binding_model_id" ref="real_estate.model_plot_inventory"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">action = records.action_export_units_xlsx()</field>
        </record>

    </data>
</odoo>
