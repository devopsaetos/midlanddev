        <record model="ir.ui.view" id="land_development.block_tree">
            <field name="name">land_development block_tree</field>
            <field name="model">society</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" string="Name"/>
                    <field name="code"/>
                    <field name="location_id" invisible="1"/>
                    <field name="city_id"/>
                    <field name="authority_id"/>
                    <field name="society_id" string="Project"/>
                    <field name="partner_id"/>
                </list>
            </field>
        </record>

        <!-- Society -->
        <record model="ir.actions.act_window" id="land_development.action_society">
            <field name="name">Project</field>
            <field name="res_model">society</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add an New Project.
              </p><p>
                The main system you want to implement for Building Management System.
              </p>
            </field>
            <field name="domain">
                [
                    ('is_society','=',1),
                    ('project_type','in',['skyscraper', False])
                ]
            </field>
            <field name="context">
                {
                    'default_is_society':1,
                    'default_project_type':'skyscraper',
                    'current_view': 'building'
                }
            </field>
            <field name="view_mode">list,form</field>
<!--            <field name="search_view_id" ref="land_development.building_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('real_estate.society_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.building_form')}),
            ]"
            />
        </record>

        <record model="ir.actions.act_window" id="land_development.action_phase">
            <field name="name">Building</field>
            <field name="res_model">society</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add an New Building.
              </p><p>
                The Building will be created in context with the parent Project.
              </p>
            </field>
            <field name="domain">
                [
                    ('is_society','!=',1),
                    ('project_type','in',['skyscraper', False])
                ]
            </field>
            <field name="context">
                {
                    'default_is_society':0,
                    'search_default_building':1,
                    'default_project_type':'skyscraper',
                    'current_view': 'building'
                }
            </field>
            <field name="view_mode">list,form</field>
<!--            <field name="search_view_id" ref="land_development.building_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.block_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.building_form')}),
                ]"
            />
        </record>

        <menuitem
            id="land_development.society"
            name="Project"
            parent="land_development.menu_society"
            action="land_development.action_society"
            sequence='2'
        />

        <menuitem
            id="land_development.society_phase"
            name="Building"
            parent="land_development.menu_society"
            action="land_development.action_phase"
            sequence='3'
        />
    </data>
</odoo>
