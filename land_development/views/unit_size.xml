<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.ui.view" id="land_development.unit_size_form">
            <field name="name">land_development unit_size_form</field>
            <field name="model">unit.size</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_type" invisible="1"/>
                                <field name="name"/>
                                <field name="standard_area" string="Total Area (sft)"
                                       groups="real_estate.group_unit_size_in_specific"/>
                                <field name="from_area" groups="real_estate.group_unit_size_in_range"/>
                            </group>
                            <group>
                                <field name="code"/>
                                <field name="to_area" groups="real_estate.group_unit_size_in_range"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="land_development.unit_size_tree">
            <field name="name">land_development unit_size_tree</field>
            <field name="model">unit.size</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="standard_area" string="Total Area (sft)"/>
                </list>
            </field>
        </record>

        <!--        <record model="ir.ui.view" id="land_development.unit_size_search">-->
        <!--            <field name="name">land_development unit_size_search</field>-->
        <!--            <field name="model">unit.size</field>-->
        <!--            <field name="priority">2</field>-->
        <!--            <field name="arch" type="xml">-->
        <!--                <search>-->
        <!--                    <field name="name"/>-->
        <!--                    <field name="code"/>-->
        <!--                    <field name="standard_area" string="Total Area (sft)"/>-->
        <!--                </search>-->
        <!--            </field>-->
        <!--        </record>-->

        <record model="ir.actions.act_window" id="land_development.action_unit_size">
            <field name="name">Size</field>
            <field name="res_model">unit.size</field>

            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add an Size of Unit.
                </p>
            </field>
            <field name="view_mode">list,form</field>
            <field name="domain">
                [
                ('project_type','in',['skyscraper', False])
                ]
            </field>
            <!--            <field name="search_view_id" ref="land_development.unit_size_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.unit_size_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.unit_size_form')}),
            ]"
            />
            <field name="context">{'current_view': 'building', 'default_project_type':'skyscraper'}</field>
        </record>

        <menuitem
                id="land_development.unit_size"
                name="Size"
                parent="land_development.menu_inventory"
                action="land_development.action_unit_size"
                sequence='3'
        />

    </data>
</odoo>