        <record model="ir.actions.act_window" id="land_development.action_plot_inventory">
            <field name="name">Unit</field>
            <field name="res_model">plot.inventory</field>

            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Here Unit Inventory will show, Which you will create from Inventory Creation wizard.
                </p>
            </field>
            <field name="domain">
                [
                ('project_type','in',['skyscraper', False])
                ]
            </field>
            <field name="view_mode">list,form</field>
            <!--            <field name="search_view_id" ref="land_development.plot_inventory_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.plot_inventory_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.plot_inventory_form')}),
            ]"
            />
            <field name="context">{'current_view': 'building', 'default_project_type':'skyscraper'}</field>
        </record>

        <menuitem
                id="land_development.plot_inventory"
                name="Unit"
                parent="land_development.menu_unit_inventory"
                action="land_development.action_plot_inventory"
                sequence='2'
        />

    </data>
