        <record model="ir.actions.act_window" id="land_development.action_sector">
            <field name="name">Floors</field>
            <field name="res_model">sector</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add an New Floor.
              </p><p>
                The Floor will be created in context with the Blocks and Buildings.
              </p>
            </field>
            <field name="domain">
                [
                    ('project_type','in',['skyscraper', False])
                ]
            </field>
<!--            <field name="search_view_id" ref="land_development.sector_search"/>-->
            <field name="context">
                {
                    'search_default_group_by_society_id': 1,
                    'search_default_group_by_phase_id': 1,
                    'default_project_type':'skyscraper',
                    'current_view': 'building'
                }
            </field>
            <field name="view_mode">list,form</field>
<!--            <field name="search_view_id" ref="land_development.sector_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.sector_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.sector_form')}),
                ]"
            />
        </record>

        <menuitem
            id="land_development.sector"
            name="Floors"
            action="land_development.action_sector"
            parent="land_development.menu_society"
            sequence="4"
        />

    </data>
