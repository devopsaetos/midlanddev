    <record model="ir.actions.act_window" id="land_development.action_investment">
            <field name="name">Investment</field>
            <field name="res_model">investment</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click create to add Investment data.
              </p>
            </field>
            <field name="domain">
                [
                    ('project_type','in',['skyscraper', False])
                ]
            </field>
            <field name="context">{ 'current_view': 'building', 'default_project_type':'skyscraper'}</field>
            <field name="view_mode">list,form</field>
<!--            <field name="search_view_id" ref="land_development.investment_view_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.investment_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.investment_view_form')}),
                ]"
            />
        </record>

    <menuitem
            id="land_development.investment_menu"
            name="Investment"
            action="land_development.action_investment"
            sequence="2"
            parent="land_development.menu_investment_parent"
    />


</odoo>
