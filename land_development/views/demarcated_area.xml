<odoo>
    <data>

        <record model="ir.ui.view" id="land_development.demarcated_area_form">
            <field name="name">land_development demarcated_area_form</field>
            <field name="model">demarcated.area</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <field name="project_type" invisible='1'/>
                            <h1>
                                <field name="inventory_id" default_focus="1" placeholder="Name" options="{'no_create': True, 'no_open': True}"/>
                            </h1>
                        </div>
                        <group>
                            <group string = "Survey Detail">
                                <field name="checker_id" options="{'no_create': True}"/>
                                <field name="surveyor_id" options="{'no_create': True}"/>
                                <field name="user_id" options="{'no_create': True}"/>
                            </group>
                            <group string = "Area Detail">
                                <field name="total_area"/>
                                <field name="actual_area"/>
                                <field name="access_short"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page string="Dimensions" autofocus="autofocus">
                                <field name="dimension_line">
                                    <list editable="bottom">
                                        <field name="dimension"/>
                                        <field name="name"/>
                                        <field name="value"/>
                                        <field name="bounded_by"/>
                                        <field name="cardinal"/>
                                    </list>
                                </field>
                            </page>
                            <page name="plot_map" string="Unit Map" autofocus="autofocus">
                                <field name="plot_image" widget='image' string='Unit Image'/>
                            </page>
                        </notebook>
                    </sheet>
                    
<!--                    <div class="oe_chatter">-->
<!--                        <field name="message_follower_ids" widget="mail_followers"/>-->
<!--                        <field name="activity_ids" widget="mail_activity"/>-->
<!--                        <field name="message_ids" widget="mail_thread"/>-->
<!--                    </div>-->
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="land_development.action_demarcated_area">
            <field name="name">Demarcated Area</field>
            <field name="res_model">demarcated.area</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add Demarcation of Units.
              </p>
            </field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="real_estate.demarcated_area_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('real_estate.demarcated_area_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.demarcated_area_form')}),
                ]"
            />
            <field name="context">{'current_view': 'building', 'default_project_type':'skyscraper'}</field>
            <field name="domain">
                [
                    ('project_type','in',['skyscraper', False])
                ]
            </field>
        </record>

        <menuitem
            id="land_development.demarcated_area"
            name="Demarcated Area"
            parent="land_development.menu_inventory"
            action="land_development.action_demarcated_area"
            sequence='7'
        />
    </data>
</odoo>
