<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="land_development.unit_swapping_request_form" model="ir.ui.view">
            <field name="name">land_development unit_swapping_request_form</field>
            <field name="model">unit.swapping.request</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <form create="false" edit="true">
                    <header>
                        <button name="approve_request"
                                type="object"
                                class="oe_highlight"
                                string="Approve"
                                groups="real_estate.group_approve_transfer_req"
                                invisible="state != 'draft'"/>
                        <button name="request_cancel"
                                type="object"
                                class="oe_highlight"
                                string="Cancel"
                                groups="real_estate.group_approve_transfer_req"
                                invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button
                                    name="open_invoice"
                                    type="object"
                                    class="oe_stat_button"
                                    string="Invoice"
                                    icon="fa-pencil-square-o"
                                    invisible="invoice_created != True">
                            </button>
                            <button
                                    name="generate_invoice"
                                    type="object"
                                    class="oe_stat_button"
                                    string="Generate Invoice"
                                    icon="fa-pencil-square-o"
                                    invisible="apply_charges == 'no' or invoice_created == True">
                            </button>
                        </div>
                        <div class="oe_title oe_state_size">
                            <h1>
                                <field name="name" readonly="1"/>
                                <field name="project_type" invisible="1"/>
                                <field name="invoice_created" invisible="1"/>
                            </h1>
                        </div>
                        <group>
                            <field name="applicable_on" readonly="1"/>
                            <field name="transaction_type" readonly="1"/>
                            <field name="appointment_date" required="1" readonly="state != 'draft'"/>

                        </group>
                        <group string="Member Details " invisible="applicable_on != 'file'">
                            <group>
                                <field name="membership_id"/>
                            </group>
                        </group>
                        <group string="Property Detail " invisible="applicable_on != 'file'">
                            <group>
                                <field name="file_id" readonly="1"/>
                                <field name="society_id" string="Project" readonly="state != 'draft'"/>
                                <field name="phase_id" string="Building" readonly="state != 'draft'"/>
                                <field name="sector_id" string="Floor" readonly="state != 'draft'"/>
                                <field name="inventory_id" string="Unit" readonly="state != 'draft'"/>
                                <field name="unit_number" string="Unit No." readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="tracking_id"/>
                                <field name="category_id" string="Category" readonly="state != 'draft'"/>
                                <field name="unit_category_type_id" string="Product" readonly="state != 'draft'"/>
                                <field name="size_id" readonly="state != 'draft'"/>
                                <field name="unit_class_id" string="Type" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group string="New Property Detail " invisible="applicable_on != 'file'">
                            <group>
                                <field name="new_inventory_id" string="New Unit"
                                       domain="[('state','=','avalible_for_sale'),
                                                ('project_type','in',['skyscraper', False])]"
                                       required="transaction_type == 'swap'"
                                       invisible="transaction_type != 'swap'"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="new_society_id" string="Project"/>
                                <field name="new_phase_id" string="Building"/>
                                <field name="new_sector_id" string="Floor"/>
                            </group>
                            <group>
                                <field name="new_category_id" string="Category"/>
                                <field name="new_unit_category_type_id" string="Product"/>
                                <field name="new_size_id"/>
                                <field name="new_unit_class_id" string="Type"/>
                                <field name="change_price" readonly="state != 'draft'"/>
                                <field name="amount" required="change_price == 'yes'"
                                       invisible="change_price != 'yes'"/>
                                <field name="apply_charges" readonly="state != 'draft'"/>
                                <field name="charges_amount" required="apply_charges == 'yes'"
                                       invisible="apply_charges != 'yes'"/>
                            </group>
                        </group>
                        <group name="unit_details" string="Unit Details" invisible="applicable_on != 'file'">
                            <group>
                                <field name="booking_date"/>
                                <field name="starting_date"/>
                                <field name="payment_states"/>
                                <field name="interval_id"/>
                            </group>
                            <group>
                                <field name="net_sale_amount"/>
                                <field name="ttl_sale_amount"/>
                                <field name="initial_payment"/>
                                <field name="plan_description"/>
                            </group>
                        </group>
                        <group string="Customer Detail"
                               invisible="applicable_on != 'investment' or transaction_type != 'open_file'">
                            <group>
                                <field widget="mask" data-inputmask="'mask': '99999-9999999-9'"
                                       name="transferee_cnic_number" required="transaction_type == 'open_file'"
                                       readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <button
                                        name="search_member"
                                        icon="fa-arrow-right"
                                        type="object"
                                        string="Search Member"
                                        class="btn-link"
                                        invisible="state != 'draft'"
                                />
                            </group>
                            <group>
                                <field name="is_transferee_partner" invisible="1" readonly="state != 'draft'"/>
                                <field name="transferee_partner_id"
                                       invisible="1"
                                       readonly="is_transferee_partner == True"
                                       context="{
                                        'form_view_ref': 'real_estate.view_partner_form',
                                        'default_is_member' : 1
                                    }"
                                />
                                <field name="transferee_name" string="Name" readonly="is_transferee_partner == True"/>
                                <field name="transferee_company_type" string="Member Type"
                                       readonly="is_transferee_partner == True"/>
                                <field name="transferee_mobile"
                                       placeholder="+92-300-2321443"
                                       widget="mask" data-inputmask="'mask': '+99-999-9999999'"
                                       readonly="is_transferee_partner == True"/>
                                <field name="transferee_email" readonly="is_transferee_partner == True"/>
                                <field name="transferee_gender" readonly="is_transferee_partner == True"/>
                            </group>
                            <group>
                                <field name="transferee_relation_name" string="Father/Spouse "
                                       readonly="state != 'draft' or is_transferee_partner == True"/>
                            </group>
                            <group name='primary_address' string="Primary Address">
                                <!-- All address fields are Inherited field except city_id -->
                                <label for="transferee_street" string="Address"/>
                                <div class="o_address_format">
                                    <field
                                            name="transferee_street"
                                            placeholder="Street..."
                                            class="o_address_street"
                                            required='0'
                                            readonly="state != 'draft' or is_transferee_partner == True"/>

                                    <field
                                            name="transferee_street2"
                                            placeholder="Street 2..."
                                            class="o_address_street"
                                            readonly="state != 'draft' or is_transferee_partner == True"/>

                                    <field
                                            name="transferee_city_id"
                                            placeholder="City"
                                            class="o_address_city"
                                            required='0'
                                            options='{"no_open": True}'
                                            readonly="state != 'draft' or is_transferee_partner == True"/>

                                    <field
                                            name="transferee_state_id"
                                            string="Province"
                                            class="o_address_state"
                                            placeholder="State"
                                            options='{"no_open": True}'
                                            readonly="state != 'draft' or is_transferee_partner == True"/>

                                    <field
                                            name="transferee_zip"
                                            placeholder="ZIP"
                                            class="o_address_zip"
                                            readonly="state != 'draft' or is_transferee_partner == True"/>

                                    <field
                                            name="transferee_country_id"
                                            placeholder="Country"
                                            class="o_address_country"
                                            options='{"no_open": True, "no_create": True}'
                                            readonly="state != 'draft' or is_transferee_partner == True"/>
                                </div>
                            </group>
                            <group string="Next Of Kin">
                                <field name="kin_name" readonly="is_transferee_partner == True"/>
                                <field name="kin_mobile"
                                       placeholder="+92-300-2321443"
                                       widget="mask" data-inputmask="'mask': '+99-999-9999999'"
                                       readonly="is_transferee_partner == True"/>
                                <field name="kin_cnic"
                                       widget="mask" data-inputmask="'mask': '99999-9999999-9'"
                                       readonly="is_transferee_partner == True"/>
                                <field name="kin_member_relation"
                                       readonly="is_transferee_partner == True"/>
                                <field name="other_relation"
                                       invisible="kin_member_relation != 'other'"
                                       required="kin_member_relation == 'other'"
                                       readonly="is_transferee_partner == True"/>
                            </group>
                        </group>
                        <group name="investment_details" string="Investment Details"
                               invisible="applicable_on != 'investment'">
                            <group>
                                <field name="investment_id" readonly="1"/>

                            </group>
                            <group>
                                <field name="investor_id"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page string="Details" autofocus="autofocus" invisible="applicable_on != 'investment'">
                                <field name="unit_swapping_request_lines" readonly="1">
                                    <list create="false" delete="false">
                                        <field name="check"/>
                                        <field name="transaction_type"/>
                                        <field name="investment_id" readonly="1"/>
                                        <field name="investor_file_id" readonly="1"/>
                                        <field name="sector_id" readonly="1" string="Floor"/>
                                        <field name="category_id" string="Category" readonly="1"/>
                                        <field name="unit_category_type_id" string="Product" readonly="1"/>
                                        <field name="size_id" string="Size" readonly="1"/>
                                        <field name="unit_class_id" string="Type" readonly="1"/>
                                        <field name="inventory_id" string="Unit No." readonly="1"
                                               domain="[('project_type','=','housing_society')]"/>
                                        <field name="investor_unit_price"/>
                                        <field name="new_price"/>
                                        <field name="unit_number" string="Unit No." readonly="1" invisible="1"/>
                                        <field name="new_inventory_id" string="New Unit No."
                                               domain="[('state', '=', 'avalible_for_sale'),('project_type','=','housing_society')]"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="land_development.unit_swapping_request_tree" model="ir.ui.view">
            <field name="name">land_development unit_swapping_request_tree</field>
            <field name="model">unit.swapping.request</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <list create="false" edit="false">
                    <field name="name"/>
                    <field name="membership_id"/>
                    <field name="applicable_on"/>
                    <field name="transaction_type"/>
                    <field name="society_id"/>
                    <field name="phase_id"/>
                    <field name="appointment_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="land_development.action_unit_swapping_request" model="ir.actions.act_window">
            <field name="name">Unit Requests</field>
            <field name="res_model">unit.swapping.request</field>
            <field name="type">ir.actions.act_window</field>
            <field name="domain">
                [
                ('project_type','in',['skyscraper', False])
                ]
            </field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.unit_swapping_request_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.unit_swapping_request_form')}),
            ]"
            />
            <field name="context">{'current_view': 'buildings'}</field>
        </record>

        <menuitem
                id="land_development.unit_requests"
                name="Unit Requests"
                groups="real_estate.group_initiate_transfer_req,real_estate.group_approve_transfer_req"
                action="land_development.action_unit_swapping_request"
                parent="land_development.menu_transfer"
                sequence="5"
        />

    </data>
</odoo>
