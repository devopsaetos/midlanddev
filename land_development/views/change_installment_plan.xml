<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="land_development.change_installment_plan_form" model="ir.ui.view">
            <field name="name">land_development change_installment_plan_form</field>
            <field name="model">change.installment.plan</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="file_id" domain="[('project_type', 'in', ['skyscraper', False])]"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="membership_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="tracking_id"/>
                                <field name="member_id"/>
                            </group>
                        </group>
                        <group>
                            <group name="left_panel">
                            </group>

                            <group class="oe_subtotal_footer oe_right">
                                <button string="Search" name="search_file" type="object" class="btn-primary"/>
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page string="Change Installment Plan" autofocus="autofocus">
                                <field name="return_line">
                                    <list create="false">
                                        <field name="file_id"/>
                                        <field name="membership_id"/>
                                        <field name="category_id" string='Unit Category'/>
                                        <field name="size_id"/>
                                        <field name="sector_id" string="Floor"/>
                                    </list>

                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="file_id"/>
                                            </group>
                                            <notebook colspan="4">
                                                <page string="Payment Plan" autofocus="autofocus">
                                                    <form>
                                                        <sheet>
                                                            <group>
                                                                <group>
                                                                    <field name="plan_description"/>
                                                                    <field name="interval_id"/>
                                                                    <field name="total_installment"/>
                                                                    <field name="starting_date"/>
                                                                </group>
                                                                <group>
                                                                    <field name="balance_amount"/>
                                                                </group>
                                                            </group>
                                                            <notebook colspan="4">

                                                                <page string="Additional Amount">
                                                                    <field name="add_product_line">
                                                                        <list editable="bottom">
                                                                            <field name="is_fully_paid"
                                                                                   invisible='True'/>
                                                                            <field name="product_id"
                                                                                   options="{'no_create': True, 'no_open': True}"/>
                                                                            <field name="payment_type"/>
                                                                            <field name="value"/>
                                                                            <field name="total" sum='total'/>
                                                                            <field name="initial_payment" sum='total'/>
                                                                            <field name="remaining_payment"
                                                                                   sum='total'/>
                                                                            <field name="no_of_installment"
                                                                                   readonly="is_fully_paid == True"/>
                                                                            <field name="per_installment"/>
                                                                        </list>
                                                                    </field>
                                                                </page>
                                                            </notebook>
                                                        </sheet>
                                                    </form>
                                                </page>
                                            </notebook>
                                        </sheet>

                                        <footer>
                                            <button string="Create Installment Plan" name="create_new_installment_plan"
                                                    type="object" class="btn-primary"/>
                                            <button string="Discard" class="btn-default" special="cancel"/>
                                        </footer>
                                    </form>

                                </field>
                            </page>
                        </notebook>
                    </sheet>

                    <footer>
                        <button string="Discard" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="land_development.action_change_installment_plan" model="ir.actions.act_window">
            <field name="name">Change Installment Plan</field>
            <field name="res_model">change.installment.plan</field>
            <field name="type">ir.actions.act_window</field>

            <field name="view_mode">form</field>
            <field name="view_id" ref="land_development.change_installment_plan_form"/>
            <field name="target">new</field>
            <field name="context">{'current_view': 'building'}</field>
        </record>

        <menuitem
                id="land_development.change_installment_plan"
                name="Change Installment Plan"
                action="land_development.action_change_installment_plan"
                parent="land_development.menu_transfer"
                sequence="1"
        />

    </data>
</odoo>
