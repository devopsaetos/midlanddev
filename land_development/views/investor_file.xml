        <record model="ir.actions.act_window" id="land_development.action_investor_file">

            <field name="name">Investor's File Management</field>
            <field name="res_model">investor.file</field>

            <field name="view_mode">list,form</field>
            <field name="domain">
                [
                ('project_type','in',['skyscraper', False])
                ]
            </field>
            <field name="context">{'current_view': 'building', 'default_project_type': 'skyscraper', 'search_default_group_by_investor_id': 1}</field>
<!--            <field name="search_view_id" ref="land_development.investor_file_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.investor_file_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.investor_file_form')}),
                ]"
            />
        </record>

