        <record model="ir.actions.act_window" id="land_development.action_location">
            <field name="name">Location</field>
            <field name="res_model">location</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add an New Location.
              </p>
            </field>
            <field name="view_mode">list,form</field>
            <field name="context">{'current_view': 'realestate', 'default_project_type':'skyscraper'}</field>
            <field name="domain">
                [
                    ('project_type','in',['skyscraper', False])
                ]
            </field>
        </record>

        <menuitem
            id="land_development.location"
            name="Location"
            parent="land_development.menu_society"
            action="land_development.action_location"
            sequence='8'
        />
        
    </data>
</odoo>