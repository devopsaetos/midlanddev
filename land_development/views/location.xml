<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.ui.view" id="land_development.location_form">
            <field name="name">land_development location_form</field>
            <field name="model">location</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title oe_state_size">
                            <field name="project_type" invisible='1'/>
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <div class="o_address_format">
                                    <field 
                                        name="street" 
                                        placeholder="Street..." 
                                        class="o_address_street"
                                    />

                                    <field 
                                        name="city_id" 
                                        placeholder="City" 
                                        class="o_address_city"
                                        options='{"no_open": True}'
                                        context="{'state_id': state_id}"
                                    />

                                    <field 
                                        name="state_id" 
                                        string="Province"
                                        class="o_address_state" 
                                        placeholder="State"
                                        options='{"no_open": True}'
                                        context="{'country_id': country_id}"
                                    />
                                    <field 
                                        name="zip" 
                                        placeholder="ZIP" 
                                        class="o_address_zip"
                                    />
                                    <field 
                                        name="country_id" 
                                        placeholder="Country" 
                                        class="o_address_country"
                                        options='{"no_open": True, "no_create": True}'
                                    />
                                </div>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="land_development.location_tree">
            <field name="name">land_development location_tree</field>
            <field name="model">location</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="street"/>
                    <field name="city_id"/>
                    <field name="state_id" string="Province"/>
                    <field name="zip"/>
                    <field name="country_id"/>
                </list>
            </field>
        </record>

