        <record model="ir.actions.act_window" id="land_development.action_investors">
            <field name="name">Investors</field>
            <field name="res_model">res.member</field>
            <field name="domain">[('is_investor','=',1),('project_type','in',['skyscraper', False])]</field>
            <field name="context">
                {
                'default_is_investor':1,
                'default_project_type':'skyscraper',
                'current_view': 'building'
                }
            </field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add new Member.
                </p>
            </field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.view_investor_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.view_investor_form')})]"
            />
        </record>

