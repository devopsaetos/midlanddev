<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="land_development.unit_category_type_form">
            <field name="name">land_development unit_category_type_form</field>
            <field name="model">unit.category.type</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_type" invisible="1"/>
                                <field name="name"/>
                                <field name="plot_category_id" string="Unit Category" invisible="1" domain="[('project_type', 'in', ['skyscraper', False])]"/>
                            </group>
                            <group>
                                <field name="code"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="land_development.unit_category_type_tree">
            <field name="name">land_development unit_category_type_tree</field>
            <field name="model">unit.category.type</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>

<!--        <record model="ir.ui.view" id="land_development.unit_category_type_search">-->
<!--            <field name="name">land_development unit_category_type_search</field>-->
<!--            <field name="model">unit.category.type</field>-->
<!--            <field name="priority">2</field>-->
<!--            <field name="arch" type="xml">-->
<!--                <search>-->
<!--                    <field name="name"/>-->
<!--                    <field name="code"/>-->
<!--                </search>-->
<!--            </field>-->
<!--        </record>-->


        <record model="ir.actions.act_window" id="land_development.action_unit_category_type">
            <field name="name">Product</field>
            <field name="res_model">unit.category.type</field>

            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to add Product Type.
              </p>
            </field>
            <field name="domain">
                [
                    ('project_type','in',['skyscraper', False])
                ]
            </field>
            <field name="context">{ 'current_view': 'building', 'default_project_type':'skyscraper'}</field>
            <field name="view_mode">list,form</field>
<!--            <field name="search_view_id" ref="land_development.unit_category_type_search"/>-->
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.unit_category_type_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.unit_category_type_form')}),
            ]"
            />
        </record>

        <menuitem
            id="land_development.unit_category_type"
            name="Product"
            parent="land_development.menu_inventory"
            action="land_development.action_unit_category_type"
            sequence='2'
        />
    </data>
</odoo>