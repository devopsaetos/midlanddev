<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="land_development.inventory_creation_tree_view" model="ir.ui.view">
            <field name="name">land_development_inventory_creation_tree_view</field>
            <field name="model">create.inventory</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list name='create_inventory_tree' string="Create Inventory">
                    <field name="name"/>
                    <field name="society_id"/>
                    <field name="phase_id"/>
                    <field name="sector_id"/>
                    <field name="status"/>
                    <field name="total_inventory" invisible="1"/>
                </list>
            </field>
        </record>

        <record id="land_development.inventory_creation_form_view" model="ir.ui.view">
            <field name="name">land_development inventory_creation_form</field>
            <field name="model">create.inventory</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit For Approval" name="submit_bulk_inventory"
                                groups="real_estate.create_inventory_users" type="object" class="btn-primary"
                                invisible="status != 'draft'"/>
                        <button string="Approve" name="create_bulk_inventory"
                                groups="real_estate.approve_inventory_users" type="object" class="btn-primary"
                                invisible="status != 'submitted'"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_type" invisible="1"/>
                                <field name="society_id"
                                       options="{'no_create': True, 'no_open': True}"
                                       string="Project"
                                       domain="[
                                                ('is_society','=',1),
                                                ('project_type','in',['skyscraper', False])
                                               ]"
                                />
                                <field name="sector_id"
                                       options="{'no_create': True, 'no_open': True}"
                                       string="Floors"
                                       domain="[('project_type','in',['skyscraper', False])]"
                                />
                            </group>
                            <group>
                                <field name="phase_id"
                                       options="{'no_create': True, 'no_open': True}"
                                       string="Building"
                                       domain="[
                                                ('is_society','!=',1),
                                                ('project_type','in',['skyscraper', False])
                                               ]"
                                />
                            </group>
                        </group>
                        <group>
                            <button string="Select All" name="select_all_inventory_lines"
                                    invisible="status != 'submitted'"
                                    groups="real_estate.approve_inventory_users" type="object" class="btn-primary"/>
                        </group>
                        <notebook colspan="4">
                            <page string="Create Inventory" autofocus="autofocus">
                                <field name="inventory_line">
                                    <list editable="bottom">
                                        <field name="is_select"
                                               invisible="parent.status != 'submitted'"/>
                                        <field name="nop" string="No. of Units"/>
                                        <field name="category_id" string="Category"
                                               options="{'no_open': True, 'no_create': True}"
                                               domain="[('project_type', 'in', ['skyscraper', False])]"/>
                                        <field name="unit_category_type_id" string="Product"
                                               options="{'no_open': True, 'no_create': True}"
                                               domain="[('project_type', 'in', ['skyscraper', False])]"/>
                                        <field name="size_id" domain="[('project_type', 'in', ['skyscraper', False])]"
                                               options="{'no_open': True, 'no_create': True}"/>
                                        <field name="unit_class_id" string="Type"
                                               options="{'no_create': True, 'no_open': True}"
                                               domain="[('project_type', 'in', ['skyscraper', False])]"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="land_development.action_inventory_creation" model="ir.actions.act_window">
            <field name="name">Create Inventory</field>
            <field name="res_model">create.inventory</field>
            <field name="type">ir.actions.act_window</field>
            <field name="domain">[('status','=','draft'),('project_type','in',['skyscraper', False])]</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.inventory_creation_tree_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.inventory_creation_form_view')}),
                ]"
            />

            <field name="target">current</field>
            <field name="context">{'current_view': 'building', 'default_project_type':'skyscraper'}</field>
        </record>

        <record id="land_development.action_inventory_approve" model="ir.actions.act_window">
            <field name="name">Approve Inventory</field>
            <field name="res_model">create.inventory</field>
            <field name="view_mode">list,form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">current</field>
            <field name="domain">[('status','in',('submitted', 'approved')),('project_type','in',['skyscraper', False])]</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('land_development.inventory_creation_tree_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('land_development.inventory_creation_form_view')}),
                ]"
            />
            <field name="context">{ 'current_view': 'building', 'default_project_type':'skyscraper'}</field>
        </record>

        <menuitem
                id="land_development.inventory_creation"
                name="Create Inventory"
                action="land_development.action_inventory_creation"
                parent="land_development.menu_unit_inventory"
                sequence="1"
        />

        <menuitem
                id="land_development.inventory_approval"
                name="Approve Inventory"
                action="land_development.action_inventory_approve"
                parent="land_development.menu_unit_inventory"
                sequence="2"
        />

    </data>
</odoo>
