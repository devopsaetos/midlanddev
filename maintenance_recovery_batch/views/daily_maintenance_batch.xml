<odoo>
    <data>
        <!--        Tree View-->
        <record model="ir.ui.view" id="daily_maintenance_batch_tree_view">
            <field name="name">Daily Expense Batch Tree View</field>
            <field name="model">daily.maintenance.batch</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="user_id"/>
                    <!-- <field name="branch_id"/> --> <!-- res.branch not available in this project -->
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <!--        Form View-->
        <record id="daily_maintenance_batch_form_view" model="ir.ui.view">
            <field name="name">Daily Expense Batch Form View</field>
            <field name="model">daily.maintenance.batch</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <!-- Odoo 19: literal translation of the old attrs domain
                             ['|', ('state','!=','submit'), ('state','!=','approved')] which is
                             always-true (a record's state can never equal both 'submit' and
                             'approved' simultaneously), so this button was already effectively
                             always invisible pre-conversion. Kept as-is (not a version-syntax
                             concern) rather than silently changing the business logic. -->
                        <button name="set_to_draft" string="Set to Draft"
                                invisible="state != 'submit' or state != 'approved'"
                                class="oe_highlight" type="object"
                                groups="maintenance_recovery_batch.officer_group_id"/>

                        <button type="object"
                                class="oe_highlight"
                                string="Submit To Manager"
                                name="submit_to_manager"
                                state="draft"
                                invisible="payment_submit != False"
                                groups="maintenance_recovery_batch.officer_group_id"
                        />
                        <button name="approved" string="Approved"
                                class="oe_highlight" type="object"
                                invisible="payment_created != False"
                                groups="maintenance_recovery_batch.manager_group_id"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="account_payment_created" type="object" widget="statinfo"
                                    icon="fa-pencil-square-o" string="Receipt"
                                    invisible="payment_approved != True"
                                    groups="maintenance_recovery_batch.manager_group_id"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date" readonly="state != 'draft'" required="1"
                                       force_save="1"/>
                                <field name="user_id"
                                       options='{"no_open": True, "no_create": True, "no_create_edit": True}'
                                       required="1" force_save="1"/>
                                <field name="journal_id"
                                       required="1"
                                       force_save="1"
                                       options='{"no_open": True, "no_create": True, "no_create_edit": True}'
                                />
                                <field name="total_records" readonly="1" force_save="1"/>
                                <field name="account_payment_id" invisible="1" force_save="1"/>
                                <field name="payment_submit" invisible="1" force_save="1"/>
                                <field name="payment_approved" invisible="1" force_save="1"/>
                                <field name="payment_created" invisible="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="company_id" readonly="1" force_save="1"/>
                                <!-- <field name="branch_id" readonly="1" force_save="1"/> --> <!-- res.branch not available in this project -->

                                <!--                                <field name="total_amount" readonly="1"-->
                                <!--                                       style="font-size:18px !important;font-weight: bolder !important;"/>-->
                            </group>
                        </group>
                        <!--                        <group>-->
                        <!--                            <button name="search_invoices" string="Search Invoices" class="oe_highlight" type="object"/>-->
                        <!--                        </group>-->
                        <notebook>
                            <page string="Maintenance">
                                <field name="maintenance_line_ids" readonly="state != 'draft'"
                                       mode="list">
                                    <list>
                                        <field name="company_id" invisible="1"/>
                                        <field name="sequence" invisible="1"/>
                                        <field name="sector_id" options="{'no_create': True, 'no_open': True}"
                                               required="1" force_save="1"/>
                                        <field name="street_id" options="{'no_create': True, 'no_open': True}"
                                               required="1" force_save="1"/>
                                        <field name="house_id" options="{'no_create': True, 'no_open': True}"
                                               required="1" force_save="1"/>
                                        <field name="category_id" options="{'no_create': True, 'no_open': True}"
                                               readonly="1" force_save="1"/>
                                        <field name="product_id" options="{'no_create': True, 'no_open': True}"
                                               required="1" force_save="1"/>
                                        <field name="partner_id" options="{'no_create': True, 'no_open': True}"
                                               readonly="1"/>
                                        <field name="invoice_ids" options="{'no_create': True, 'no_open': True}"
                                               invisible="1" force_save="1"/>
                                        <field name="journal_id" required="1" invisible="1"/>
                                        <!-- fiscal_month_id/fiscal_year_id removed: fiscal.month/fiscal.year models do not exist in this project -->
                                        <!-- <field name="fiscal_month_id" options="{'no_create': True, 'no_open': True}"
                                               force_save="1" string="Month"/> -->
                                        <!-- <field name="fiscal_year_id" options="{'no_create': True, 'no_open': True}"
                                               invisible="1" force_save="1"/> -->
                                        <field name="due_amount" readonly="1" force_save="1" sum="Total"/>
                                        <field name="paid_amount" sum="Total" required="1"/>
                                        <field name="discount" sum="Total" invisible="1"/>
                                        <field name="balance" readonly="1" sum="Total"/>
                                        <field name="payment_id" readonly="1" invisible="1"/>
                                        <field name="payment_date" required="1"/>
                                        <button string="Receipt" name="print_receipt" type="object" class="btn-primary"
                                                icon="fa-pencil-square-o" width="0.1"
                                                style="background-color: #4198c7;"
                                                column_invisible="parent.payment_submit != True"/>
                                    </list>
                                    <form string="daily_maintenance_line_form">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="is_inv_select" invisible="1"/>
                                                    <field name="unit_class_id"
                                                           options="{'no_create': True, 'no_open': True}"/>
                                                    <field name="house_id"
                                                           options="{'no_create': True, 'no_open': True}"/>
                                                    <field name="street_id"
                                                           options="{'no_create': True, 'no_open': True}"/>
                                                    <field name="product_id"
                                                           options="{'no_create': True, 'no_open': True}"/>
                                                    <field name="paid_amount"
                                                           readonly="is_inv_select == False" required="is_inv_select == True"/>
                                                    <field name="journal_id" invisible="1"/>
                                                </group>
                                                <group>
                                                    <field name="sector_id"
                                                           options="{'no_create': True, 'no_open': True}"/>
                                                    <field name="category_id"
                                                           options="{'no_create': True, 'no_open': True}"/>
                                                    <field name="partner_id"
                                                           options="{'no_create': True, 'no_open': True}" readonly="1"/>
                                                    <!-- fiscal_month_id/fiscal_year_id removed: fiscal.month/fiscal.year models do not exist in this project -->
                                                    <!-- <field name="fiscal_month_id"
                                                           options="{'no_create': True, 'no_open': True}"/> -->
                                                    <!-- <field name="fiscal_year_id"
                                                           options="{'no_create': True, 'no_open': True}"/> -->
                                                    <field name="discount" invisible="1"/>
                                                    <field name="payment_date" required="1"/>

                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Invoices">
                                                    <field name="invoice_ids"
                                                           options="{'no_create': True, 'no_open': True}">
                                                        <list editable="bottom">
                                                            <field name="name"/>
                                                            <field name="partner_id" invisible="0"
                                                                   options="{'no_create': True, 'no_open': True}"/>
                                                            <field name="date"/>
                                                            <!-- fiscal_month_id does not exist on account.move (fiscal.month model not defined in this project) -->
                                                            <!-- <field name="fiscal_month_id"
                                                                   options="{'no_create': True, 'no_open': True}"
                                                                   readonly="1"/> -->
                                                            <field name="invoice_partner_display_name"
                                                                   invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')"
                                                                   groups="base.group_user" string="Vendor"/>
                                                            <field name="invoice_partner_display_name"
                                                                   invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"
                                                                   groups="base.group_user" string="Customer"/>
                                                            <field name="invoice_date" optional="show"
                                                                   invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')"
                                                                   string="Bill Date"/>
                                                            <field name="invoice_date" optional="show"
                                                                   invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"
                                                                   string="Invoice Date"/>
                                                            <field name="invoice_user_id" optional="show"
                                                                   invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"
                                                                   string="Sales Person"/>
                                                            <field name="invoice_date_due" optional="show"/>
                                                            <field name="amount_untaxed_signed" string="Tax Excluded"
                                                                   sum="Total" optional="hide"/>
                                                            <field name="amount_tax_signed" string="Tax" sum="Total"
                                                                   optional="hide"/>
                                                            <field name="amount_total_signed" string="Total" sum="Total"
                                                                   optional="show"/>
                                                            <field name="amount_residual_signed" string="Amount Due"
                                                                   sum="Amount Due" optional="show"/>
                                                            <field name="currency_id" invisible="1"/>
                                                            <field name="company_currency_id" invisible="1"/>
                                                            <field name="state" optional="hide"/>
                                                            <!-- Odoo 19: account.move renamed invoice_payment_state -> payment_state -->
                                                            <field name="payment_state" optional="show"/>
                                                            <!-- Odoo 19: account.move renamed type -> move_type -->
                                                            <field name="move_type"
                                                                   invisible="context.get('default_move_type', True)"/>
                                                        </list>
                                                    </field>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>

                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- actions opening views on models -->
        <record model="ir.actions.act_window" id="maintenance_recovery_batch.daily_maintenance_batch_action">
            <field name="name">Daily Transactions</field>
            <field name="res_model">daily.maintenance.batch</field>
            <field name="view_mode">list,form</field>
        </record>
        <record id="maintenance_recovery_batch.daily_maintenance_batch_sequence" model="ir.sequence">
            <field name="name">Daily Maintenance Batch Sequence</field>
            <field name="code">daily.maintenance.batch.sequence</field>
            <field name="prefix">MNT/REC/</field>
            <field name="padding">0</field>
            <field name="company_id" eval="False"/>
        </record>
        <menuitem name="Maintenance Transactions" sequence="7"
                  id="maintenance_recovery_batch.daily_maintenance_batch_menu_item"
                  parent="maintenance_charges.maintenance_charges_main_menu"
                  action="maintenance_recovery_batch.daily_maintenance_batch_action"/>

        <menuitem id="maintenance_invoice_report.maintenance_invoice_report_wizards_menu"
                  action="maintenance_invoice_report.maintenance_invoice_report_wizard_action"
                  name="Maintenance Charges Invoice"
                  parent="maintenance_charges.maintenance_charges_main_menu"
        />
    </data>
</odoo>