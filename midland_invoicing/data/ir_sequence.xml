<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_midland_invoice" model="ir.sequence">
        <field name="name">Midland Customer Invoice</field>
        <field name="code">midland.invoice</field>
        <field name="prefix">INV/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_midland_payment" model="ir.sequence">
        <field name="name">Midland Payment</field>
        <field name="code">midland.payment</field>
        <field name="prefix">PMNT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_dealer_confirmation" model="ir.sequence">
        <field name="name">Dealer Confirmation</field>
        <field name="code">dealer.confirmation</field>
        <field name="prefix">DCNF/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
