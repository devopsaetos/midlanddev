<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="midland_invoicing.midland_invoice_rule" model="ir.rule">
            <field name="name">Midland Invoice multi-company</field>
            <field name="model_id" ref="model_midland_invoice"/>
            <field name="domain_force">
                [
                '|',
                ('company_id','=',False),
                ('company_id','in',company_ids)
                ]
            </field>
        </record>

        <record id="midland_invoicing.midland_payment_rule" model="ir.rule">
            <field name="name">Midland Payment multi-company</field>
            <field name="model_id" ref="model_midland_payment"/>
            <field name="domain_force">
                [
                '|',
                ('company_id','=',False),
                ('company_id','in',company_ids)
                ]
            </field>
        </record>
    </data>
</odoo>
