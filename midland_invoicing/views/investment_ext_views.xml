<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit real_estate investment form: add smart button + Generate Invoices button -->
    <record id="investment_form_midland_invoice_ext" model="ir.ui.view">
        <field name="name">investment.form.midland.invoice.ext</field>
        <field name="model">investment</field>
        <field name="inherit_id" ref="real_estate.investment_view_form"/>
        <field name="arch" type="xml">

            <!-- Smart button in button_box -->
            <div name="button_box" position="inside">
                <button name="action_view_midland_invoices"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="midland_invoice_count == 0">
                    <field name="midland_invoice_count" widget="statinfo" string="Invoices"/>
                </button>
            </div>

            <!-- Generate Invoices button in header (before state statusbar) -->
            <field name="state" position="before">
                <button name="action_generate_installment_invoices"
                        string="Generate Invoices"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'reserved' or midland_invoice_count &gt; 0"/>
            </field>

        </field>
    </record>

    <!-- Inherit land_development investment form: same smart button + Generate Invoices button -->
    <record id="building_investment_form_midland_invoice_ext" model="ir.ui.view">
        <field name="name">building.investment.form.midland.invoice.ext</field>
        <field name="model">investment</field>
        <field name="inherit_id" ref="land_development.investment_view_form"/>
        <field name="arch" type="xml">

            <!-- Smart button in button_box -->
            <div name="button_box" position="inside">
                <button name="action_view_midland_invoices"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="midland_invoice_count == 0">
                    <field name="midland_invoice_count" widget="statinfo" string="Invoices"/>
                </button>
            </div>

            <!-- Generate Invoices button in header (before state statusbar) -->
            <field name="state" position="before">
                <button name="action_generate_installment_invoices"
                        string="Generate Invoices"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'reserved' or midland_invoice_count &gt; 0"/>
            </field>

        </field>
    </record>

</odoo>
