<?xml version="1.0"?>
<odoo>

        <record model="ir.ui.view" id="default_payment.multi_invoice_payment_tree">
            <field name="name">default_payment multi_invoice_payment_tree</field>
            <field name="model">multi.invoice.payment</field>
            <field name="priority" eval="16"/>
            <field name="arch" type="xml">
                <list create="false" edit="false" decoration-info="state == 'draft'" string="Multi Payment Logs" decoration-muted="state == 'cancel'">
                    <field name="state" invisible="1"/>
                    <field name="active" invisible="1"/>
                    <field name="invoice_payment_state" invisible="1"/>
                    <field name="type" invisible="1"/>
                    <field name="partner_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="payment_id" readonly="1" invisible="1"/>
                    <field name="payment_date"/>
                    <field name="invoice_id"/>
                    <field name="invoice_date"/>
                    <field name="invoice_date_due"/>
                    <field name="amount_total_signed" string="Total" sum="Total" optional="show"/>
                    <field name="payment_due" readonly="1" string="Amount Due" sum="Amount Due" optional="show"/>
                    <field name="payment_amount" sum="Payment Amount" readonly="0"/>
                    <field name="discount_amount" readonly="0"/>
                    <field name="payment_difference" optional="show" string="Difference" sum="Payment Difference"/>
                    <field name="payment_difference_handling" optional="show" string="Action" readonly="payment_difference == 0.0"
                           invisible="1"/>
                    <field name="writeoff_account_id" optional="show" string="Account" readonly="payment_difference_handling != 'reconcile'"
                           invisible="1"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="default_payment.multi_invoice_payment_search">
            <field name="name">default_payment multi_invoice_payment_search</field>
            <field name="model">multi.invoice.payment</field>
            <field name="priority" eval="16"/>
            <field name="arch" type="xml">
                <search string="Multi Payment Logs">
                    <field name="state"/>
                    <field name="active"/>
                    <field name="invoice_payment_state"/>
                    <field name="type"/>
                    <field name="partner_id"/>
                    <field name="currency_id"/>
                    <field name="payment_id"/>
                    <field name="payment_date"/>
                    <field name="invoice_id"/>
                    <field name="invoice_date"/>
                    <field name="invoice_date_due"/>
                    <field name="amount_total_signed" string="Total"/>
                    <field name="payment_due" string="Amount Due"/>
                    <field name="payment_amount"/>
                    <field name="discount_amount"/>
                    <field name="payment_difference" string="Difference"/>
                    <field name="payment_difference_handling" string="Action"/>
                    <field name="writeoff_account_id" string="Account"/>
                </search>
            </field>
        </record>

        <record id="default_payment.multi_invoice_payment_receivables_action" model="ir.actions.act_window">
            <field name="name">Multi Invoice Payment Log</field>
            <field name="res_model">multi.invoice.payment</field>
            <field name="domain">[('type', 'in', ['out_invoice','in_refund'])]</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="default_payment.multi_invoice_payment_tree"/>
        </record>

        <record id="default_payment.multi_invoice_payment_payables_action" model="ir.actions.act_window">
            <field name="name">Multi Invoice Payment Log</field>
            <field name="res_model">multi.invoice.payment</field>
            <field name="domain">[('type', 'in', ['in_invoice','out_refund'])]</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="default_payment.multi_invoice_payment_tree"/>
        </record>

        <menuitem
            action="default_payment.multi_invoice_payment_receivables_action"
            id="default_payment.multi_invoice_payment_receivables"
            parent="account.menu_finance_receivables"
            sequence="16"
            groups="default_payment.group_multi_invoices"
        />

        <menuitem
            action="default_payment.multi_invoice_payment_payables_action"
            id="default_payment.multi_invoice_payment_payables"
            parent="account.menu_finance_payables"
            sequence="21"
            groups="default_payment.group_multi_invoices"
        />

</odoo>
