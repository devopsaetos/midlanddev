        <record id="view_account_advance_payment_invoice_form" model="ir.ui.view">
            <field name="name">view.apply.advance.payment.form</field>
            <field name="model">apply.advance.payment</field>
            <field name="arch" type="xml">
                <form string="Apply Advance Payments">
                    <sheet>
                        <div class="oe_title">
                            <label for="partner_id" class="oe_edit_only"/>
                            <h1><field name="partner_id" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="journal_id" domain="[('company_id', '=', company_id)]"/>
                                <field name="date" />
                                <field name="invoice_residual"/>
                                <field name="advance_payment_total"/>
                                <field name="adjust_amount_total"/>
                            </group>
                            <group>
                                <field name="company_id" readonly="1"/>
                                <field name="currency_id"/>
                                <field name="partner_type" readonly="1"/>
                            </group>
                        </group>
                        <separator />
                        <notebook>
                            <page string="Advance payments to apply">
                                <field name="advance_payment_ids"
                                       domain="[('company_id', '=', company_id), ('is_advance_payment', '=', True),
                                                ('partner_id', '=', partner_id), ('partner_type', '=', partner_type),
                                                ('amount_residual', '!=', 0.0), ('state', '=', 'paid')]"
                                       context="{'default_payment_category': 'advance_payment',
                                                 'default_partner_id': partner_id,
                                                 'default_partner_type': partner_type,
                                                 'default_company_id': company_id,
                                                 'default_currency_id': currency_id}">
                                    <list string="Advance Payments" editable="bottom">
                                        <field name="date" invisible="1"/>
                                        <field name="name"/>
                                        <field name="journal_id"/>
                                        <field name="payment_method_line_id" invisible="1"/>
                                        <field name="company_id" invisible="1"/>
                                        <field name="amount_to_adjust" sum="Amount"/>
                                        <field name="projected_residual" string="Remaining Amount" sum="Balance"/>
                                        <field name="amount_residual" invisible="1"/>
                                        <field name="amount" sum="Amount"/>
                                        <field name="reconciled_invoices_count" invisible="1"/>
                                        <field name="state" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>

                        <footer>
                            <button string='Apply' name="apply_advance_payment" type="object" class="btn-primary"/>
                            <button string="Cancel" class="btn-default" special="cancel"/>
                        </footer>
                    </sheet>
               </form>
            </field>
        </record>

        <record id="default_payment.action_account_advance_payment_invoice" model="ir.actions.act_window">
            <field name="name">Apply Advance Payments</field>
            <field name="res_model">apply.advance.payment</field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

</odoo>
