                        <br/>
                        <br/>
                        <table class="table table-striped table-bordered">
                            <thead>
                                <tr style="background-color:#191970;color:#fff;font-size:14px;">
                                    <th class="p-1 align-middle text-center">
                                        <span>Sr No.</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Member</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>File No.</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Sector</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Street</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>House</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Date</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Journal</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Category</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Product</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Amount</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="total_amount" t-value="0"/>
                                <t t-set="serial_number" t-value="0"/>
                                <t t-foreach="account_payment" t-as="account">
                                    <t t-set="serial_number" t-value="serial_number + 1"/>
                                    <tr style="font-size:14px !important;">
                                        <td class="p-1 align-middle text-center">
                                            <span t-esc="serial_number"/>.
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.file_id.membership_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.file_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.file_id.sector_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.file_id.street_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.file_id.inventory_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.payment_date"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.journal_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.file_id.category_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-left">
                                            <span t-esc="account.file_id.unit_category_type_id.name"/>
                                        </td>
                                        <td class="p-1 align-middle text-right">
                                            <span t-esc="sum(account.multi_invoice_ids.filtered(lambda invoice: invoice.invoice_id.property_invoice_type in ['maintenance_charges', 'society_charges'] and any(line.product_id.id == 103 for line in invoice.invoice_id.invoice_line_ids)).mapped('payment_amount'))"
                                                  t-options='{"widget": "float", "precision": 2}'/>
                                        </td>
                                    </tr>
                                    <t t-set="total_amount"
                                       t-value="total_amount + sum(account.multi_invoice_ids.filtered(lambda invoice: invoice.invoice_id.property_invoice_type in ['maintenance_charges', 'society_charges'] and any(line.product_id.id == 103 for line in invoice.invoice_id.invoice_line_ids)).mapped('payment_amount'))"/>
                                </t>
                                <tr style="font-size:14px !important;">
                                    <td colspan="10" class="p-1 align-middle text-left">
                                        <strong>Total</strong>
                                    </td>
                                    <strong>
                                        <td class="p-1 align-middle text-right">
                                            <span t-esc="total_amount" t-options='{"widget": "float", "precision": 2}'/>
                                        </td>
                                    </strong>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>

