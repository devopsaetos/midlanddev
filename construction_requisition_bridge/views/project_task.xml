<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_form_requisition_bridge_ext" model="ir.ui.view">
        <field name="name">project.task.form.requisition.bridge</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <!-- Header buttons -->
            <header position="inside">
                <button name="action_create_material_requisition"
                        string="Create Material Requisition"
                        type="object"
                        class="btn-primary"/>
                <button name="action_create_purchase_requisition"
                        string="Create Purchase Requisition"
                        type="object"
                        class="btn-primary"/>
            </header>
            <!-- Stat buttons -->
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object"
                        name="button_view_material_requisitions"
                        invisible="material_requisition_count == 0"
                        icon="fa-list-alt">
                    <field name="material_requisition_count" widget="statinfo"
                           string="Material Req."/>
                </button>
                <button class="oe_stat_button" type="object"
                        name="button_view_purchase_requisitions"
                        invisible="purchase_requisition_count == 0"
                        icon="fa-file-text-o">
                    <field name="purchase_requisition_count" widget="statinfo"
                           string="Purchase Req."/>
                </button>
            </div>
        </field>
    </record>

</odoo>
