<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="material_purchase_requisition_form_ext" model="ir.ui.view">
        <field name="name">material.purchase.requisition.form.ext</field>
        <field name="model">material.purchase.requisition</field>
        <field name="inherit_id" ref="purchase_requisitions.material_purchase_requisition_form_view"/>
        <field name="arch" type="xml">
            <!-- Add project/task after description -->
            <field name="requisition_description" position="after">
                <field name="project_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="task_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
            </field>
            <!-- Add cost sheet column in requisition lines list -->
            <xpath expr="//field[@name='requisition_line_ids']//list//field[@name='product_id']" position="after">
                <field name="task_cost_sheet_id"
                       optional="show"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

</odoo>
