<odoo>
    <template id="maintenance_customized_header">
        <div class="header">
            <div class="o_clean_header">
                <div class="row" style="font-family:'Roboto',sans-serif">
                    <div class="col-7">
                        <img t-if="o.env.company.logo" t-att-src="image_data_uri(o.env.company.logo)" alt="Logo"
                        />
                    </div>
                    <div class="col-5" name="company_address" style="font-size:12px; text-align:right;color:black">
                        <ul class="list-unstyled">
                            <strong>
                                <li t-if="o.env.company.name">
                                    <span t-field="o.env.company.name"/>
                                </li>
                            </strong>
                            <li t-if="o.env.company.street">
                                <span t-field="o.env.company.street"/>
                            </li>
                            <li t-if="o.env.company.street2">
                                <span t-field="o.env.company.street2"/>
                                <span t-field="o.env.company.city"/>
                            </li>
                            <li t-if="o.env.company.country_id">
                                <span t-field="o.env.company.country_id.name"/>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </template>
    <template id="maintenance_customized_footer">
        <div class="footer">
            <div class="row" style="font-size:11px;font-family:'Roboto',sans-serif;color:black;">
                <div class="col-4 text-center" style="margin-top:0px;">
                    <span>Printed By:
                        <span t-esc="request.env.user.name"/>
                    </span>
                </div>
                <div class="col-4 text-center" style="margin-top:0px;"/>
                <div class="col-4 text-center" style="margin-top:0px;">
                    <span>Print Date:
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y')"/>
                    </span>
                </div>
            </div>
        </div>
    </template>
    <data>
        <template id="maintenance_recovery_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="maintenance_recovery.maintenance_customized_header"/>
                    <t t-call="maintenance_recovery.maintenance_customized_footer"/>
                    <t t-call="web.basic_layout">
                        <div class="page">
                            <div class="row">
                                <div class="col-12 text-center">
                                    <h5 style="color:#191970;" class="text-capitalize">
                                        <b>MAINTENANCE RECOVERY</b>
                                    </h5>
                                </div>
                            </div>
                            <hr/>
                            <div class="col-12 text-capitalize">
                                <div class="row" style="color:black;">
                                    <div class="col-6">
                                        <t t-if="sector_ids">
                                            <div class="row" style="color:black;">
                                                <div class="col-4">
                                                    <b>Sector:</b>
                                                </div>
                                                <div class="col-8" style="background-color:#F6F6F6;">
                                                    <t t-foreach="sector_ids" t-as="sector">
                                                        <span t-esc="sector.name"/>,
                                                    </t>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-if="product_id">
                                            <div class="row" style="color:black;">
                                                <div class="col-4">
                                                    <b>Product:</b>
                                                </div>
                                                <div class="col-8" style="background-color:#F6F6F6;">
                                                    <t t-foreach="product_id" t-as="product">
                                                        <span t-esc="product.name"/>,
                                                    </t>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-if="size_id">
                                            <div class="row" style="color:black;">
                                                <div class="col-4">
                                                    <b>Product:</b>
                                                </div>
                                                <div class="col-8" style="background-color:#F6F6F6;">
                                                    <span t-esc="size_id.name"/>,
                                                </div>
                                            </div>
                                        </t>
                                        <t t-if="type_id">
                                            <div class="row" style="color:black;">
                                                <div class="col-4">
                                                    <b>Product:</b>
                                                </div>
                                                <div class="col-8" style="background-color:#F6F6F6;">
                                                    <span t-esc="type_id.name"/>,
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                    <div class="col-6">
                                        <t t-if="date_from">
                                            <div class="row" style="color:black;">
                                                <div class="col-4">
                                                    <b>Date From:</b>
                                                </div>
                                                <div class="col-8" style="background-color:#F6F6F6;">
                                                    <span t-esc="date_from"
                                                          t-options="{'widget': 'date','format': 'dd-MM-yyyy'}"/>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-if="date_to">
                                            <div class="row" style="color:black;">
                                                <div class="col-4">
                                                    <b>Date To:</b>
                                                </div>
                                                <div class="col-8" style="background-color:#F6F6F6;">
                                                    <span t-esc="date_to"
                                                          t-options="{'widget': 'date','format': 'dd-MM-yyyy'}"/>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <hr/>
                        <!--**************************************** First Table ***********************-->
                        <table class="table table-striped table-bordered">
                            <thead>
                                <tr style="background-color:#191970;color:#fff;font-size:14px;">
                                    <th class="p-1 align-middle text-center">
                                        <span>Sector</span>
                                    </th>

                                    <th class="p-1 align-middle text-center">
                                        <span>Total Amount Due</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Total Amount Paid</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sector_total" t-value="0.0"/>
                                <t t-set="sector_total_due" t-value="0.0"/>
                                <t t-set="grand_sector_total" t-value="0.0"/>
                                <t t-set="grand_sector_total_due" t-value="0.0"/>
                                <t t-foreach="sectors" t-as="sector">
                                    <tr style="font-size:12px !important;">
                                        <td class="p-1 align-middle text-center"
                                            style="background-color:#191970;color:#fff;">
                                            <span t-esc="sector['name']"/>
                                        </td>
                                        <t t-foreach="sector['products']" t-as="product">
                                            <t t-set="sector_total_due"
                                               t-value="sector_total_due + product['total_not_paid']"/>
                                            <t t-set="sector_total"
                                               t-value="sector_total + product['total_paid']"/>
                                        </t>
                                        <td class="p-1 align-middle text-right">
                                            <span t-esc="sector_total_due"
                                                  t-options='{"widget": "float", "precision": 2}'/>
                                            <t t-set="grand_sector_total_due"
                                               t-value="grand_sector_total_due + sector_total_due"/>
                                        </td>
                                        <td class="p-1 align-middle text-right">
                                            <span t-esc="sector_total"
                                                  t-options='{"widget": "float", "precision": 2}'/>
                                            <t t-set="grand_sector_total" t-value="grand_sector_total + sector_total"/>
                                        </td>
                                        <t t-set="sector_total" t-value="0.0"/>
                                        <t t-set="sector_total_due" t-value="0.0"/>
                                    </tr>
                                </t>
                                <tr>
                                    <td class="p-1 align-middle text-center"
                                        style="background-color:#191970;color:#fff;font-size:14px;">
                                        <span>Total</span>
                                    </td>
                                    <td class="p-1 align-middle text-right">
                                        <span t-esc="grand_sector_total_due"
                                              t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                    <td class="p-1 align-middle text-right">
                                        <span t-esc="grand_sector_total"
                                              t-options='{"widget": "float", "precision": 2}'/>
                                    </td>

                                </tr>
                            </tbody>
                        </table>
                        <div style="page-break-after: always;"/>

                        <!-- ******************************************** Second Table ****************************************************************************-->
                        <table class="table table-striped table-bordered">
                            <thead>
                                <tr style="background-color:#191970;color:#fff;font-size:14px;">
                                    <th>Product Name</th>
                                    <th>Un-Paid Invoices</th>
                                    <th>Paid Invoices</th>
                                    <th>Total Product Due</th>
                                    <th>Total Product Paid</th>

                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="grand_total_paid_invoices" t-value="0"/>
                                <t t-set="grand_total_unpaid_invoices" t-value="0"/>
                                <t t-set="grand_total_not_paid" t-value="0.0"/>
                                <t t-set="grand_total_paid" t-value="0.0"/>
                                <t t-foreach="products" t-as="sector">
                                    <tr style="background-color:#191970;color:#fff;font-size:12px;">
                                        <td colspan="5" class="text-center">
                                            <span t-esc="sector['name']"/>
                                        </td>
                                    </tr>
                                    <t t-foreach="sector['products']" t-as="product">
                                        <tr>
                                            <td class="text-left">
                                                <span t-esc="product['name']"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-esc="product['count_not_paid']"/>
                                                <t t-set="grand_total_unpaid_invoices"
                                                   t-value="grand_total_unpaid_invoices + product['count_not_paid']"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-esc="product['count_paid']"/>
                                                <t t-set="grand_total_paid_invoices"
                                                   t-value="grand_total_paid_invoices + product['count_paid']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="product['total_not_paid']"
                                                      t-options='{"widget": "float", "precision": 2}'/>
                                                <t t-set="grand_total_not_paid"
                                                   t-value="grand_total_not_paid + product['total_not_paid']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="product['total_paid']"
                                                      t-options='{"widget": "float", "precision": 2}'/>
                                                <t t-set="grand_total_paid"
                                                   t-value="grand_total_paid + product['total_paid']"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                                <tr style="background-color:#191970;color:#fff;font-size:14px;">
                                    <td class="p-1 align-middle text-center"
                                    >
                                        <span>Total</span>
                                    </td>
                                    <td class="p-1 align-middle text-center">
                                        <span t-esc="grand_total_unpaid_invoices"
                                        />
                                    </td>
                                    <td class="p-1 align-middle text-center">
                                        <span t-esc="grand_total_paid_invoices"
                                        />
                                    </td>
                                    <td class="p-1 align-middle text-right">
                                        <span t-esc="grand_total_not_paid"
                                              t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                    <td class="p-1 align-middle text-right">
                                        <span t-esc="grand_total_paid"
                                              t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div style="page-break-after: always;"/>
                        <!-- ******************************************** Second Table ****************************************************************************-->
                        <!-- ******************************************** Third Table ****************************************************************************-->
                        <table class="table table-striped table-bordered">
                            <thead>
                                <tr style="background-color:#191970;color:#fff;font-size:14px;">

                                    <th class="p-1 align-middle text-center">
                                        <span>Sr. No.</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Member Name</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>File No.</span>
                                    </th>
                                    <th class="p-1 align-middle text-center">
                                        <span>Sector</span>
                                    </th>
                                    <th class="p-1 align-middle text-center;"
                                        style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap; text-align: center;">
                                        <span>Amount Due</span>
                                    </th>
                                    <th class="p-1 align-middle text-center;"
                                        style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap; text-align: center;">
                                        <span>Amount Paid</span>
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                <t t-set="sr_no" t-value="0"/>
                                <t t-set="grand_total_paid" t-value="0"/>
                                <t t-set="grand_total_due" t-value="0"/>
                                <t t-foreach="sectors" t-as="sector">
                                    <t t-foreach="sector['products']" t-as="product">
                                        <tr style="font-size:10px;">
                                            <t t-set="sr_no" t-value="sr_no + 1"/>
                                            <td class="p-1 align-middle text-center"
                                                style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap;">
                                                <span t-esc="sr_no"/>.
                                            </td>
                                            <td class="p-1 align-middle text-left"
                                                style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap;">
                                                <span t-esc="product['customer_name']"/>
                                            </td>
                                            <td class="p-1 align-middle text-center"
                                                style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap;">
                                                <span t-esc="product['file_name']"/>
                                            </td>
                                            <td class="p-1 align-middle text-center"
                                                style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap;">
                                                <span t-esc="product['product_name']"/>
                                            </td>
                                            <td class="p-1 align-middle text-right"
                                                style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap;">
                                                <span t-esc="product['total_not_paid']"
                                                      t-options='{"widget": "float", "precision": 2}'/>
                                                <t t-set="grand_total_due"
                                                   t-value="grand_total_due + product['total_not_paid']"/>
                                            </td>
                                            <td class="p-1 align-middle text-right"
                                                style="overflow: hidden;text-overflow: ellipsis;white-space: nowrap;">
                                                <span t-esc="product['total_paid']"
                                                      t-options='{"widget": "float", "precision": 2}'/>
                                                <t t-set="grand_total_due"
                                                   t-value="grand_total_due + product['total_paid']"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                                <tr>
                                    <td colspan="4">
                                        <span>Total</span>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="grand_total_due" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="grand_total_paid" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>

                            </tbody>
                        </table>
                        <!-- ******************************************** Third Table ****************************************************************************-->
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>