<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="project_team_view_list" model="ir.ui.view">
        <field name="name">project.team.list</field>
        <field name="model">project.team</field>
        <field name="arch" type="xml">
            <list string="Project Teams">
                <field name="name"/>
                <field name="email"/>
                <field name="default_hrs"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="project_count"/>
            </list>
        </field>
    </record>

    <record id="project_team_view_form" model="ir.ui.view">
        <field name="name">project.team.form</field>
        <field name="model">project.team</field>
        <field name="arch" type="xml">
            <form string="Project Team">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_projects"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <field name="project_count" widget="statinfo" string="Projects"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Team Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="email" widget="email"/>
                            <field name="default_hrs"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="product_owner_ids" widget="many2many_tags"
                                   options="{'no_create': True}" readonly="1"/>
                             <field name="member_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="project_team_action" model="ir.actions.act_window">
        <field name="name">Project Teams</field>
        <field name="res_model">project.team</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
