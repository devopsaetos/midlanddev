<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="allotment_request_batch_form" model="ir.ui.view">
            <field name="name">allotment allotment_request_batch_form</field>
            <field name="model">allotment.request.batch</field>
            <field name="arch" type="xml">
                <form create="false">
                    <header>
                        <button name="generate_files" type="object" string="Generate Allotments"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <label for="date_from" string="Period"/>
                                <div>
                                    <field name="date_from" class="oe_inline"/>-
                                    <field name="date_to" class="oe_inline"/>
                                </div>
                                <field name="society_id"/>
                                <field name="phase_id"/>
                            </group>
                            <group>
                                <field name="category_id"/>
                                <field name="unit_category_type_id"/>

                            </group>
                        </group>
                        <notebook>
                            <page name="Files" string="Files">
                                <field name="allotment_request_ids"/>
                            </page>
                            <page name="other_info" string="Allotment Info">
                                <group>
                                    <group>
                                        <field name="sector_id" options="{'no_create':True}"/>
                                        <field name="approved_responsibe_id"
                                               invisible="not approved_responsibe_id"/>
                                        <field name="issued_responsibe_id"
                                               invisible="not approved_responsibe_id"/>
                                        <field name="printed_responsibe_id"
                                               invisible="not printed_responsibe_id"/>
                                        <field name="canceled_responsibe_id"
                                               invisible="not canceled_responsibe_id"/>
                                    </group>
                                    <group>
                                        <field name="street_id" options="{'no_create':True}"/>

                                        <field name="approved_date"
                                               invisible="not approved_date"/>
                                        <field name="issued_date" invisible="not issued_date"/>
                                        <field name="printed_date"
                                               invisible="not printed_date"/>
                                        <field name="canceled_date"
                                               invisible="not canceled_date"/>
                                    </group>
                                </group>
                            </page>

                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="allotment_request_batch_tree" model="ir.ui.view">
            <field name="name">allotment allotment_request_batch_tree</field>
            <field name="model">allotment.request.batch</field>
            <field name="arch" type="xml">
                <list>
                    <field name="society_id"/>
                    <field name="phase_id"/>
                    <field name="category_id"/>
                    <field name="unit_category_type_id"/>
                    <field name="sector_id"/>
                    <field name="street_id"/>
                </list>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_allotment_request_batch">
            <field name="name">Allotment Batch</field>
            <field name="res_model">allotment.request.batch</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
                id="allotment_request_batch"
                name="Allotment Request Batch"
                action="action_allotment_request_batch"
                parent="real_estate.menu_inventory_root"
                sequence="6"
        />

    </data>
</odoo>
