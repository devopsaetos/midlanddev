<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="document_issuance_view_form" model="ir.ui.view">
            <field name="name">document_issuance_view_form</field>
            <field name="model">document.issuance</field>
            <field name="arch" type="xml">
                <form string="document_issuance_form">
                    <header>
                        <button name="action_issuance" type="object"
                                string="Issue" class="oe_highlight"
                                invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="document_type"
                                       required="1"
                                       readonly="state != 'draft'"/>
                                <field name="received_by"
                                       required="1"
                                       readonly="state != 'draft'"/>
                                <field name="file_ids" widget="many2many_tags"
                                       required="1"
                                       domain="[('membership_id','=', received_by)]"
                                       readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="received_date"
                                       required="1"
                                       readonly="state != 'draft'"/>
                                <field name="receiver_cnic"
                                       widget="mask"
                                       data-inputmask="'mask': '99999-9999999-9'"
                                       readonly="state != 'draft'"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="document_issuance_view_tree" model="ir.ui.view">
            <field name="name">_view_tree</field>
            <field name="model">document.issuance</field>
            <field name="arch" type="xml">
                <list string="_tree">
                    <field name="document_type"/>
                    <field name="received_date"/>
                    <field name="receiver_cnic"/>
                    <field name="received_by"/>
                </list>
            </field>
        </record>

        <record id="document_issuance_action" model="ir.actions.act_window">
            <field name="name">Document Issuance</field>
            <field name="res_model">document.issuance</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="document_issuance_menu"
                  name="Document Issuance"
                  parent="allotment.allotment_real_estate_menu"
                  action="document_issuance_action"/>
    </data>
</odoo>
