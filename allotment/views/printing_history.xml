<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="printing_history_view_tree" model="ir.ui.view">
        <field name="name">printing_history_view_tree</field>
        <field name="model">printing.history</field>
        <field name="arch" type="xml">
            <list edit="0" create="0" delete="0">
                <field name="document_type"/>
                <field name="file_id"/>
                <field name="print_date"/>
                <field name="print_by"/>
            </list>
        </field>
    </record>

    <record id="printing_history_action" model="ir.actions.act_window">
        <field name="name">Printing History</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">printing.history</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem
            id="printing_history_menu"
            name="Printing History"
            parent="allotment.allotment_real_estate_menu"
            action="allotment.printing_history_action"
            sequence="40"
    />
    <record id="allotment.printing_history_rule" model="ir.rule">
        <field name="name">printing_history multi-company</field>
        <field name="model_id" ref="model_printing_history"/>
        <field name="domain_force">
            [
            '|',
            ('file_id.society_id.company_id','=',False),
            ('file_id.society_id.company_id','in',company_ids)
            ]
        </field>
    </record>

</odoo>
