<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_allotment_review" model="res.groups">
        <field name="name">Allotment Review</field>

        <field name="comment">the user will have the access to the review the allotment</field>
    </record>

    <record id="group_allotment_approve" model="res.groups">
        <field name="name">Allotment Approve</field>

        <field name="comment">the user will have the access to the approve the allotment</field>
    </record>

    <record id="group_allotment_print" model="res.groups">
        <field name="name">Allotment Print</field>
        <field name="comment">the user will have the access to the Print the allotment</field>
    </record>

    <record id="group_allotment_issue" model="res.groups">
        <field name="name">Allotment Issuance</field>
        <field name="comment">the user will have the access to the issue the allotment</field>
    </record>

    <record id="group_allotment_cancel" model="res.groups">
        <field name="name">Allotment Cancel</field>
        <field name="comment">the user will have the access to the cancel the allotment</field>
    </record>
    <record id="allotment.allotment_batch_rule" model="ir.rule">
            <field name="name">Allotment Batch multi-company</field>
            <field name="model_id" ref="model_allotment_batch"/>
            <field name="domain_force">
                [
                '|',
                ('company_id','=',False),
                ('company_id','in',company_ids)
                ]
            </field>
        </record>

</odoo>