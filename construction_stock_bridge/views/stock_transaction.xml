<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_transaction_form_bridge_ext" model="ir.ui.view">
        <field name="name">stock.transaction.form.bridge.ext</field>
        <field name="model">stock.transaction</field>
        <field name="inherit_id" ref="supply_chain_customizations.stock_transaction_form"/>
        <field name="arch" type="xml">
            <!-- Add project/task after date -->
            <field name="date" position="after">
                <field name="project_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="task_id"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
            </field>
            <!-- Pass task context to lines -->
            <field name="line_ids" position="attributes">
                <attribute name="context">{'default_task': task_id}</attribute>
            </field>
            <!-- Add cost sheet column after product_id in lines list -->
            <xpath expr="//field[@name='line_ids']//list//field[@name='product_id']" position="after">
                <field name="task_cost_sheet_id"
                       optional="show"
                       options="{'no_quick_create': True, 'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

</odoo>
